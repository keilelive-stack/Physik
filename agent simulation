        "    # Die gekoppelten Differentialgleichungen\n",
        "    d_phi = (a * (1 - gamma) - b * s) * damping_phi\n",
        "    d_gamma = I_in - lam * gamma\n",
        "    d_s = (alpha * gamma - beta * phi) * damping_s\n",
        "    d_delta = kappa * (gamma - phi) - correction\n",
        "\n",
        "    return [d_phi, d_gamma, d_s, d_delta]\n",
        "\n",
        "# --- 2. Parameter und Simulation ---\n",
        "params = (0.5, 0.1, 0.2, 0.4, 0.8, 0.1, 0.1, 10.0, 0.7)\n",
        "t = np.linspace(0, 150, 3000)\n",
        "y0 = [1.0, 0.0, 0.0, 0.0]\n",
        "\n",
        "sol = odeint(ciq_final_model, y0, t, args=params)\n",
        "df_final = pd.DataFrame(sol, columns=['Phi', 'Gamma', 'S', 'Delta'])\n",
        "df_final['Time'] = t\n",
