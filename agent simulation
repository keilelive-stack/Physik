        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "from mpl_toolkits.mplot3d import Axes3D\n",
        "\n",
        "def plot_psi_3d_structure(agent):\n",
        "    # Extract current state from agent (supporting both CPU and GPU)\n",
        "    if agent.use_gpu:\n",
        "        import cupy as cp\n",
        "        psi = cp.asnumpy(agent.psi_gpu).flatten()\n",
        "    else:\n",
