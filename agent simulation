        "\n",
        "    n_states = len(psi)\n",
        "    # Arrange 256 states into a 3D grid (approx 6x6x7)\n",
        "    side = int(np.ceil(n_states**(1/3)))\n",
        "    x, y, z = np.meshgrid(np.arange(side), np.arange(side), np.arange(side))\n",
        "    x, y, z = x.flatten()[:n_states], y.flatten()[:n_states], z.flatten()[:n_states]\n",
        "\n",
        "    amplitudes = np.abs(psi)**2\n",
        "    phases = np.angle(psi)\n",
        "\n",
        "    fig = plt.figure(figsize=(12, 10))\n",
        "    ax = fig.add_subplot(111, projection='3d')\n",
        "\n",
        "    # Scale bubble sizes for visibility: base size + probability weight\n",
        "    sizes = amplitudes * 8000 + 20\n",
        "    sc = ax.scatter(x, y, z, c=phases, s=sizes, cmap='hsv', alpha=0.7, edgecolors='w')\n",
        "\n",
        "    ax.set_title(f\"3D CIQ Wavefunction Topology\\nFrame: {agent.frame_counter} | H: {agent.H_local:.2f}\", fontsize=15)\n",
