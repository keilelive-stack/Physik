        "\n",
        "# --- 1. Die finale stabilisierte CIQ-Weltformel (v335-338) ---\n",
        "def ciq_final_model(y, t, a, b, alpha, beta, lam, kappa, I_in, K, delta_crit):\n",
        "    phi, gamma, s, delta = y\n",
        "\n",
        "    # Kapazitäts-Dämpfung (Logistische Sättigung)\n",
        "    damping_phi = (1 - phi/K)\n",
        "    damping_s = (1 - abs(s)/K)\n",
        "\n",
        "    # Sigmoid-Korrektur für den Drift (Weicher Schwellenwert)\n",
        "    k_smooth = 10.0\n",
        "    soft_switch = 1.0 / (1.0 + np.exp(-k_smooth * (abs(delta) - delta_crit)))\n",
        "    correction = 5.0 * delta * soft_switch\n",
