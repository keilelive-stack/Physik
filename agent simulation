        "    plt.plot(df['Phi'], label='Kohärenz')\n",
        "    plt.plot(df['S'], label='Speicher')\n",
        "    plt.title('CIQ Stabilisierte Realitätsmetrik')\n",
        "    plt.legend()\n",
        "    plt.show()\n",
        "\"\"\"\n",
