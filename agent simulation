        "\n",
        "try:\n",
        "    import cupy as cp\n",
        "    GPU_AVAILABLE = True\n",
        "except ImportError:\n",
        "    GPU_AVAILABLE = False\n",
        "    cp = None\n",
        "\n",
        "class CIQ_Quantum_Agent:\n",
        "    def __init__(self, use_gpu=True):\n",
        "        self.N = 8\n",
        "        self.mu = 0.08\n",
        "        self.use_gpu = use_gpu and GPU_AVAILABLE\n",
        "\n",
        "        # Stabilisierungsparameter v335-338\n",
        "        self.K = 10.0\n",
        "        self.delta_crit = 0.7\n",
        "        self.a, self.b = 0.5, 0.1\n",
        "        self.alpha, self.beta = 0.2, 0.4\n",
        "        self.lam, self.kappa = 0.8, 0.1\n",
        "        self.I_in = 0.1\n",
        "\n",
        "        # State Variables\n",
        "        self.phi = 1.0\n",
        "        self.gamma = 0.0\n",
        "        self.S_DM = 0.0\n",
        "        self.Delta = 0.0\n",
        "        self.R = 1.0\n",
        "        self.H_local = 70.0\n",
        "        self.rho_DE = 0.7\n",
        "        self.rho_DM = 0.25\n",
        "\n",
        "        self.psi_cpu = tensor([basis(2, 0)] * self.N)\n",
        "        self.H_q = self._create_orchestra_hamiltonian()\n",
        "\n",
        "        if self.use_gpu:\n",
        "            self.H_q_gpu = cp.asarray(self.H_q.full().astype(np.complex128))\n",
        "            self.psi_gpu = cp.asarray(self.psi_cpu.full().astype(np.complex128))\n",
        "            self.U_gpu = cp.linalg.expm(-1j * 0.01 * self.mu * self.H_q_gpu)\n",
        "\n",
        "        self.frame_counter = 0\n",
        "        self.cosmo_history = {'a': [], 'rho_DE': [], 'rho_DM': [], 'H': []}\n",
        "\n",
        "        self.real_particles = {\n",
        "            'Elektron': {'omega': 7.8e20},\n",
        "            'Proton': {'omega': 1.42e24},\n",
        "            'Higgs (LHC)': {'omega': 3.02e25},\n",
        "            'Top Quark (LHC)': {'omega': 4.18e25},\n",
        "            'W-Boson (LHC)': {'omega': 1.94e25},\n",
        "            'Z-Boson (LHC)': {'omega': 2.20e25},\n",
        "            'High-z Galaxy (JWST)': {'omega': 1.0e18},\n",
        "            'Primordial BH': {'omega': 5.0e16},\n",
        "            'p (Baryon)': {'omega': 1.0e20},\n",
        "            'Omega (Meson)': {'omega': 6.0e20}\n",
        "        }\n",
        "\n",
        "    def _create_orchestra_hamiltonian(self):\n",
        "        N = self.N; H = 0\n",
        "        for i in range(N):\n",
        "            op = [sigmaz() if j == i else qeye(2) for j in range(N)]\n",
        "            H += tensor(op)\n",
        "        return H\n",
        "\n",
        "    def calculate_quantum_term(self):\n",
        "        if self.use_gpu:\n",
        "            self.psi_gpu = self.U_gpu @ self.psi_gpu\n",
        "            return cp.real(cp.vdot(self.psi_gpu.conj(), self.H_q_gpu @ self.psi_gpu)).get() * self.mu\n",
        "        else:\n",
        "            U = (-1j * self.H_q * 0.01 * self.mu).expm()\n",
        "            self.psi_cpu = U * self.psi_cpu\n",
        "            return expect(self.H_q, self.psi_cpu) * self.mu\n",
        "\n",
        "    def get_total_magnetization(self):\n",
        "        return self.calculate_quantum_term() / self.mu / self.N\n",
        "\n",
        "    def ciq_ode_step(self, dt=0.01, cosmic_time=0.0):\n",
        "        q_val = self.calculate_quantum_term()\n",
        "        q_boost = np.real(np.exp(1j * q_val))\n",
        "\n",
        "        damping_phi = (1 - self.phi/self.K)\n",
        "        damping_s = (1 - abs(self.S_DM)/self.K)\n",
        "\n",
        "        k_smooth = 10.0\n",
        "        soft_switch = 1.0 / (1.0 + np.exp(-k_smooth * (abs(self.Delta) - self.delta_crit)))\n",
        "        correction = 5.0 * self.Delta * soft_switch\n",
        "\n",
        "        dphi = (self.a * (1 - self.gamma) - self.b * self.S_DM) * damping_phi\n",
        "        dgamma = self.I_in - self.lam * self.gamma\n",
        "        dS = (self.alpha * self.gamma - self.beta * self.phi) * damping_s\n",
        "        ddelta = self.kappa * (self.gamma - self.phi) - correction\n",
        "\n",
        "        self.phi += dphi * dt * q_boost\n",
        "        self.gamma += dgamma * dt\n",
        "        self.S_DM += dS * dt\n",
        "        self.Delta += ddelta * dt\n",
        "\n",
        "        self.H_local = 68.53 * (1 + 0.1 * self.Delta)\n",
        "        self.frame_counter += 1\n",
        "\n",
        "        return self.phi, self.S_DM, self.R, 1.0, self.H_local\n",
        "\n",
        "    def real_data_neugier_scan(self):\n",
        "        print('--- LHC & JWST Neugier-Scan started ---')\n",
        "        for name, data in self.real_particles.items():\n",
        "            omega = data.get('omega', 1e20)\n",
        "            chi = 0.42 * (omega / 1e20)\n",
        "            print(f'{name:<22} | chi: {chi:.3f} | SPI: STABIL')\n",
        "\n",
        "    def run_interactive_20ms_loop(self, max_frames=500):\n",
        "        for frame in range(max_frames):\n",
        "            self.ciq_ode_step(dt=0.01)"
