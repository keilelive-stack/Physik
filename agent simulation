        "import zipfile\n",
        "import os\n",
        "from google.colab import files\n",
        "\n",
        "# --- 1. Definition des Master-Skripts mit integrierter v335-338 Logik ---\n",
        "master_script_content = r\"\"\"\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy.integrate import odeint\n",
        "\n",
        "class CIQ_Master_Engine:\n",
        "    def __init__(self):\n",
        "        # Stabilisierte Parameter v335-338\n",
        "        self.a, self.b = 0.5, 0.1\n",
        "        self.alpha, self.beta = 0.2, 0.4\n",
        "        self.lam, self.kappa = 0.8, 0.1\n",
        "        self.I_in = 0.1\n",
        "        self.K = 10.0\n",
        "        self.delta_crit = 0.7\n",
        "\n",
        "    def model(self, y, t):\n",
        "        phi, gamma, s, delta = y\n",
        "        damping_phi = (1 - phi/self.K)\n",
        "        damping_s = (1 - abs(s)/self.K)\n",
        "\n",
        "        # Sigmoid-Korrektur (Der 'Echtzeit-Patch')\n",
        "        k_smooth = 10.0\n",
        "        soft_switch = 1.0 / (1.0 + np.exp(-k_smooth * (abs(delta) - self.delta_crit)))\n",
        "        correction = 5.0 * delta * soft_switch\n",
        "\n",
        "        d_phi = (self.a * (1 - gamma) - self.b * s) * damping_phi\n",
        "        d_gamma = self.I_in - self.lam * gamma\n",
        "        d_s = (self.alpha * gamma - self.beta * phi) * damping_s\n",
        "        d_delta = self.kappa * (gamma - phi) - correction\n",
        "        return [d_phi, d_gamma, d_s, d_delta]\n",
        "\n",
        "    def run(self, duration=150):\n",
        "        t = np.linspace(0, duration, 3000)\n",
        "        y0 = [1.0, 0.0, 0.0, 0.0]\n",
        "        sol = odeint(self.model, y0, t)\n",
        "        return pd.DataFrame(sol, columns=['Phi', 'Gamma', 'S', 'Delta'])\n",
        "\n",
        "# Execution logic\n",
        "if __name__ == '__main__':\n",
        "    engine = CIQ_Master_Engine()\n",
        "    df = engine.run()\n",
        "    print('--- CIQ Master Engine v335-338: Stabilisierung Aktiv ---')\n",
        "    print(f'Finaler Phi-Wert: {df[\"Phi\"].iloc[-1]:.4f}')\n",
