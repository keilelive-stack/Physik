class Agent_XO_v2:
    """
    Korrigierter Agent mit Hazard-Rate-Logik.

    KERNKORREKTUR:
    - q_boost war immer 0 (Real(−i·H·|ψ⟩) = 0 für Pauli-X und |0⟩/|1⟩)
    - Ersetzt durch Hazard-Rate h(u) aus Eisen-Kalibrierung
    - Antizipiert Kollaps (sieht Klippe bevor CI < 0.5)
    - Kalibriert auf Fe-56 Isotop-Resonanz bei u=0.725
    """

    def __init__(self, regime="Kosmos_DESI"):
        self.eisen = EisenKalibrierung()
        self.regime = regime
        self.history = []

        # Schwellen aus Hazard-Rate-Analyse
        self.H_CLIFF_WARNING  = 2.0   # Klippe wird steil
        self.H_COLLAPSE       = 4.0   # Kritischer Kollaps
        self.CI_FLOOR         = EisenKalibrierung.E_CONST  # 0.3738

        # Eisen-Kipppunkt Tracking
        self.iron_trigger_count = 0
        self.last_trigger_c = None

    def evaluate(self, state_vector):
        """
        Bewertet den Systemzustand und entscheidet Aktion.
        Verwendet Hazard-Rate statt des kaputten q_boost.
        """
        z, m, q, a, b, c, e = state_vector

        # Continuity als normierte Zeit u für die Eisen-Kalibrierung
        # c=0.7 entspricht u≈0.5 (stabiler Bereich)
        # c=7.91 entspricht u≈1.2 (Kollaps-Zone)
        u = c / (2 * self.eisen.U_EISEN_ANKER * 5.0)  # Normierung auf [0,1.5]
        u = np.clip(u, 0.001, 2.0)

        ci = self.eisen.ci(u, self.regime)
        h_u = self.eisen.hazard_rate(u, self.regime)

        # Entscheidungslogik basierend auf Hazard-Rate
        status = "STABIL"
        actions = []

        if h_u > self.H_COLLAPSE or u >= self.eisen.U_EISEN_ANKER:
            status = "CRITICAL_COLLAPSE"
            actions.append("TRIGGER_DELTA_I_PROTECTION")

        elif h_u > self.H_CLIFF_WARNING:
            status = "CLIFF_APPROACH"
            actions.append("PREPARE_ZETA_SHIELD")

        # Eisen-Kipppunkt: Katalysator-Effekt
        if ci < self.CI_FLOOR:
            actions.append("IRON_CATALYST_BOUNCE")
            self.iron_trigger_count += 1
            self.last_trigger_c = c

        # Standard CIQ-Schwellen
        if c < 0.7:
            actions.append("TRIGGER_SINGULARITY_PATCH")

        if m < -0.1:  # Möbius nach Symmetriebruch
            actions.append("MOEBIUS_STABILIZATION")

        log = {
            "state": state_vector,
            "u": round(u, 4),
            "ci": round(ci, 4),
            "hazard_rate": round(h_u, 4),
            "status": status,
            "actions": actions
        }
        self.history.append(log)
        return log

    def get_iron_summary(self):
        return {
            "total_triggers": self.iron_trigger_count,
            "last_c": self.last_trigger_c,
            "ci_floor": round(self.CI_FLOOR, 4)
        }


