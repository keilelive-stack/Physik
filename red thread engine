class CIQ_Earth_Agent_v2:
    """
    Korrigierter Erd-Agent (ersetzt Iridium_Iron_Credit + Agenten_logic).
    Trigger basiert auf e_bit direkt — NICHT auf e_bit * q_boost (der immer 0 war).
    """

    def __init__(self):
        self.k_B = 1.380649e-23
        self.hbar = 1.054571817e-34
        self.c = 299792458
        self.G = 6.67430e-11
        self.r_scale = 1e-10
        self.E_binding_iron = 8.8e-13  # Fe-56: 8.8 MeV/Nukleon in Joule
        self.T_ambient = 288
        self.complexity_level = "Reptilien-Gleichgewicht"

        # Hazard-Rate-basierter Trigger
        self.agent_xo = Agent_XO_v2()

    def calculate_ebit(self, T):
        e_thermal = self.k_B * T * np.log(2)
        e_quantum = (self.hbar * self.c) / (2 * self.r_scale)
        e_base = e_thermal + e_quantum
        coupling = self.G / (self.r_scale * self.c**4)
        discriminant = 1 - 4 * coupling * e_base
        return e_base, discriminant

    def simulate_impact(self, external_energy_joule):
        t_peak = self.T_ambient + (external_energy_joule * 1e-25)
        e_bit, discriminant = self.calculate_ebit(t_peak)

        # KORRIGIERT: direkte Schwelle, kein q_boost
        trigger = (e_bit >= self.E_binding_iron * 0.1) or (discriminant < 0)

        if trigger:
            self.complexity_level = "Säugetier/Bewusstsein-Gleichgewicht"
            return (
                f"!!! K-Pg BOUNCE !!!\n"
                f"E_bit = {e_bit:.2e} J (Schwelle: {self.E_binding_iron*0.1:.2e} J)\n"
                f"Diskriminante: {discriminant:.6f}\n"
                f"Neuer Zustand: {self.complexity_level}"
            )
        return f"Stabil. E_bit={e_bit:.2e} J < Eisen-Limit."


class CIQ_Insolvency_Agent_v2:
    """
    Korrigierter Insolvenz-Agent (ersetzt Missing_point_script).
    KORREKTUR: Bounce-Logik war invertiert (z >= LIMIT_Z verhinderte Bounce).
    """

    def __init__(self):
        self.k_B = 1.380649e-23
        self.hbar = 1.054571817e-34
        self.c = 299792458
        self.G = 6.67430e-11
        self.E_binding_iron = 8.8e-13
        self.z_initial = 0.35     # KORRIGIERT: war 0.7, Bounce braucht z < LIMIT_Z
        self.LIMIT_Z = 0.4        # Kipppunkt
        self.entropy_debt = 0.0

        # Hazard-Rate Trigger
        self.eisen = EisenKalibrierung()

    def calculate_ebit(self, T, r):
        e_thermal = self.k_B * T * np.log(2)
        e_quantum = (self.hbar * self.c) / (2 * r)
        e_base = e_thermal + e_quantum
        coupling = self.G / (r * self.c**4)
        discriminant = 1 - 4 * coupling * e_base
        return e_base, discriminant

    def simulate(self, T, r):
        z = self.z_initial
        e_bit, discriminant = self.calculate_ebit(T, r)

        # Hazard-Rate als primärer Trigger
        u = min(r / (self.eisen.U_EISEN_ANKER * 1e-35), 2.0)
        h_u = self.eisen.hazard_rate(u)

        trigger = (discriminant < 0) or (h_u > 4.0)

        if trigger:
            # KORRIGIERT: Bounce wenn z < LIMIT_Z (war vorher invertiert)
            if z < self.LIMIT_Z:
                self.entropy_debt += e_bit
                return (
                    f"!!! INSOLVENZ-BOUNCE !!!\n"
                    f"z={z:.2f} < LIMIT_Z={self.LIMIT_Z} → Bounce aktiv\n"
                    f"Hazard-Rate: {h_u:.4f}, Diskriminante: {discriminant:.4e}\n"
                    f"Entropie-Schuld: {self.entropy_debt:.2e} J"
                )
            else:
                return f"Divergenz (z={z:.2f} >= {self.LIMIT_Z}): Kein Bounce möglich."
        return f"Stabil. Hazard={h_u:.4f}, disc={discriminant:.4f}"


class CIQ_Cosmic_Zins_Agent_v2:
    """
    Korrigierter Kosmischer Zinssatz-Agent.
    KORREKTUR: extra_term = 1 + H_0*r_scale/c war immer 2.0 (bedeutungslos).
    Jetzt: Standard-Diskriminante ohne künstlichen Faktor.
    """

    def __init__(self):
        self.k_B  = 1.380649e-23
        self.hbar = 1.054571817e-34
        self.c    = 299792458
        self.G    = 6.67430e-11
        self.H_0  = 70e3 / 3.086e19       # Hubble-Konstante in 1/s
        self.LIMIT_TENSION = 0.1
        self.entropy_debt = 0.0
        self.eisen = EisenKalibrierung()

    def calculate_ebit(self, T, r_scale):
        e_thermal = self.k_B * T * np.log(2)
        e_quantum = (self.hbar * self.c) / (2 * r_scale)
        e_base = e_thermal + e_quantum

        # KORRIGIERT: Standard-Diskriminante ohne extra_term=2
        # Original: 1 - 4*coupling*e_base*(1 + H_0*r_scale/c)
        # Fehler:   H_0*(c/H_0)/c = 1 → extra_term = 2 immer
        coupling = self.G / (r_scale * self.c**4)
        discriminant = 1 - 4 * coupling * e_base  # Korrekte Formel
        return e_base, discriminant

    def simulate(self, H_0_measured):
        tension = abs(H_0_measured - self.H_0) / self.H_0
        r_scale = self.c / H_0_measured

        e_bit, discriminant = self.calculate_ebit(T=2.7, r_scale=r_scale)

        # Hazard-Rate auf Hubble-Skala
        u_hubble = min(tension * 5, 2.0)  # Tension → normierte Zeit
        h_u = self.eisen.hazard_rate(u_hubble)

        trigger = (tension > self.LIMIT_TENSION) or (discriminant < 0)

        if trigger:
            self.entropy_debt += e_bit * tension
            return (
                f"!!! KOSMISCHER BOUNCE !!!\n"
                f"Tension: {tension:.4f} (Limit: {self.LIMIT_TENSION})\n"
                f"Hazard-Rate: {h_u:.4f}\n"
                f"Diskriminante: {discriminant:.6f}\n"
                f"Entropie-Schuld: {self.entropy_debt:.2e} J"
            )
        return f"Stabil. Tension={tension:.4f}, H_u={h_u:.4f}"


