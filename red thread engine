class EisenKalibrierung:
    """
    Kalibrierungsparameter aus den Real-Data-Fits (Audit Sept 2025).
    Drei Regime die alle mit CI(u) = exp(-A*u - B*u^n) beschrieben werden.
    """
    REGIMES = {
        "Kosmos_DESI":   {"A": 0.584,   "B": 1.034,  "n": 4.0},   # Steilste Klippe
        "Neuro_EEG":     {"A": 2.1063,  "B": 3.5411, "n": 1.965}, # Quadratisch
        "Bio_Calcium":   {"A": 1.25,    "B": 0.0,    "n": 1.5},   # Einfach exponentiell
    }

    # Fe-56 Fixpunkt: u bei dem CI am stärksten knickt (Bindungsenergie-Maximum)
    U_EISEN_ANKER = 0.725

    # Eisengarn-Konstante: Mindest-CI am Fixpunkt für stabilen Bounce
    E_CONST = np.exp(-(1 - 1/np.sqrt(3840.0)))  # ≈ 0.3738

    @staticmethod
    def ci(u, regime="Kosmos_DESI"):
        p = EisenKalibrierung.REGIMES[regime]
        return np.exp(-p["A"] * u - p["B"] * (u ** p["n"]))

    @staticmethod
    def hazard_rate(u, regime="Kosmos_DESI"):
        """h(u) = A + n·B·u^(n-1) — die Steilheit der Klippe."""
        p = EisenKalibrierung.REGIMES[regime]
        return p["A"] + p["n"] * p["B"] * (u ** (p["n"] - 1))


