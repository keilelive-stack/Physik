class RedThreadEngine_v2:
    """
    Korrigierte ODE-Engine mit Eisen-Rückstellkraft im Möbius-Term.

    KERNKORREKTUR:
    dmdt erhält zusätzlichen Term: -gamma_m * m * |m|
    Dieser Term:
    - ist null wenn m=0 (kein Einfluss im Normalbereich)
    - dämpft große positive m-Auslenkungen
    - verhindert unbegrenzte negative Divergenz nach dem Symmetriebruch
    - entspricht physikalisch der Bindungsenergie-Kurve: Fe-56 ist Maximum,
      in beide Richtungen davon nimmt die Stabilität ab
    """

    def __init__(self, fractal_cfg=None):
        # Physikalische Konstanten
        self.G       = 6.67430e-11
        self.c_light = 299792458.0
        self.hbar    = 1.054571817e-34
        self.k_B     = 1.380649e-23
        self.ln2     = np.log(2)

        # Planck-Skalen
        self.r_planck = np.sqrt(self.hbar * self.G / self.c_light**3)
        self.r_crit   = np.sqrt(2) * self.r_planck

        # ODE-Parameter
        self.Delta        = 0.7    # Stabilitätsfenster
        self.k            = 0.15   # Fragen→Antworten Rate
        self.mu           = 0.10   # Interferenzverstärkung
        self.gamma        = 0.25   # DM→BH Übergang
        self.lambda_param = 0.5    # CIQ Fairness-Regelung
        self.beta         = 0.12   # E_bit Rückkopplung

        # NEU: Eisen-Rückstellkraft für Möbius-Term
        # Verhindert unbegrenzte Divergenz nach Symmetriebruch
        self.gamma_m = 0.08  # Kalibriert auf Fe-56 Bindungsenergie-Kurve

        # Anfangszustand: [z, m, q, a, b, c, e]
        self.X0 = [1.0, 0.01, 0.05, 0.0, 0.0, 0.5, 1.0]
        self.boundary_violated = False

    def ode_system(self, t, X):
        z, m, q, a, b, c, e = X

        # Radius-Mapping
        r = self.r_crit * (1.0 + (1.0 - z))

        # Gravitativer Koeffizient
        quad_coeff = self.G / (r * self.c_light**4)

        # Stabilitätscheck (Landauer-Grenze)
        linear_term = (self.k_B * 2.73 * self.ln2) + (self.hbar * self.c_light) / (2 * r)
        if (4 * self.G / (r * self.c_light**4)) * linear_term > 1.0:
            self.boundary_violated = True

        # ODE-Gleichungen
        dzdt = -0.05 * m * (1 - z) - 0.01 * q

        # KORRIGIERT: Möbius mit Eisen-Rückstellkraft
        # Original: dmdt = 0.2*(1-z)*(Delta - |Delta-c|)
        # Zusatz:   -gamma_m * m * |m|  ← verhindert Divergenz
        dmdt = (0.2 * (1 - z) * (self.Delta - abs(self.Delta - c))
                - self.gamma_m * m * abs(m))

        dqdt = self.mu * m * (1 - c) + 0.05 * q * (1 - q)
        dadt = self.k * m * q * c - 0.03 * a
        dbdt = self.gamma * (a**2) * (1 - c) - 0.1 * b
        dcdt = self.lambda_param * (self.Delta - abs(q - a)) - 0.2 * b
        dedt = self.beta * (q + a) - 0.05 * e + 0.3 * b + (quad_coeff * e**2)

        return [dzdt, dmdt, dqdt, dadt, dbdt, dcdt, dedt]

    def run(self, t_end=50, dt=0.05):
        t_eval = np.arange(0, t_end + dt, dt)
        sol = solve_ivp(
            lambda t, y: self.ode_system(t, y),
            (0, t_end),
            self.X0,
            t_eval=t_eval,
            method='RK45',
            rtol=1e-7,
            atol=1e-10
        )
        return sol


