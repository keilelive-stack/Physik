class OrchestraVisualizer:
    """
    Visualisiert das Quanten-Orchester in einem 8-Panel-Dashboard:
    
    ```
    +-------------+-------------+-------------+
    | Phasenfeld  | Fermion-    | Bosonen-    |
    | Phi(x,y)    | Jazz |nabla Phi|  | Chor g_eff  |
    +-------------+-------------+-------------+
    | Gravitations| Dunkles     | R-S-H       |
    | Bass        | Archiv S_DM | Dynamik     |
    +-------------+-------------+-------------+
    | Radiale Profile           | Eigenzeit   |
    | (Sonifikation)            | & Energie   |
    +---------------------------+-------------+
    
    v5.0: SM-Parameter in Panel-Titeln integriert
    Panel 1: phi_super + m_Z
    Panel 4: cos(theta_W) + m_W/m_Z
    Panel 5: N_nu (Neutrino-Familien)
    """

    def __init__(self, engine):
        self.engine = engine
        self.fig    = None
        self.axes   = {}

    def create_dashboard(self):
        """Erstelle das 8-Panel Dashboard"""
        self.fig = plt.figure(figsize=(20, 14), facecolor='#0a0a1a')
        gs = gridspec.GridSpec(3, 3, hspace=0.35, wspace=0.3,
                               left=0.05, right=0.95, top=0.93, bottom=0.05)

        self.fig.suptitle(
            'CIQ Quanten-Orchester  Akustische Ontologie der Raumzeit  (v5 SM-Integration)',
            fontsize=16, color='#fbbf24', fontweight='bold', y=0.98
        )

        panel_names = [
            ('phase',  gs[0, 0], 'Phasenfeld Phi(x,y)\n"Partitur des Raums"'),
            ('jazz',   gs[0, 1], 'Fermionen-Jazz |nabla Phi|\n"Antisymmetrische Dissonanz"'),
            ('choir',  gs[0, 2], 'Bosonen-Chor g_eff\n"Kohaerente Geometrie"'),
            ('bass',   gs[1, 0], 'Gravitations-Bass\n"Infraschall des Kosmos"'),
            ('sdm',    gs[1, 1], 'Dunkles Archiv S_DM\n"Stumme Resonatoren"'),
            ('rsh',    gs[1, 2], 'R-S-H Dynamik\n"Stabilitaet Q = R/(S+eps)"'),
            ('radial', gs[2, 0:2], 'Radiale Sonifikation\n"Klangprofil der Bubble"'),
            ('zeit',   gs[2, 2], 'Eigenzeit & Energie\n"Takt des Universums"'),
        ]

        for name, spec, title in panel_names:
            ax = self.fig.add_subplot(spec)
            ax.set_facecolor('#0a0a1a')
            ax.set_title(title, color='white', fontsize=10, pad=8)
            ax.tick_params(colors='#888888', labelsize=8)
            for spine in ax.spines.values():
                spine.set_color('#333333')
            self.axes[name] = ax

        return self.fig

    def update(self, frame_label=''):
        """Aktualisiere alle Panels"""
        e   = self.engine
        L   = e.L
        ext = [-L, L, -L, L]

        for ax in self.axes.values():
            ax.clear()
            ax.set_facecolor('#0a0a1a')
            ax.tick_params(colors='#888888', labelsize=8)

        # -- Panel 1: Phasenfeld Phi --
        ax = self.axes['phase']
        ax.imshow(e.Phi, extent=ext, origin='lower', cmap=CMAP_RESONANZ,
                  vmin=-1.5, vmax=1.5)
        ax.set_title(f'Phasenfeld Phi(x,y)  t={e.time:.2f}\n'
                     f'phi_super={e.phi_super:.4f}  |  m_Z={e.m_Z_GeV} GeV',
                     color='white', fontsize=9, pad=6)
        ax.contour(e.X, e.Y, e.Phi, levels=[0], colors='#ff6b6b',
                   linewidths=0.5, alpha=0.7)

        # -- Panel 2: Fermionen-Jazz |nabla Phi| --
        ax = self.axes['jazz']
        grad_y, grad_x = np.gradient(e.Phi, e.dx)
        contrast = np.sqrt(grad_x**2 + grad_y**2)
        ax.imshow(contrast, extent=ext, origin='lower', cmap=CMAP_JAZZ)
        ax.set_title('Fermionen-Jazz |nabla Phi|\n"Phasenkontrast = Klangintensitaet"',
                     color='white', fontsize=9, pad=6)

        # -- Panel 3: Bosonen-Chor g_eff --
        ax = self.axes['choir']
        g_eff = e.compute_geometry()
        ax.imshow(np.log1p(g_eff), extent=ext, origin='lower', cmap=CMAP_CHOR)
        ax.set_title('Bosonen-Chor g_eff(Phi)\n"Emergente Geometrie"',
                     color='white', fontsize=9, pad=6)

        # -- Panel 4: Gravitations-Bass --
        ax = self.axes['bass']
        try:
            bass = e.gravitational_bass()
        except Exception:
            bass = np.zeros_like(e.Phi)
        ax.imshow(np.abs(bass), extent=ext, origin='lower', cmap=CMAP_BASS)
        ax.set_title(f'Gravitations-Bass (Spin-2)\n'
                     f'cos(theta_W)={e.cos_theta_W:.4f} | m_W/m_Z={e.m_W_GeV}/{e.m_Z_GeV}',
                     color='white', fontsize=9, pad=6)

        # -- Panel 5: Dunkles Archiv S_DM --
        ax = self.axes['sdm']
        sdm_display = np.log1p(e.S_DM * 100)
        ax.imshow(sdm_display, extent=ext, origin='lower', cmap=CMAP_SDM)
        ax.set_title(f'Dunkles Archiv S_DM\n'
                     f'Summe(S_DM)={np.sum(e.S_DM):.2f}  N_nu={e.N_nu:.4f}',
                     color='white', fontsize=9, pad=6)

        # -- Panel 6: R-S-H Dynamik --
        ax = self.axes['rsh']
        if len(e.history['time']) > 1:
            t = e.history['time']
            ax.plot(t, e.history['R'], color='#2dd4bf', lw=1.5, label='R (Resonanz)')
            ax.plot(t, e.history['S'], color='#f43f5e', lw=1.5, label='S (Stoerung)')
            ax.plot(t, e.history['H'], color='#a78bfa', lw=1.5, label='H (Harmonie)')
            ax.plot(t, e.history['Q'], color='#fbbf24', lw=2.0,
                    label=f'Q={e.history["Q"][-1]:.2f}', linestyle='--')
            ax.axhline(y=1.0, color='#555555', linestyle=':', alpha=0.5)
            ax.legend(fontsize=7, loc='upper right',
                      facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')
            ax.set_xlabel('Zeit', color='#888', fontsize=8)
        ax.set_title('R-S-H Dynamik\nQ>1=stabil  Q<1=Kollaps',
                     color='white', fontsize=9, pad=6)

        # -- Panel 7: Radiale Sonifikation --
        ax = self.axes['radial']
        center  = e.N // 2
        r_axis  = np.linspace(0, L, center)
        phi_radial      = np.abs(e.Phi[center, center:])
        sdm_radial      = e.S_DM[center, center:]
        g_radial        = g_eff[center, center:]
        contrast_radial = contrast[center, center:]

        ax.fill_between(r_axis, 0, phi_radial * 2, alpha=0.3, color='#2dd4bf',
                        label='Phi "Grundton"')
        ax.plot(r_axis, contrast_radial, color='#d63384', lw=1.5,
                label='|nabla Phi| "Jazz-Intensitaet"')
        ax.plot(r_axis, sdm_radial * 50, color='#9933ff', lw=1.5,
                label='S_DM x50 "Dunkler Nachhall"')
        ax.plot(r_axis, np.log1p(g_radial) * 0.5, color='#66ccff', lw=1.5,
                label='ln(g_eff) "Geometrie"')
        ax.legend(fontsize=7, loc='upper right',
                  facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')
        ax.set_xlabel('Radius r', color='#888', fontsize=8)
        ax.set_ylabel('Amplitude', color='#888', fontsize=8)
        ax.set_title('Radiale Sonifikation\n"Klangprofil der Vakuum-Bubble"',
                     color='white', fontsize=9, pad=6)

        # -- Panel 8: Eigenzeit & Energie --
        ax = self.axes['zeit']
        if len(e.history['time']) > 1:
            t   = e.history['time']
            ax2 = ax.twinx()
            ax.plot(t, e.history['eigenzeit'], color='#fbbf24', lw=1.5,
                    label='dtau/dt Eigenzeit')
            ax2.plot(t, e.history['energy'], color='#f43f5e', lw=1.0,
                     alpha=0.7, label='Energie')
            ax2.plot(t, np.array(e.history['bubble_radius']) / L,
                     color='#2dd4bf', lw=1.0, alpha=0.7, label='R_bubble/L')
            ax.legend(fontsize=7, loc='upper left',
                      facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')
            ax2.legend(fontsize=7, loc='upper right',
                       facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')
            ax2.tick_params(colors='#888888', labelsize=8)
            ax.set_xlabel('Zeit', color='#888', fontsize=8)
        ax.set_title('Eigenzeit & Energie\n"Takt des Universums"',
                     color='white', fontsize=9, pad=6)

        # Zentraler Status-Text (v8: bridge_score ergänzt)
        if e.history["Q"] and e.wf_history["k_eff"]:
            _bsc = (f'br_score={e.bridge_history["bridge_score"][-1]:.3f} | '
                    if e.bridge_history["bridge_score"] else '')
            status = (f'Step {e.step_count} | '
                      f'Q={e.history["Q"][-1]:.2f} | '
                      f'Delta_crit={e.delta_crit} | '
                      f'dtau/dt={e.history["eigenzeit"][-1]:.3f} | '
                      f'cos(theta_W)={e.cos_theta_W:.4f} | '
                      f'norm(Psi)={e.norm_wf:.3f} | '
                      f'k_eff={e.wf_history["k_eff"][-1]:.3f} | '
                      f'v_ph={e.wf_history["v_phase"][-1]:.3f} | '
                      f'v_gr={e.wf_history["v_group"][-1]:.3f} | '
                      + _bsc)
        else:
            status = ''
        self.fig.text(0.5, 0.005, status, ha='center', color='#666',
                      fontsize=9, fontstyle='italic')

    def plot_bridge_score(self):
        """
        Separates Brückenformel-Score-Panel (v8).

        4-Linien-Plot der Brücken-Observablen:
          - S_Pi(t):      QM-Gravitations-Schutzschalter (magenta)
          - A_br_sdm(t):  S_DM-Aktivierungsfaktor (gold)
          - B_rsh(t):     R-S-H bridge_linear-Skalierung (cyan)
          - S_ez(t):      Eigenzeit-Vor-Schalter (violet)
          - bridge_score: hybrid_aggregate Gesamtscore (weiss, lw=2)

        Alle Kurven im Bereich [0,1].
        Horizontale Referenzlinien bei 0.5 (Resonanzpunkt) und 1.0.

        Kann einzeln als PNG gespeichert oder in run_full_dashboard aufgerufen
        werden (speichert als ciq_bridge_score.png).
        """
        e = self.engine
        bh = e.bridge_history

        if not bh['S_Pi']:
            print("  [plot_bridge_score] Keine Brücken-History vorhanden (0 Schritte).")
            return None

        fig, (ax_main, ax_score) = plt.subplots(
            2, 1, figsize=(14, 8), facecolor='#0a0a1a',
            gridspec_kw={'height_ratios': [2, 1], 'hspace': 0.35}
        )
        fig.suptitle(
            'CIQ Brückenformel-Score  U = ∫Psi_bridge(C,B,I,E) dt  (v8)',
            fontsize=14, color='#fbbf24', fontweight='bold', y=0.99
        )

        t = list(range(len(bh['S_Pi'])))

        # -- Oberes Panel: die vier Schalter-Observablen --
        for ax in [ax_main, ax_score]:
            ax.set_facecolor('#0a0a1a')
            ax.tick_params(colors='#888888', labelsize=8)
            for spine in ax.spines.values():
                spine.set_color('#333333')

        ax_main.plot(t, bh['S_Pi'],     color='#e879f9', lw=1.5,
                     label='S_Pi   - QM-Gravitations-Schutzschalter')
        if bh.get('A_br_sdm'):
            ax_main.plot(t, bh['A_br_sdm'], color='#fbbf24', lw=1.2, alpha=0.85,
                         label='A_br_sdm - S_DM-Aktivierungsfaktor')
        if bh.get('B_rsh'):
            ax_main.plot(t, bh['B_rsh'],    color='#2dd4bf', lw=1.2, alpha=0.85,
                         label='B_rsh    - R-S-H bridge_linear')
        if bh.get('S_ez'):
            ax_main.plot(t, bh['S_ez'],     color='#a78bfa', lw=1.2, alpha=0.85,
                         label='S_ez     - Eigenzeit-Vor-Schalter')
        ax_main.axhline(0.5, color='#555555', ls='--', lw=0.8, alpha=0.6,
                        label='0.5 = Resonanzpunkt')
        ax_main.axhline(1.0, color='#333333', ls=':', lw=0.8, alpha=0.5)
        ax_main.set_ylim(-0.05, 1.10)
        ax_main.set_ylabel('Schalter-Wert [0,1]', color='#888', fontsize=9)
        ax_main.set_title(
            'Brückenformel-Schalter: S_Pi / A_br_sdm / B_rsh / S_ez\n'
            '  0 = inaktiv/klassisch   0.5 = Resonanz/Planck-Punkt   1 = Bounce/voll aktiv',
            color='white', fontsize=9, pad=6
        )
        ax_main.legend(fontsize=8, loc='upper left',
                       facecolor='#1a1a2e', edgecolor='#333', labelcolor='white',
                       ncol=2)

        # -- Unteres Panel: hybrid_aggregate bridge_score + U_integral --
        if bh.get('bridge_score'):
            ax_score.plot(t, bh['bridge_score'], color='white', lw=2.0,
                          label='bridge_score (hybrid)')
        ax_score.axhline(0.5, color='#555555', ls='--', lw=0.8, alpha=0.6)

        ax2 = ax_score.twinx()
        if bh.get('U_integral'):
            ax2.plot(t, bh['U_integral'], color='#f43f5e', lw=1.0, alpha=0.7,
                     label='U = ∫Psi_bridge dt')
            ax2.tick_params(colors='#888888', labelsize=8)
            ax2.set_ylabel('U (akkumuliert)', color='#f43f5e', fontsize=8)
            ax2.legend(fontsize=8, loc='upper right',
                       facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')

        ax_score.set_ylabel('bridge_score [0,1]', color='#888', fontsize=9)
        ax_score.set_xlabel('Zeitschritt', color='#888', fontsize=8)
        ax_score.set_ylim(-0.05, 1.10)
        ax_score.set_title(
            'Gesamt-Brückenformel-Score (hybrid_aggregate)  &  U-Integral',
            color='white', fontsize=9, pad=6
        )
        ax_score.legend(fontsize=8, loc='upper left',
                        facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')

        # Zusammenfassungs-Text
        if bh['S_Pi'] and bh.get('bridge_score'):
            _last_bsc = bh['bridge_score'][-1]
            _last_spi = bh['S_Pi'][-1]
            _regime   = ('Bounce'   if _last_spi > 0.75 else
                         'Resonanz' if _last_spi > 0.25 else 'Klassisch')
            fig.text(
                0.5, 0.005,
                f'Letzter Schritt: bridge_score={_last_bsc:.4f} | '
                f'S_Pi={_last_spi:.4f} | Regime: {_regime} | '
                f'U={bh["U_integral"][-1]:.4f}',
                ha='center', color='#666', fontsize=9, fontstyle='italic'
            )

        return fig

    def save_frame(self, filename):
        self.fig.savefig(filename, dpi=150, facecolor='#0a0a1a',
                         edgecolor='none', bbox_inches='tight')

    def plot_gp_drift(self):
        """
        GP-Energiedrift-Dashboard (v10).

        Zeigt ueber alle bisher gelaufenen Schritte:
          - E_gp_tot(t):            GP-Gesamtenergie (Erhaltungsgroesse)
          - |E_gp_tot - E0|  (log): Drift ab Startenergie
          - E_gp_kin/trap/int(t):   Energiekomponenten
          - norm_raw(t):            Unitaritaetsdrift des GP-Propagators

        Speichert 'ciq_gp_drift.png' und gibt fig zurueck.
        Funktioniert nur wenn engine.use_gp=True und min. 1 GP-Schritt gelaufen.
        """
        e  = self.engine
        wh = e.wf_history

        if not wh.get('E_gp_tot') or len(wh['E_gp_tot']) == 0:
            print("  [plot_gp_drift] Keine GP-History (use_gp=False oder 0 Schritte).")
            return None

        steps   = np.arange(1, len(wh['E_gp_tot']) + 1)
        E_tot   = np.array(wh['E_gp_tot'])
        E_kin   = np.array(wh['E_gp_kin'])
        E_trap  = np.array(wh['E_gp_trap'])
        E_int   = np.array(wh['E_gp_int'])
        E_drift = np.array(wh['E_gp_drift'])
        E0      = e._E_gp_0 if e._E_gp_0 is not None else E_tot[0]
        nr_raw  = np.array(wh.get('norm_raw', []))
        # norm_raw kann laenger sein (CIQ-Felder werden auch ohne GP aufgezeichnet)
        nr_raw  = nr_raw[:len(steps)] if len(nr_raw) >= len(steps) else nr_raw

        CBCK = '#09091a'
        CPAN = '#0e0e24'
        CT   = '#ff5555'
        CS   = '#55aaff'
        CK   = '#fbbf24'
        CTR  = '#2dd4bf'
        CI   = '#a78bfa'
        CTEXT= '#eef2ff'
        CGRID= '#252555'

        fig = plt.figure(figsize=(20, 14), facecolor=CBCK)
        gs  = gridspec.GridSpec(3, 3, figure=fig, hspace=0.44, wspace=0.33)

        def _ax(g, title, ylabel, xlabel='Schritt'):
            ax = fig.add_subplot(g)
            ax.set_facecolor(CPAN)
            ax.set_title(title, color=CTEXT, fontsize=9.5, pad=7, fontweight='bold')
            ax.set_ylabel(ylabel, color=CTEXT, fontsize=8.5)
            ax.set_xlabel(xlabel, color=CTEXT, fontsize=8.5)
            ax.tick_params(colors=CTEXT, labelsize=7.5)
            for sp in ax.spines.values(): sp.set_color('#334477')
            ax.grid(True, color=CGRID, lw=0.5, alpha=0.7)
            return ax

        # P1: E_gp_tot
        ax = _ax(gs[0, 0], 'E_GP_tot  (GP-Gesamtenergie)\nIdeal = E0 = konstant', 'E_GP')
        ax.plot(steps, E_tot, color=CT, lw=1.4, alpha=0.9, label='E_GP_tot')
        ax.axhline(E0, color='#99ffaa', lw=1.0, ls='--', alpha=0.7,
                   label=f'E0 = {E0:.5f}')
        ax.legend(fontsize=7.5, facecolor='#0d0d25', labelcolor=CTEXT,
                  framealpha=0.95, edgecolor='#445599')

        # P2: |E_gp_tot - E0|  log
        ax = _ax(gs[0, 1], '|E_GP − E0|  (log-Skala)\nEnergiedrift ab Startenergie', '|E_GP − E0|')
        ax.semilogy(steps, E_drift + 1e-30, color=CT, lw=1.4, alpha=0.9,
                    label=f'mean={E_drift.mean():.3e}  final={E_drift[-1]:.3e}')
        ax.legend(fontsize=7.5, facecolor='#0d0d25', labelcolor=CTEXT,
                  framealpha=0.95, edgecolor='#445599')

        # P3: Energiekomponenten
        ax = _ax(gs[0, 2], 'GP-Energie-Komponenten\nE_kin + E_trap + E_int = E_tot', 'Energie')
        ax.plot(steps, E_kin,  color=CK,  lw=1.2, alpha=0.85, label='E_kin  (kinetisch)')
        ax.plot(steps, E_trap, color=CTR, lw=1.2, alpha=0.85, label='E_trap  (Falle pot_b*r²)')
        ax.plot(steps, E_int,  color=CI,  lw=1.2, alpha=0.85, label='E_int  (g/2*|Ψ|⁴)')
        ax.legend(fontsize=7.5, facecolor='#0d0d25', labelcolor=CTEXT,
                  framealpha=0.95, edgecolor='#445599')

        # P4: norm_raw des CIQ-Propagators (zum Vergleich)
        ax = _ax(gs[1, 0], 'norm_raw  (CIQ-Propagator ‖Ψ‖²)\n1.0 = unitär', '‖Ψ‖²')
        if len(nr_raw) > 0:
            ax.plot(np.arange(1, len(nr_raw)+1), nr_raw, color=CS, lw=1.2, alpha=0.85)
            ax.axhline(1.0, color='#99ffaa', lw=0.8, ls='--', alpha=0.5)

        # P5: E_drift kumuliert (Integral der Drift)
        ax = _ax(gs[1, 1], 'Kumulierte E_GP-Drift  ∑|ΔE|\nWachstumsrate zeigt O(dt³)-Akkumulation',
                 '∑|E_GP − E0|')
        ax.plot(steps, np.cumsum(E_drift), color='#ff9955', lw=1.4, alpha=0.9)

        # P6: dE_drift/dt (Drift-Rate)
        ax = _ax(gs[1, 2], 'Drift-Rate  d|ΔE|/dt\nSollte bei Strang O(dt²) bleiben', 'd|ΔE|/dt')
        if len(E_drift) > 1:
            dEdrift = np.diff(E_drift, prepend=E_drift[0])
            ax.semilogy(steps, np.abs(dEdrift) + 1e-30, color='#ff9955', lw=1.0, alpha=0.85)

        # P7: E_kin vs E_int (Konkurrenzdynamik)
        ax = _ax(gs[2, 0], 'E_kin vs E_int  (Virialtheorem-Check)\nE_kin + E_trap/2 ~ E_int/2 (TF-Limit)',
                 'Energie')
        ax.plot(steps, E_kin,        color=CK,  lw=1.2, alpha=0.85, label='E_kin')
        ax.plot(steps, E_int,        color=CI,  lw=1.2, alpha=0.85, label='E_int')
        ax.plot(steps, E_kin + E_int, color=CT, lw=1.0, alpha=0.6,  label='E_kin+E_int', ls='--')
        ax.legend(fontsize=7.5, facecolor='#0d0d25', labelcolor=CTEXT,
                  framealpha=0.95, edgecolor='#445599')

        # P8: E_gp_tot Residuum (Hochpassfilter: E - gleitender Mittelwert)
        ax = _ax(gs[2, 1], 'E_GP Residuum  (E − gleit. Mittelwert)\nHochfrequente Propagatorfehler',
                 'E_GP − <E_GP>_w')
        window = max(10, len(E_tot) // 20)
        E_smooth = np.convolve(E_tot, np.ones(window)/window, mode='same')
        ax.plot(steps, E_tot - E_smooth, color='#f59e0b', lw=0.9, alpha=0.85)
        ax.axhline(0, color='#99ffaa', lw=0.7, ls='--', alpha=0.4)

        # P9: Zusammenfassung
        ax9 = fig.add_subplot(gs[2, 2])
        ax9.set_facecolor(CPAN)
        ax9.axis('off')
        lines = [
            "GP-PROPAGATOR-ZUSAMMENFASSUNG (v10)",
            f"g_gp={e.g_gp}  pot_b={e.potential_b}",
            f"N={e.N}  dt={e.dt}  Steps={len(steps)}",
            "",
            f"Startenergie E0:",
            f"  {E0:.7f}",
            "",
            f"|E_GP − E0|:",
            f"  mean  = {E_drift.mean():.4e}",
            f"  std   = {E_drift.std():.4e}",
            f"  max   = {E_drift.max():.4e}",
            f"  final = {E_drift[-1]:.4e}",
            "",
            f"norm_raw (CIQ):",
            f"  mean  = {nr_raw.mean():.4e}" if len(nr_raw) > 0 else "  (nicht verfuegbar)",
            "",
            f"E_kin  final = {E_kin[-1]:.5f}",
            f"E_trap final = {E_trap[-1]:.5f}",
            f"E_int  final = {E_int[-1]:.5f}",
        ]
        for i, line in enumerate(lines):
            bold  = i in (0, 7, 13)
            color = '#ffcc44' if i == 0 else CTEXT
            ax9.text(0.04, 0.98 - i * 0.052, line,
                     transform=ax9.transAxes, color=color,
                     fontsize=8.0, va='top', fontweight='bold' if bold else 'normal',
                     fontfamily='monospace')

        # Haupttitel
        fig.suptitle(
