class PotentialStufe:
    """
    Endliche Potentialstufe (PDF Kap. 1.3.3, S. 70-75):
    
    ```
    U(x) = U1  fuer x > 0
    U2  fuer x < 0   (U2 > U1)
    
    Fall i)  U2 > epsilon > U1 :
    k1 = sqrt(epsilon - U1)
    kappa2 = sqrt(U2 - epsilon)
    phi  = arctan(k1/kappa2)
    A2/A1 = sin(phi) = sqrt((epsilon-U1)/(U2-U1))
    psi(x) = { A1*sin(k1*x + phi)   x > 0  (oszillatorisch)
    { A2*exp(kappa2*x)      x < 0  (exponentiell abfallend)
    
    Fall ii) epsilon > U2 :
    k1 = sqrt(epsilon - U1),  k2 = sqrt(epsilon - U2)
    r = (k1-k2)/(k1+k2)       (Fresnelanalog: Amplitudenreflexion)
    t = 1 + r = 2*k1/(k1+k2)  (Amplitudentransmission)
    R = |r|^2,  T = (k2/k1)*|t|^2 = 4*k1*k2/(k1+k2)^2
    R + T = 1  (Erhaltungssatz der Wahrscheinlichkeit)
    """
    def __init__(self, U1=0.0, U2=3.0, hbar=HBAR_NORM, m=M_NORM):
        self.U1   = float(U1)
        self.U2   = float(U2)
        self.hbar = float(hbar)
        self.m    = float(m)

    def koeffizienten_fall_i(self, epsilon):
        """Stetigkeitsbedingungen fuer Fall i: U2 > epsilon > U1"""
        assert self.U1 < epsilon < self.U2, "epsilon muss U1 < epsilon < U2 erfuellen"
        k1     = np.sqrt(epsilon - self.U1)
        kappa2 = np.sqrt(self.U2 - epsilon)
        phi    = np.arctan2(k1, kappa2)        # = arctan(k1/kappa2)
        A2_A1  = np.sin(phi)                   # = sqrt((epsilon-U1)/(U2-U1))
        return {'k1': k1, 'kappa2': kappa2, 'phi': phi, 'A2_A1': A2_A1}

    def reflexion_transmission_fall_ii(self, epsilon):
        """Reflexions- und Transmissionskoeffizienten fuer Fall ii: epsilon > U2"""
        assert epsilon > self.U2, "epsilon muss groesser als U2 sein"
        k1 = np.sqrt(epsilon - self.U1)
        k2 = np.sqrt(epsilon - self.U2)
        r  = (k1 - k2) / (k1 + k2)
        t  = 2 * k1 / (k1 + k2)          # = 1 + r
        R  = r**2
        T  = (k2 / k1) * t**2            # = 4*k1*k2/(k1+k2)^2
        return {'k1': k1, 'k2': k2, 'r': r, 't': t, 'R': R, 'T': T}

    def wellenfunktion_fall_i(self, x_arr, epsilon, A1=1.0):
        """psi(x) fuer Fall i: x>0 oszillatorisch, x<0 exponentiell"""
        c  = self.koeffizienten_fall_i(epsilon)
        k1, kappa2, phi, A2_A1 = c['k1'], c['kappa2'], c['phi'], c['A2_A1']
        A2 = A1 * A2_A1
        return np.where(x_arr >= 0,
                        A1 * np.sin(k1 * x_arr + phi),
                        A2 * np.exp(kappa2 * x_arr))

    def wellenfunktion_fall_ii(self, x_arr, epsilon):
        """Realteil von psi(x) fuer Fall ii: oszillatorisch ueberall"""
        c  = self.reflexion_transmission_fall_ii(epsilon)
        k1, k2, r, t = c['k1'], c['k2'], c['r'], c['t']
        return np.where(x_arr >= 0,
                        np.cos(-k1*x_arr) + r * np.cos(k1*x_arr),
                        t * np.cos(-k2*x_arr))

    def scan_RT(self, epsilon_arr):
        """R(epsilon) und T(epsilon) fuer einen Energie-Scan"""
        R_arr, T_arr = [], []
        for eps in epsilon_arr:
            if eps > self.U2:
                c = self.reflexion_transmission_fall_ii(eps)
                R_arr.append(c['R']); T_arr.append(c['T'])
            else:
                R_arr.append(1.0); T_arr.append(0.0)
        return np.array(R_arr), np.array(T_arr)

