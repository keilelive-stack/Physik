def compute_paper_metrics(engine):
    """
    Berechnet alle Paper-Ready Metriken in einem Aufruf.
    Verwendung: metrics = compute_paper_metrics(engine)

    Rückgabe:
        dict mit allen drei Schwachstellen behoben:
        - bridge: vollständige Brückenformel-Metriken
        - sdm:    messbare S_DM-Observablen
        - grav:   explizite Gravitationsgrößen

    Für Plots:
        engine.bridge_history, engine.sdm_obs_history, engine.grav_history
    """
    # Initialisierung der Hilfsklassen
    if not hasattr(engine, '_bridge_explicit'):
        engine._bridge_explicit = BrueckenformelExplizit(
            alpha=engine.__dict__.get('alpha_br', 0.05),
            beta=engine.__dict__.get('beta_br', 0.02),
            gamma=engine.__dict__.get('gamma_br', 0.03),
            delta=engine.__dict__.get('delta_br', 0.10),
            zeta=engine.__dict__.get('zeta_br', 0.08),
        )
    if not hasattr(engine, '_sdm_obs'):
        engine._sdm_obs = SDMObservables()
    if not hasattr(engine, '_ciq_grav'):
        engine._ciq_grav = CIQGravitation()
    if not hasattr(engine, 'sdm_obs_history'):
        engine.sdm_obs_history = {
            'sigma_v_eff': [], 'f_dm': [], 'sdm_mean': [], 'H': [],
            'rho_tot': [], 'bounce_ratio': [], 'Delta': [], 'S_grav': [], 'P_grav': []
        }
    if not hasattr(engine, 'grav_history'):
        engine.grav_history = {
            'H': [], 'H2': [], 'rho_tot': [], 'bounce_ratio': [],
            'Delta': [], 'S_grav': [], 'P_grav': [],
            'Phi_G_max': [], 'Phi_G_mean': []
        }

    br  = engine._bridge_explicit
    sdm = engine._sdm_obs
    grav = engine._ciq_grav
    dx   = engine.dx

    # ── Brückenformel ────────────────────────────────────────────────
    C_field = br.compute_C(engine.Phi, dx)
    C_mean  = float(np.mean(C_field))
    B_field = br.compute_B(engine.Phi, engine.R_grid, dx)
    B_mean  = float(np.mean(B_field))
    I_val   = br.compute_I(engine.Phi, dx)
    E_q     = br.compute_Eq(engine.Phi, engine._K2, dx)
    r_bub   = engine.measure_bubble_radius()
    E_g     = br.compute_Eg(engine.phi_super, r_bub)
    Psi_br  = br.compute_Psi_bridge(C_mean, B_mean, I_val, E_q, E_g)
    U_int   = br.update_U_integral(engine._U_integral, Psi_br, engine.dt)
    engine._U_integral = U_int
    eq_ok, delta_E = br.gleichgewicht_check(E_q, E_g)

    bridge_metrics = {
        'C_mean':       C_mean,
        'B_mean':       B_mean,
        'I_entropy':    I_val,
        'E_q':          E_q,
        'E_g':          E_g,
        'Psi_bridge':   Psi_br,
        'U_integral':   U_int,
        'delta_E':      delta_E,
        'gleichgewicht': eq_ok,
        'einheiten':    br.EINHEITEN,
    }

    # ── S_DM Observablen ─────────────────────────────────────────────
    sigma_v = sdm.compute_sigma_v_eff(engine.S_DM, engine.R_grid, dx)
    f_dm    = sdm.compute_f_dm(engine.S_DM, engine.Phi, dx)

    sdm_metrics = {
        'sigma_v_eff': sigma_v,
        'f_dm':        f_dm,
        'sdm_mean':    float(np.mean(engine.S_DM)),
        'sdm_max':     float(np.max(engine.S_DM)),
    }

    # ── Gravitation ───────────────────────────────────────────────────
    Phi_G, rho_tot_field = grav.solve_poisson(
        engine.Phi, engine.S_DM, dx,
        potential_a=engine.potential_a, potential_b=engine.potential_b
    )
    rho_geo_mean = float(np.mean(np.maximum(rho_tot_field - engine.Phi**2
                                            - ZETA_SDM * engine.S_DM, 0.0)))
    friedmann = grav.compute_friedmann_H_squared(
        phi_super    = engine.phi_super,
        S_DM_mean    = float(np.mean(engine.S_DM)),
        rho_geo_mean = rho_geo_mean,
    )
    dsp = grav.compute_delta_sp_operator(engine.Phi, engine.S_DM, engine.R_grid, dx)

    grav_metrics = {
        'Phi_G':          Phi_G,
        'Phi_G_max':      float(np.max(np.abs(Phi_G))),
        'Phi_G_mean':     float(np.mean(Phi_G)),
        'rho_tot_mean':   float(np.mean(rho_tot_field)),
        'friedmann':      friedmann,
        'delta_sp':       dsp,
    }

    # ── History tracken ──────────────────────────────────────────────
    engine.sdm_obs_history['sigma_v_eff'].append(sigma_v)
    engine.sdm_obs_history['f_dm'].append(f_dm)
    engine.sdm_obs_history['sdm_mean'].append(float(np.mean(engine.S_DM)))
    engine.sdm_obs_history['H'].append(friedmann['H'])
    engine.sdm_obs_history['rho_tot'].append(friedmann['rho_tot'])
    engine.sdm_obs_history['bounce_ratio'].append(friedmann['bounce_ratio'])
    engine.sdm_obs_history['Delta'].append(dsp['Delta'])
    engine.sdm_obs_history['S_grav'].append(dsp['S'])
    engine.sdm_obs_history['P_grav'].append(dsp['P'])

    engine.grav_history['H'].append(friedmann['H'])
    engine.grav_history['H2'].append(friedmann['H2'])
    engine.grav_history['rho_tot'].append(friedmann['rho_tot'])
    engine.grav_history['bounce_ratio'].append(friedmann['bounce_ratio'])
    engine.grav_history['Delta'].append(dsp['Delta'])
    engine.grav_history['S_grav'].append(dsp['S'])
    engine.grav_history['P_grav'].append(dsp['P'])
    engine.grav_history['Phi_G_max'].append(grav_metrics['Phi_G_max'])
    engine.grav_history['Phi_G_mean'].append(grav_metrics['Phi_G_mean'])

    return {
        'bridge': bridge_metrics,
        'sdm':    sdm_metrics,
        'grav':   grav_metrics,
        'time':   engine.time,
    }


