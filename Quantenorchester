class BrueckenformelExplizit:
    """
    Explizite, paper-ready Brückenformel.

    Gleichung:
        U(t) = ∫₀ᵗ Ψ_bridge(C, B, I, E_q, E_g) dt'

    mit:
        Ψ_bridge = α·C + β·B + γ·I + δ·(E_q + E_g)

    Einheiten (CIQ-normiert, ℏ=1, m=1):
        [Ψ_bridge] = CIQ-Energiedichte  (normiert)
        [C]        = m⁻² (2D: Wahrscheinlichkeitsdichte = |Ψ|²/dx²)
        [B]        = Beschleunigung/dx² (effektiver Gravitationsterm)
        [I]        = dimensionlos (Shannon, normiert auf [0,1])
        [E_q]      = ℏ·ω_eff  (Quantenfluktuationsenergie)
        [E_g]      = G·M̄/r_bubble (Gravitationsenergie-Proxy)
        [U]        = Σ Ψ_bridge · dt  (akkumulierte Wirkung)

    Ableitung aus Wirkungsprinzip:
        S_CIQ = ∫ [R/16πG + ℒ_QM + ℒ_DM - ζ·S_DM·(E_q-E_g)²] d⁴x
        δS_CIQ/δΦ = 0  →  □Φ + dV/dΦ = J_bridge
        J_bridge = dℒ_bridge/dΦ = Ψ_bridge(C,B,I,E)
    """

    # Physikalische Einheiten-Dokumentation (für Paper)
    EINHEITEN = {
        'U':         'CIQ-Wirkungsdichte [ℏ/m²] (normiert: ℏ=1)',
        'Psi_bridge':'CIQ-Energiedichte-Rate [ℏ/m²/s] (normiert)',
        'C':         'Wahrscheinlichkeitsdichte |Ψ|²/norm [m⁻²]',
        'B':         'Gravitationsbeschleunigung G·M/r² [m/s²]',
        'I':         'Shannon-Entropie −Σρ·log(ρ) [dimensionlos]',
        'E_q':       'Quantenenergie ℏ·ω_eff [J] (norm: ℏ=1)',
        'E_g':       'Gravitationsenergie G·M̄/r_bubble [J] (norm)',
        'S_Pi':      'Sigmoid-Bifurkation: klassisch↔Bounce [0,1]',
        'delta_crit':'Planck-Schwelle = phi_eq / cos(θ_W) [normiert]',
    }

    # Gleichgewichtsbedingung (Planck-Punkt)
    GLEICHGEWICHT = """
    Planck-Gleichgewicht:  ΔI = 0  ⟺  E_q = E_g
    Ableitung:
        E_q = ℏ·ω_eff   (Nullpunktsenergie der Resonanz)
        E_g = G·M̄/r_b  (Gravitationsenergie der Blase)
        ΔI = 0:  ω_eff = G·M̄/(ℏ·r_b) = c³/(G·M_Planck) → normiert: E_q_norm = E_g_norm = 1
    Physik: An diesem Punkt ist Quantendruck = Gravitationsanziehung.
    CIQ: phi_super = delta_crit = phi_eq / cos(θ_W)
    """

    def __init__(self, alpha=0.05, beta=0.02, gamma=0.03, delta=0.10, zeta=0.08):
        self.alpha = alpha   # Informationsdichte-Gewicht
        self.beta  = beta    # Gravitationsterms-Gewicht
        self.gamma = gamma   # Entropie-Gewicht
        self.delta = delta   # Energie-Kopplungsgewicht
        self.zeta  = zeta    # S_Pi-Rückkopplungs-Stärke

    def compute_C(self, Phi, dx):
        """
        C = Materiedichte / Informationsdichte
        C = |Φ|² / ‖Φ‖  (normierte Wahrscheinlichkeitsdichte)
        Einheit: m⁻² (2D), m⁻³ (3D)
        """
        norm_phi = np.sqrt(np.sum(Phi**2) * dx**2) + 1e-15
        return Phi**2 / norm_phi

    def compute_B(self, Phi, R_grid, dx, G_norm=G_CIQ_NORM):
        """
        B = Raumzeitbindung = G · M̄ / r²
        M̄ = ∫|Φ|² dV  (effektive Masse aus Felddichte)
        Einheit: m/s² (normiert: G=G_norm, m=1)

        Ableitung: Poisson ∇²Φ_G = 4πG·ρ
        Näherung (Fernfeld): B(r) ≈ G·M̄/r²
        """
        M_eff = np.sum(Phi**2) * dx**2           # effektive Feldmasse
        r_safe = np.maximum(R_grid, dx)
        return G_norm * M_eff / r_safe**2

    def compute_I(self, Phi, dx):
        """
        I = Shannon-Entropie / Informationsfluss
        I = -∑ ρ · log(ρ) · dx²   (diskrete Shannon-Entropie)
        ρ = |Φ|² / ‖Φ‖²  (normierte Wahrscheinlichkeit)
        Einheit: dimensionlos (normiert auf [0, log N])
        """
        prob = Phi**2
        prob_sum = np.sum(prob) * dx**2 + 1e-15
        rho = prob / prob_sum
        rho_safe = np.maximum(rho, 1e-300)
        I_raw = -np.sum(rho_safe * np.log(rho_safe)) * dx**2
        # Normierung auf [0, 1]: I_max = log(N²) für gleichverteilte Dichte
        I_max = np.log(Phi.size)
        return float(I_raw / max(I_max, 1.0))

    def compute_Eq(self, Phi, K2, dx):
        """
        E_q = Quantenfluktuationsenergie
        E_q = ℏ·ω_eff  mit  ω_eff = <k²>^(1/2)  (RMS-Wellenzahl × ℏ/m)
        ℏ=1, m=1 → E_q = sqrt(∑|Φ̃_k|²·k²) / ‖Φ̃‖
        Einheit: [ℏ·rad/s] = normiert dimensionlos

        Ableitung: aus dem kinetischen Term der Schrödinger-Gleichung
            <E_kin> = ⟨Ψ|−(ℏ²/2m)∇²|Ψ⟩ = (ℏ²/2m)·∑k²·|Φ̃_k|²/‖Φ̃‖²
        """
        Phi_k  = sfft.fft2(Phi)
        norm_k = np.sum(np.abs(Phi_k)**2) + 1e-15
        omega_eff = np.sqrt(np.sum(K2 * np.abs(Phi_k)**2) / norm_k)
        return float(omega_eff)   # E_q = ℏ·ω_eff, ℏ=1

    def compute_Eg(self, phi_super, r_bubble, G_norm=G_CIQ_NORM):
        """
        E_g = Gravitationsenergie-Proxy
        E_g = G · M̄ / r_bubble
        M̄ ∝ phi_super  (Feldstärke als Massenproxy)
        Einheit: [G·m/r] = normiert dimensionlos

        Ableitung: Newtons Gravitationsenergie E = −G·M·m/r
        CIQ-Proxy: M → phi_super (Ordnungsparameter),
                   r → r_bubble (Blasenradius aus measure_bubble_radius())
        """
        r_safe = max(r_bubble, 1e-3)
        return float(G_norm * phi_super / r_safe)

    def compute_Psi_bridge(self, C_mean, B_mean, I_val, E_q, E_g):
        """
        Ψ_bridge = α·C + β·B + γ·I + δ·(E_q + E_g)

        VOLLSTÄNDIGE ABLEITUNG:
        ─────────────────────────────────────────────────────────────
        Ausgehend vom CIQ-Wirkungsfunktional:
            S = ∫[ℒ_QM + ℒ_grav + ℒ_bridge] d⁴x

        mit dem Brückenlagrangian:
            ℒ_bridge = −ζ·S_DM·(E_q − E_g)²
                     + α·C·Φ  (Informationsdichte-Kopplung)
                     + β·B·Φ  (Gravitationskopplung)
                     + γ·I·Φ  (Entropie-Kopplung)
                     + δ·(E_q + E_g)·Φ  (Energiekopplung)

        Euler-Lagrange: δℒ_bridge/δΦ = Ψ_bridge
            → Ψ_bridge = α·C + β·B + γ·I + δ·(E_q + E_g)

        Einheit von Ψ_bridge [CIQ-normiert]:
            α·C  ~ [0.05]·[m⁻²] normiert → [dimensionlos/Gitterzelle]
            β·B  ~ [0.02]·[G·M/r²] normiert → [dimensionlos/Gitterzelle]
            γ·I  ~ [0.03]·[1] → [dimensionlos]
            δ·E  ~ [0.10]·[ℏω] normiert → [dimensionlos]
        ─────────────────────────────────────────────────────────────
        """
        return (self.alpha * C_mean
               + self.beta  * B_mean
               + self.gamma * I_val
               + self.delta * (E_q + E_g))

    def update_U_integral(self, U_prev, Psi_bridge, dt):
        """
        Numerische Integration: U(t) = ∫₀ᵗ Ψ_bridge dt'
        Trapezregel: U(t+dt) ≈ U(t) + Ψ_bridge · dt
        Einheit: [U] = [Ψ_bridge] · [t] = normierte Wirkungsdichte
        """
        return U_prev + Psi_bridge * dt

    def gleichgewicht_check(self, E_q, E_g, epsilon=0.01):
        """
        Prüft ob Planck-Gleichgewicht erreicht: |E_q - E_g| < epsilon
        Rückgabe: (ist_gleichgewicht: bool, delta_E: float)
        """
        delta_E = abs(E_q - E_g)
        return delta_E < epsilon, delta_E


