# 7. CIQ_ROTATIONSMODELL

# Baryonisch-holographisches Rotationsmodell aus dem SPARC/CIQ-Manuskript

# Kalibriert v4 (holographisch-baryonischer Fit)

# 

# Konstanten:

# kappa_G  - holographische Kopplungskonstante (v4) [dimensionlos]

# kappa_c  - Kern-Kopplungskonstante (v4) [dimensionlos]

# G        - Gravitationskonstante in astronomischen Einheiten

# (kpc*(km/s)^2/M_sun)

# r_c      - Fixer Skalenradius des holographischen Terms in kpc

# ================================================================

kappa_G: float = 6.523e-2
kappa_c: float = 6.854e-4
G: float = 4.300917e-6      # kpc * (km/s)^2 / M_sun
r_c: float = 11.55          # kpc

def compute_Mbar(V_max: float) -> float:
    """
    Baryonische Masse M_bar nach der baryonischen Tully-Fisher-Relation (BTFR).
    M_bar = 50 * V_max^4  [M_sun]
    """
    return 50.0 * V_max**4

def compute_Rd(V_max: float) -> float:
    """
    Scheibenradius R_d in kpc nach empirischem Skalierungsgesetz.
    R_d = 3.5 * (V_max / 100)^0.5
    """
    return 3.5 * (V_max / 100.0)**0.5

def compute_Sigma0(M_bar: float, R_d: float) -> float:
    """Flaechenmassendichte Sigma_0 = M_bar / (2*pi * R_d^2)."""
    return M_bar / (2.0 * np.pi * R_d**2)

def compute_f_HI(V_max: float) -> float:
    """
    Gasmassenskalierungsfaktor f_HI.
    f_HI = 0.45 * (V_max / 100)^(-1.20)
    """
    return 0.45 * (V_max / 100.0)**(-1.2)

def compute_B_over_D(V_max: float) -> float:
    """
    Bulge-zu-Disk-Verhaeltnis B_over_D.
    B_over_D = 0.04 * (V_max / 100)^(+1.50)
    """
    return 0.04 * (V_max / 100.0)**(1.5)

def compute_R_bulge(V_max: float) -> float:
    """
    Bulge-Radius R_bulge in kpc.
    R_bulge = 0.50 * (V_max / 100)^0.80
    """
    return 0.50 * (V_max / 100.0)**0.80

def compute_M_bulge(M_bar: float, B_over_D: float, f_HI: float) -> float:
    """
    Bulge-Masse M_bulge in M_sun.
    M_bulge = (B_over_D / (1 + B_over_D)) * M_bar * (1 - f_HI)
    """
    return (B_over_D / (1.0 + B_over_D)) * M_bar * (1.0 - f_HI)

def compute_A_h(Sigma0: float) -> float:
    """
    Holographischer Amplitudenparameter A_h.
    A_h = kappa_G * G * Sigma0
    """
    return kappa_G * G * Sigma0

def compute_A_c(M_bulge: float, R_bulge: float) -> float:
    """
    Kern-Amplitudenparameter A_c.
    A_c = kappa_c * G * M_bulge / R_bulge^2
    """
    return kappa_c * G * M_bulge / (R_bulge**2)

def compute_lambda(R_bulge: float) -> float:
    """
    Kern-Skalenlaenge lambda_rot (Python-konform, da 'lambda' reserviert).
    lambda_rot = 3.0 * R_bulge
    """
    return 3.0 * R_bulge

def rotation_curve(r_array: np.ndarray, V_max: float) -> np.ndarray:
    """
    Berechnet die Rotationsgeschwindigkeit V(r) gemaess dem CIQ v4-Rotationsmodell.
    
    ```
    Baryonischer Term (vereinfachte Punktmassenannaeherung):
    V_bar^2 = G * M_bar / r
    Holographischer Term:
    A_h / (r + r_c) * r
    Kern-Term (Gaussfoermig):
    A_c * exp(-(r / lambda_rot)^2) * r
    
    Parameter
    ---------
    r_array : Array von Radien (kpc) fuer die Berechnung.
    V_max   : Maximale Rotationsgeschwindigkeit (km/s).
    
    Returns
    -------
    V_tot : Array der Rotationsgeschwindigkeiten (km/s).
    """
    M_bar    = compute_Mbar(V_max)
    R_d      = compute_Rd(V_max)
    Sigma0   = compute_Sigma0(M_bar, R_d)
    f_HI     = compute_f_HI(V_max)
    B_over_D = compute_B_over_D(V_max)
    R_bulge  = compute_R_bulge(V_max)
    M_bulge  = compute_M_bulge(M_bar, B_over_D, f_HI)
    A_h      = compute_A_h(Sigma0)
    A_c      = compute_A_c(M_bulge, R_bulge)
    lam      = compute_lambda(R_bulge)

    # Baryonischer Beitrag (vereinfachte Punktmassenannaeherung)
    # V_bar^2 = G * M_bar / r  (Kepler-Rotation einer Punktmasse)
    r_safe = np.maximum(r_array, 1e-3)
    V2_bar = G * M_bar / r_safe

    # Holographischer Beitrag
    # V_holo^2 = A_h * r / (r + r_c)  (flaches Rotationsprofil bei r >> r_c)
    V2_holo = A_h * r_safe / (r_safe + r_c)

    # Kern-Beitrag (Bulge, Gauss-Profil)
    # V_kern^2 = A_c * r * exp(-(r/lambda)^2)  (peaked, faellt schnell ab)
    V2_kern = A_c * r_safe * np.exp(-(r_safe / lam)**2)

    # Gesamte Rotationsgeschwindigkeit: V_tot = sqrt(V2_bar + V2_holo + V2_kern)
    # Jeder Term hat die Dimension (km/s)^2 und ist einzeln physikalisch interpretierbar.
    V_tot = np.sqrt(V2_bar + V2_holo + V2_kern)
    return V_tot

