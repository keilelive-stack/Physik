class CIQGravitation:
    """
    Explizite Gravitationsfeldgleichungen für das CIQ-Framework.

    Behebt: ❌ Gravitation nur implizit (nur gravitational_bass())
    Jetzt:  ✅ Modifiziertes Poisson-Feld + CIQ-Friedmann-Gleichung

    Struktur folgt dem Δ→S→P Operator (Gravitation-der-patch.pdf):
        Δ = ρ_tot  (Instabilität / Krümmungsquelle)
        S = Äquivalenzprinzip (Sattelpunkt, m→m eliminiert)
        P = Geodäte (Minimierung der Restinstabilität)
    """

    def __init__(self, G_norm=G_CIQ_NORM, zeta=ZETA_SDM):
        self.G_norm = G_norm
        self.zeta   = zeta

    # ──────────────────────────────────────────────────────────────────
    # 3a) MODIFIZIERTES POISSON-FELD
    # ──────────────────────────────────────────────────────────────────

    def compute_rho_total(self, Phi, S_DM, dx,
                          potential_a=0.15, potential_b=0.08):
        """
        Gesamtdichte aus allen CIQ-Komponenten:

            ρ_tot = ρ_b + ζ·ρ_SDM + ρ_geo

        Komponenten:
            ρ_b   = |Φ|²                           (baryonisch/Feldenergie)
            ρ_SDM = ζ · S_DM                       (Dunkle Materie)
            ρ_geo = |∇Φ|² + a·Φ⁴ - b·Φ²           (Vakuumenergie / geometrisch)

        Einheit: [ρ] = dimensionlos (CIQ-normiert)
        Ableitung: Energie-Impuls-Tensor T_μν aus ℒ_CIQ
        """
        # Baryonische Dichte
        rho_b   = Phi**2

        # S_DM-Dichte
        rho_sdm = self.zeta * S_DM

        # Geometrische/Vakuum-Dichte
        grad_y, grad_x = np.gradient(Phi, dx)
        grad_sq = grad_x**2 + grad_y**2
        rho_geo = grad_sq + potential_a * Phi**4 - potential_b * Phi**2

        return rho_b + rho_sdm + rho_geo

    def solve_poisson(self, Phi, S_DM, dx,
                      potential_a=0.15, potential_b=0.08):
        """
        Modifiziertes Poisson-Feld:

            ∇²Φ_G = 4π·G · ρ_tot
            ∇²Φ_G = 4π·G · (ρ_b + ζ·S_DM + ρ_geo)

        Lösung im Fourier-Raum (Spektralmethode):
            Φ̃_G(k) = −4π·G · ρ̃_tot(k) / k²    (k ≠ 0)
            Φ̃_G(0) = 0                           (Eichfreiheit: kein Offset)

        Einheit:
            [Φ_G] = G·M/r = [Gravitationspotential], normiert dimensionlos
            [∇²Φ_G] = G·ρ·4π = [Beschleunigung/Länge]

        Physikalische Interpretation:
            Φ_G > 0: Gravitationsquelle (Materieanhäufung)
            Φ_G < 0: Potential-Well (Anziehung)
            ∇Φ_G:   Gravitationsbeschleunigung g = −∇Φ_G

        Δ→S→P:
            Δ(m) = ρ_tot erzeugt Φ_G
            S: Äquivalenzprinzip → alle Massen folgen ∇Φ_G gleich
            P: Trajektorie γ = argmin ∫ Φ_G(γ(t)) dt  (Geodäte)
        """
        rho_tot  = self.compute_rho_total(Phi, S_DM, dx, potential_a, potential_b)

        # Fourier-Lösung
        rho_k    = sfft.fft2(rho_tot)
        N        = Phi.shape[0]
        kx       = sfft.fftfreq(N, d=dx) * 2 * np.pi
        ky       = sfft.fftfreq(N, d=dx) * 2 * np.pi
        KX, KY   = np.meshgrid(kx, ky)
        K2       = KX**2 + KY**2
        K2[0, 0] = 1.0   # Division durch 0 vermeiden (k=0: Eichfreiheit)

        Phi_G_k  = -4 * np.pi * self.G_norm * rho_k / K2
        Phi_G_k[0, 0] = 0.0   # Kein konstanter Offset

        Phi_G    = np.real(sfft.ifft2(Phi_G_k))
        return Phi_G, rho_tot

    def compute_gravitational_acceleration(self, Phi_G, dx):
        """
        Gravitationsbeschleunigung: g = −∇Φ_G
        Einheit: [g] = [Φ_G/m] = normiert m/s² analog

        Verwendung:
            Bewegungsgleichung: ẍ = g_x, ÿ = g_y
            CIQ-Analog: Phasenfeldkraft ~ −∇Φ_G · Φ
        """
        g_y, g_x = np.gradient(-Phi_G, dx)
        return g_x, g_y

    # ──────────────────────────────────────────────────────────────────
    # 3b) CIQ-FRIEDMANN-GLEICHUNG
    # ──────────────────────────────────────────────────────────────────

    def compute_friedmann_H_squared(self, phi_super, S_DM_mean,
                                    rho_DE=0.7, rho_b_mean=None,
                                    rho_geo_mean=0.0, a_scale=1.0):
        """
        CIQ-Friedmann-Gleichung (Mastergleichung des Scripts):

            H² = (8π·G/3) · (ρ_DE + ζ·S_DM + ρ_b + ρ_geo)

        Erweiterung um Loop-Quantum-Cosmology Bounce-Term:
            H² = (8π·G/3) · ρ_tot · (1 − ρ_tot/ρ_crit_bounce)
            → H = 0 bei ρ_tot = ρ_crit_bounce  (Bounce-Punkt)

        Parameter:
            phi_super    : Ordnungsparameter (Makro-Kohärenz)
            S_DM_mean    : räumlicher Mittelwert von S_DM
            rho_DE       : Dunkle Energie (Λ-Term), normiert
            rho_b_mean   : baryonische Dichte ∝ phi_super² (default)
            rho_geo_mean : geometrische Dichte (aus Phasenfeld)
            a_scale      : Skalenfaktor a(t) (Standard: 1 = heute)

        Rückgabe:
            H²: normierter Hubble-Parameter zum Quadrat
            H:  Hubble-Rate (positiv = Expansion, negativ = Kontraktion)
            regime: 'expansion' / 'bounce' / 'contraction'

        Einheit:
            [H²] = 1/s² → normiert: [H²_norm] = dimensionlos
            Kalibrierung: H₀ = 70 km/s/Mpc → H₀_norm = H₀ · t_CIQ

        Observable:
            H(z) aus Typ-Ia Supernovae, BAO, CMB (H₀-Tension)
            CIQ-Vorhersage: ζ·S_DM_mean kann H₀-Tension erklären
                           wenn ζ·S_DM ~ 0.05·ρ_crit
        """
        if rho_b_mean is None:
            rho_b_mean = phi_super**2   # |Φ|² als Massenproxy

        # Skalierungsgesetze (a-Abhängigkeit)
        rho_b_scaled   = rho_b_mean   * a_scale**(-3)  # Materie ~ a⁻³
        rho_sdm_scaled = self.zeta * S_DM_mean * a_scale**(-3)  # DM ~ a⁻³
        rho_DE_scaled  = rho_DE                         # Λ = const

        rho_tot = rho_DE_scaled + rho_sdm_scaled + rho_b_scaled + rho_geo_mean

        # Standard Friedmann
        H2_standard = (8 * np.pi * self.G_norm / 3.0) * max(rho_tot, 0.0)

        # CIQ-Bounce Korrektur (LQC-inspiriert)
        rho_bounce_eff = RHO_BOUNCE
        H2_ciq = H2_standard * max(0.0, 1.0 - rho_tot / rho_bounce_eff)

        H = np.sqrt(max(H2_ciq, 0.0))

        # Regime-Bestimmung
        if rho_tot >= rho_bounce_eff * 0.95:
            regime = 'bounce'
        elif H > 0:
            regime = 'expansion'
        else:
            regime = 'contraction'

        return {
            'H2':           float(H2_ciq),
            'H':            float(H),
            'rho_tot':      float(rho_tot),
            'rho_DE':       float(rho_DE_scaled),
            'rho_SDM':      float(rho_sdm_scaled),
            'rho_b':        float(rho_b_scaled),
            'rho_geo':      float(rho_geo_mean),
            'regime':       regime,
            'bounce_ratio': float(rho_tot / rho_bounce_eff),
            # Einheiten für Paper
            'einheiten': {
                'H':          '1/t_CIQ (normiert)',
                'rho_tot':    'ρ_Planck (normiert)',
                'bounce_ratio': 'dimensionlos [0,1]',
            }
        }

    def compute_delta_sp_operator(self, Phi, S_DM, R_grid, dx):
        """
        CIQ Δ→S→P Operator (aus Gravitation-der-patch.pdf).

        Δ-Phase (Instabilität):
            Delta_val = ρ_tot = ρ_b + ζ·ρ_SDM + ρ_geo
            Interpretation: strukturelles Ungleichgewicht im System

        S-Phase (Sattelpunkt / Äquivalenzprinzip):
            S_val = min |∇²Φ_G|  (Punkt minimaler Raumkrümmung)
            Interpretation: S = Punkt, wo zwei gegenläufige Operatoren
                            sich strukturell ausgleichen

        P-Phase (Patch / Geodäte):
            P_val = argmin_r ρ_tot(r)  (Pfad minimaler Instabilität)
            Interpretation: P = Minimierungs-Operator

        Unified CIQ-Form:
            ℧_CIQ = P ∘ S ∘ Δ
            X* = argmin_X Δ(X)
        """
        rho_tot = self.compute_rho_total(Phi, S_DM, dx)

        # Δ-Phase: mittlere Instabilität
        Delta_val = float(np.mean(np.abs(rho_tot)))

        # S-Phase: Sattelpunkt (minimale Krümmung, nahe bei Gleichgewicht)
        Phi_G, _ = self.solve_poisson(Phi, S_DM, dx)
        lap_G    = (np.roll(Phi_G, 1, 0) + np.roll(Phi_G, -1, 0) +
                    np.roll(Phi_G, 1, 1) + np.roll(Phi_G, -1, 1) - 4 * Phi_G) / dx**2
        S_val    = float(np.min(np.abs(lap_G)))   # minimale Raumkrümmung

        # P-Phase: Position minimaler Dichte (Geodäten-Endpunkt)
        min_idx  = np.unravel_index(np.argmin(rho_tot), rho_tot.shape)
        r_min    = float(R_grid[min_idx])
        P_val    = r_min   # Geodäte endet bei minimaler Instabilität

        return {
            'Delta': Delta_val,   # Instabilität: ρ_tot-Mittel
            'S':     S_val,       # Sattelpunkt: min|∇²Φ_G|
            'P':     P_val,       # Patch: Radius minimaler ρ_tot
            'U_CIQ': P_val / max(S_val + Delta_val, 1e-10),  # Normierter Operator
        }


