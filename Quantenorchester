    ciq_grav = CIQGravitation()
    Phi_G, _ = ciq_grav.solve_poisson(engine.Phi, engine.S_DM, engine.dx,
                                        engine.potential_a, engine.potential_b)
    im2 = ax20.imshow(Phi_G, origin='lower',
                      extent=[-engine.L, engine.L, -engine.L, engine.L],
                      cmap='RdBu_r', aspect='auto')
    plt.colorbar(im2, ax=ax20, label='Φ_G [G·M/r norm.]', fraction=0.046)
    ax20.set_xlabel('x [CIQ-Einh.]')
    ax20.set_ylabel('y [CIQ-Einh.]')
    ax20.set_title('7. Gravitationspotential Φ_G\n[∇²Φ_G = 4πG(ρ_b+ζ·S_DM+ρ_geo)]',
                   color='white', fontsize=9)

    # Panel [2,1]: Friedmann H(t) + Bounce
    ax21 = fig.add_subplot(gs[2, 1])
    _style(ax21, '8. CIQ-Friedmann: H(t), Bounce-Ratio\n[H²=(8πG/3)·ρ_tot·(1-ρ/ρ_bounce)]')
    gh = engine.grav_history
    if gh['H']:
        t_g = t_arr[:len(gh['H'])] if len(t_arr) >= len(gh['H']) else range(len(gh['H']))
        ax21_r = ax21.twinx()
        ax21.plot(t_g, gh['H'],     color=C3, lw=1.8, label='H [1/t_CIQ]')
        ax21_r.plot(t_g, gh['bounce_ratio'], color=C4, lw=1.5, ls='--',
                    label='ρ/ρ_bounce')
        ax21_r.axhline(1.0, color=C4, lw=0.6, ls=':', alpha=0.7, label='Bounce-Punkt')
        ax21.set_xlabel('t [CIQ-Einh.]')
        ax21.set_ylabel('H (gelb)', color=C3, fontsize=8)
        ax21_r.set_ylabel('ρ/ρ_bounce (rot)', color=C4, fontsize=8)
        lines1, labs1 = ax21.get_legend_handles_labels()
        lines2, labs2 = ax21_r.get_legend_handles_labels()
        ax21.legend(lines1 + lines2, labs1 + labs2,
                    fontsize=7, facecolor='#111133', labelcolor='white')

    # Panel [2,2]: Δ→S→P Operator
    ax22 = fig.add_subplot(gs[2, 2])
    _style(ax22, '9. CIQ Δ→S→P Operator\n[℧_CIQ = P∘S∘Δ (Gravitation-der-patch.pdf)]')
    if gh['Delta']:
        t_dsp = t_arr[:len(gh['Delta'])] if len(t_arr) >= len(gh['Delta']) else range(len(gh['Delta']))
        ax22.plot(t_dsp, gh['Delta'],   color=C4, lw=1.5, label='Δ = ρ_tot (Instab.)')
        ax22.plot(t_dsp, gh['S_grav'],  color=C0, lw=1.5, label='S = min|∇²Φ_G|')
        ax22.plot(t_dsp, gh['P_grav'],  color=C2, lw=1.5, label='P = r(min ρ) [Geodäte]')
        ax22.set_xlabel('t [CIQ-Einh.]')
        ax22.set_ylabel('CIQ Δ,S,P [norm.]')
        ax22.legend(fontsize=7, facecolor='#111133', labelcolor='white')

    plt.savefig(speichern_als, dpi=150, bbox_inches='tight', facecolor=DARK_BG)
    plt.close(fig)
    print(f"  [Paper-Ready v1.0] Dashboard gespeichert: {speichern_als}")
    return speichern_als


