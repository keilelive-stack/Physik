class QuantenOrchesterEngine:
    """
    Kern-Simulation des CIQ Quanten-Orchester-Modells.
    
    ```
    Implementiert:
    2D Phasenfeld Phi(x,y,t) mit Doppelmulden-Potential
    Spin-abhaengige Modulationen (Fermion/Boson/Graviton)
    S_DM Akkumulation (Dunkles Archiv)
    R-S-H Dynamik
    Effektive Geometrie g(Phi)
    Eigenzeit dtau/dt
    
    Master v5.0: Standardmodell-Parameter aus Eval-GF-04 (RWTH 2004)
    Teilchenmassen als physikalische Skalierungsreferenz
    W/Z-Massenratio: m_W/m_Z = cos(theta_W)
    Top-Quark -> delta_crit Attraktor
    Z-Breite -> Daempfungsparameter
    init_bubble_teilchen() fuer SM-Teilchen-Initialisierung
    
    Phasenfeld (v4):
    a=0.15, b=0.08 -> phi_eq = sqrt(b/(2a)) ~ 0.516
    Diffusion 0.35 laesst Wellen sich ausbreiten.
    Daempfung 0.008 behaelt mehr Energie.
    
    S_DM (v4.3):
    Wachstum/Abbau-Verhaeltnis rebalanciert; logistische Saettigung;
    Glitch normiert (tanh), Decay proportional zu S_DM.
    
    Eigenzeit (v4, linear):
    phi_super = RMS-Einhuellende (~0.06-0.10)
    dtau/dt = sqrt(1 + alpha*phi_super - nu*S_DM_mean - beta*Phi_G)
    """

    def __init__(self, N=200, L=4.0, dt=0.005):
        self.N  = N
        self.L  = L
        self.dt = dt
        self.dx = 2 * L / N

        # Gitter
        x = np.linspace(-L, L, N)
        y = np.linspace(-L, L, N)
        self.X, self.Y = np.meshgrid(x, y)
        self.R_grid = np.sqrt(self.X**2 + self.Y**2)
        self.Theta  = np.arctan2(self.Y, self.X)

        # -- Physikalische Felder --
        self.Phi       = None            # Phasenfeld
        self.Phi_prev  = None            # Vorheriger Zeitschritt
        self.S_DM      = np.zeros((N, N))  # Dunkles Archiv
        self.phi_super = 0.0             # Makro-Kohaerenz (Ordnungsparameter)

        # -- R-S-H Zustand --
        self.R_val = 1.0    # Resonanz
        self.S_val = 0.5    # Stoerung
        self.H_val = 0.8    # Harmonie

        # -- Kopplungsparameter (CIQ Mastergleichung, kalibriert v4) --
        self.alpha_geo = 0.8     # Konformer Skalierungsfaktor
        self.beta_geo  = 0.25    # Gradientenkopplung

        # === PHASENFELD (v4) ===
        # Altes Problem: Diffusion zu schwach, Potential zu flach.
        # Jetzt: a=0.15, b=0.08 -> phi_eq=0.516, Barriere 10x tiefer.
        # Diffusion 0.35 laesst Wellen sich ausbreiten.
        # Daempfung 0.008 (war 0.02) behaelt mehr Energie.
        self.diffusion   = 0.35    # Phasendiffusion    (war: 0.15)
        self.potential_a = 0.15    # phi^4-Koeffizient   (war: 0.04)
        self.potential_b = 0.08    # phi^2-Koeffizient   (war: 0.02)
        self.damping     = 0.008   # Wellengleichungs-Daempfung  (war: 0.02)

        # === S_DM (v4.3) ===
        # Wachstum/Abbau-Verhaeltnis rebalanciert;
        # Decay proportional zu S_DM.
        # CFL-sicher: D=0.05 < dx^2/(4*dt) ~ 0.32
        self.gamma_sdm  = 0.015    # S_DM Wachstumsrate  (v4.3)
        self.lambda_phi = 0.25     # Kohaerenz-Abbau proportional S_DM (v4.3)
        self.sdm_max    = 2.0      # S_DM Saettigungswert (logistisch + harter Clip)

        # === EIGENZEIT (v4, linear) ===
        # phi_super jetzt ~0.06-0.10 (RMS-Einhuellende statt mean(|Phi|)).
        # Lineare Kopplung statt phi^3 (sichtbar bei kleinem phi):
        #   dtau/dt = sqrt(1 + alpha*phi_super - nu*S_DM - beta*Phi_G)
        self.alpha_ez = 2.0     # phi_super Gewicht (linear)  (war: 5.0 kubisch)
        self.nu_ez    = 0.3     # S_DM Daempfung
        self.beta_ez  = 0.1     # Phi_G Daempfung

        # ================================================================
        # STANDARDMODELL-ABGELEITETE PARAMETER (v5/v11, aus Eval-GF-04)
        # ================================================================
        #
        # delta_crit: Kritischer Schwellenwert fuer Sigmoid-Schalter (S_Pi, S_ez)
        #
        # ABLEITUNG (v11 - ersetzt fruehere Hardcodierung 0.7):
        #   1. phi_eq = sqrt(b/(2*a)): Vakuumerwartungswert des Doppelmulden-Potentials
        #      V(Phi) = a*Phi^4 - b*Phi^2 hat Minima bei +/-phi_eq.
        #      phi_eq ist die natuerliche Feldstaerke-Skala der Symmetriebrechung.
        #
        #   2. cos(theta_W) = m_W / m_Z: elektroschwacher Mischungswinkel (LEP-Messung)
        #      cos(theta_W) verbindet die SU(2)_L- und U(1)_Y-Kopplungen.
        #
        #   3. delta_crit = phi_eq / cos(theta_W)
        #      Interpretation: der kritische Schwellenwert ist der VEV,
        #      skaliert mit dem inversen Mischungswinkel. Im SM entspricht
        #      1/cos(theta_W) = m_Z/m_W der Verhaeltnismasse der neutralen
        #      zur geladenen schwachen Eichboson-Masse - ein Mass fuer die
        #      Staerke der Symmetriebrechung relativ zur Eichkopplung.
        #
        #   Numerisch: phi_eq ~ 0.516, cos(theta_W) ~ 0.882
        #              => delta_crit ~ 0.586
        #
        #   WICHTIG: delta_crit ist jetzt vollstaendig abgeleitet aus:
        #     (a) den Potentialparametern a, b (Phasenfeld-Theorie)
        #     (b) den SM-Massen m_W, m_Z (Experiment, Eval-GF-04)
        #   Kein freier Tuning-Parameter mehr.
        #
        #   Abgeleitete Hilfsgroessen (fuer Diagnostik verfuegbar):
        #     self.phi_eq:        VEV des Doppelmulden-Potentials
        #     self.phi_inflect:   Wendepunkt von V(Phi): sqrt(b/(6a))
        #     self.V_barrier:     Barrierehoehe V(0) - V(phi_eq) = b^2/(4a)
        # ================================================================

        # Vakuumerwartungswert aus Doppelmulde (abgeleitet, nicht frei)
        self.phi_eq      = np.sqrt(self.potential_b / (2.0 * self.potential_a))
        # Wendepunkt (V''=0): Kruemmungswechsel des Potentials
        self.phi_inflect = np.sqrt(self.potential_b / (6.0 * self.potential_a))
        # Barrierehoehe (analytisch exakt)
        self.V_barrier   = self.potential_b**2 / (4.0 * self.potential_a)

        # W/Z-Massenratio -> schwacher Mischungswinkel (cos theta_W = m_W/m_Z)
        # m_W = 80.426 GeV, m_Z = 91.1875 GeV (Eval-GF-04, LEP)
        self.m_W_GeV     = SM_PRAEZISION["m_W"]["wert"]        # 80.426 GeV
        self.m_Z_GeV     = SM_PRAEZISION["m_Z"]["wert"]        # 91.1875 GeV
        self.m_top_GeV   = SM_PRAEZISION["m_top"]["wert"]      # 174.3 GeV
        self.cos_theta_W = self.m_W_GeV / self.m_Z_GeV         # ~ 0.8820
        self.sin2_theta_W = SM_PRAEZISION["sin2_theta_W_nuN"]["wert"]  # 0.2277
        self.N_nu        = SM_PRAEZISION["N_nu"]["wert"]        # 2.9841
        self.alpha_s     = SM_PRAEZISION["alpha_s_mZ"]["wert"] # 0.118

        # delta_crit: abgeleitet aus phi_eq und cos_theta_W (siehe Dokumentation oben)
        # delta_crit = phi_eq / cos(theta_W) = VEV * (m_Z / m_W)
        self.delta_crit  = self.phi_eq / self.cos_theta_W
        # Diagnose-Ausgabe (einmalig bei Konstruktion)
        # print(f"  [v11] delta_crit = phi_eq/cos(theta_W) = "
        #       f"{self.phi_eq:.4f}/{self.cos_theta_W:.4f} = {self.delta_crit:.4f}"
        #       f"  (phi_inflect={self.phi_inflect:.4f}, V_barrier={self.V_barrier:.6f})")

        # Z-Breite -> Daempfungsreferenz (normiert)
        # Gamma_Z / m_Z = 2.4952 / 91.1875 ~ 0.02737 (natuerliche Breite)
        self.Gamma_Z_norm = (SM_PRAEZISION["Gamma_Z"]["wert"] /
                             SM_PRAEZISION["m_Z"]["wert"])      # ~ 0.02737

        # Higgs: Doppelmulden-Potential Kalibrierung
        # phi_eq = +-sqrt(b/(2a)) <-> Higgs-VEV (v ~ 246 GeV normiert)
        # m_H_fit = 91 GeV (indirekter Fit), m_H < 211 GeV (95% CL)
        self.m_H_fit   = 91.0    # GeV (aus EW-Fit, Eval-GF-04)
        self.m_H_limit = 211.0   # GeV (LEP-Grenze)

        # ================================================================

        # Einhuellende-Tracker fuer phi_super (exponentiell geglaettet)
        self._phi_sq_envelope = None   # wird in step() / init_bubble() initialisiert
        self._envelope_alpha  = 0.05   # Glaettungsfaktor

        # -- Zeitvariablen --
        self.time       = 0.0
        self.step_count = 0
        self._glitch_rms_current = 0.0   # v11: glitch_rms fuer WF-Block Direktzugriff

        # -- History fuer Plots --
        self.history = {
            'time': [], 'R': [], 'S': [], 'H': [], 'Q': [],
            'phi_super': [], 'sdm_total': [], 'energy': [],
            'eigenzeit': [], 'bubble_radius': []
        }

        # ================================================================
        # WELLENFUNKTIONS-FELDER (v6 - Quelle: maths2mind.com)
        # ================================================================
        # Komplexe Wellenfunktion Psi(x,y,t) = Phi_re + i*Phi_im
        # Physikalisch: freies Teilchen mit Impuls p = hbar*k, Energie E = hbar*omega
        #
        # Zerlegung:
        #   Psi(x,t)  = A * exp(-i*(omega*t - k*x))
        #   Re(Psi)   = A * cos(omega*t - k*x)   <-> Phasenfeld Phi (reeller Teil)
        #   Im(Psi)   = -A * sin(omega*t - k*x)  <-> konjugiertes Feld
        #   |Psi|^2   = A^2  (Wahrscheinlichkeitsdichte, normiert)
        #
        # Dispersionsrelation (nichtrelativistisch, freies Teilchen):
        #   E = hbar^2 * k^2 / (2*m)
        #   omega_disp(k) = hbar_norm * k^2 / (2 * m_norm)
        #
        # Phasen- und Gruppengeschwindigkeit:
        #   v_ph = omega / k
        #   v_gr = d(omega)/dk = hbar_norm * k / m_norm
        # ================================================================
        self.k_wf      = 2.0 * np.pi / (2 * L / 4)   # Wellenzahl (4 Wellenlängen in Box)
        self.omega_wf  = HBAR_NORM * self.k_wf**2 / (2 * M_NORM)  # Dispersionsrelation
        self.v_phase   = self.omega_wf / max(self.k_wf, 1e-10)     # Phasengeschwindigkeit
        self.v_group   = HBAR_NORM * self.k_wf / M_NORM            # Gruppengeschwindigkeit
        self.Phi_im    = np.zeros((N, N))     # Imaginaerteil der Wellenfunktion
        self.prob_dens = np.zeros((N, N))     # Wahrscheinlichkeitsdichte |Psi|^2
        self.norm_wf   = 1.0                  # Normierung integral(|Psi|^2) sollte ~ 1 sein
        self.wf_history = {
            'norm': [], 'prob_max': [], 'v_phase': [], 'v_group': [],
            'omega_eff': [], 'k_eff': [], 'dispersionsmaß': [],
            # v9: Strang-Splitting Diagnose-Observablen
            'norm_raw':  [],   # Normierung VOR Renormierung (= Unitaritaets-Drift pro Step)
            'E_kin_wf':  [],   # Kinetische QM-Energie <k^2> aus Fourierspektrum
            'E_pot_wf':  [],   # Potentielle QM-Energie <V_eff * |Psi|^2>
            'E_tot_wf':  [],   # Gesamtenergie E_kin + E_pot (Erhaltungsgroesse)
        }

        # ================================================================
        # STRANG-SPLITTING CACHE (v9)
        # K2 und phase_T haengen nur von Gitter und dt ab -> einmalig berechnen
        # Spart ~30% der FFT-Vorbereitung pro step().
        # ================================================================
        _kx = sfft.fftfreq(N, d=self.dx) * 2.0 * np.pi
        _ky = sfft.fftfreq(N, d=self.dx) * 2.0 * np.pi
        _KX, _KY = np.meshgrid(_kx, _ky)
        self._K2      = _KX**2 + _KY**2           # |k|^2 (N x N), unveraenderlich
        self._k_abs   = np.sqrt(self._K2)          # |k|    (N x N), unveraenderlich
        # Kinetischer Phasenfaktor exp(-i * hbar * K2 / (2m) * dt): zeitunabhaengig
        self._phase_T = np.exp(-1j * HBAR_NORM * self._K2 / (2.0 * M_NORM) * dt)
        # Brückenformel-History (v8: erweitert um A_br_sdm, B_rsh, S_ez, bridge_score)
        self.bridge_history = {
            'S_Pi': [], 'E_q': [], 'E_g': [], 'I_entropy': [],
            'U_integral': [], 'delta_E': [], 'C_mean': [], 'B_gravity': [],
            # v8: neue Schalter-Observablen
            'A_br_sdm':    [],  # logistischer S_DM-Aktivierungsfaktor [0,1]
            'B_rsh':       [],  # bridge_linear R-S-H-Skalierung [0,1]
            'S_ez':        [],  # logistischer Eigenzeit-Vor-Schalter [0,1]
            'bridge_score': [], # hybrid_aggregate aller Brücken-Indikatoren [0,1]
        }
        self._U_integral = 0.0   # Akkumuliertes Brückenformel-Integral
        # History-Schluessel erweitern
        self.history['prob_norm'] = []
        self.history['v_phase']   = []
        self.history['v_group']   = []

        # ================================================================
        # GROSS-PITAEVSKII PROPAGATOR-MODUS (v10)
        # ================================================================
        # Optionaler GP-Modus: V_eff += g_gp * |Psi|^2
        # Aktivierung: engine.use_gp = True  (Standard: False)
        # Staerke:     engine.g_gp   = 50.0  (validiert im Benchmark)
        # Startfeld:   Thomas-Fermi-Profil wenn use_gp=True und mu_TF gesetzt
        #
        # GP-Potential ist zustandsabhaengig: V(t) != V(t+dt) -> Strang O(dt^3)
        # Energiedrift verringert sich um Faktor ~14000-20000x vs Trotter.
        #
        # Neue wf_history-Keys (GP-spezifisch):
        #   'E_gp_kin':   kinetische GP-Energie <hbar^2*k^2/(2m)>
        #   'E_gp_trap':  Fallenpotential-Energie <pot_b*r^2 * |Psi|^2>
        #   'E_gp_int':   Wechselwirkungs-Energie g/2 * <|Psi|^4>
        #   'E_gp_tot':   GP-Gesamtenergie (Erhaltungsgroesse bei use_gp=True)
        #   'E_gp_drift': |E_gp_tot - E_gp_0| (Drift ab Startenergie)
        # ================================================================
        self.use_gp   = False    # GP-Modus aktivieren
        self.g_gp     = 50.0     # GP-Wechselwirkungsstaerke (validiert: g=50)
        self.mu_TF    = 3.0      # Chemisches Potential fuer Thomas-Fermi-Profil
        self._E_gp_0  = None     # Startenergie (wird beim ersten GP-Step gesetzt)
        self.wf_history['E_gp_kin']   = []
        self.wf_history['E_gp_trap']  = []
        self.wf_history['E_gp_int']   = []
        self.wf_history['E_gp_tot']   = []
        self.wf_history['E_gp_drift'] = []

    def init_bubble(self, sigma=1.5, spin_mode='fermion'):
        """
        Initialisiere Vakuum-Blase mit Spin-Modulation.

        spin_mode:
          'fermion'  -> sin(2*theta), 4*pi-Periodizitaet, Jazz-Antisymmetrie
          'boson'    -> cos(theta), 2*pi-Periodizitaet, Chor-Kohaerenz
          'graviton' -> cos(4*theta), pi-Periodizitaet, Bass-Quadrupol
          'mixed'    -> Superposition aller Moden (0.5 Fermion + 0.3 Boson + 0.2 Graviton)

        Physikalische Teilchen-Initialisierung:
          init_bubble_teilchen(name) waehlt sigma und spin_mode automatisch
          aus STANDARDMODELL_FERMIONEN / STANDARDMODELL_BOSONEN.
        """
        # Gausssche Blase (Vakuumfluktuation)
        bubble = np.exp(-self.R_grid**2 / (2 * sigma**2))

        # Spin-abhaengige Phasenmodulation
        if spin_mode == 'fermion':
            modulation = np.sin(2 * self.Theta)   # 2 Knotenlinien, 4*pi-Periode
        elif spin_mode == 'boson':
            modulation = np.cos(self.Theta)        # Knotenfreie Symmetrie
        elif spin_mode == 'graviton':
            modulation = np.cos(4 * self.Theta)    # Quadrupol-Muster
        elif spin_mode == 'mixed':
            # Gewichtete Superposition: Realitaet = alle Stimmen zusammen
            modulation = (0.5 * np.sin(2 * self.Theta)   # Fermion-Jazz
                        + 0.3 * np.cos(self.Theta)         # Boson-Chor
                        + 0.2 * np.cos(4 * self.Theta))    # Gravitations-Bass
        else:
            modulation = np.ones_like(self.Theta)

        self.Phi       = bubble * modulation
        self.Phi_prev  = self.Phi.copy()
        self.S_DM      = np.zeros((self.N, self.N))
        self._phi_sq_envelope = np.zeros((self.N, self.N))  # Reset Einhuellende
        self.time       = 0.0
        self.step_count = 0
        self.history    = {k: [] for k in self.history}

        # Wellenfunktions-Initialisierung
        # Im-Teil: pi/2-phasenverschobener Anteil (konjugierter Anteil)
        # Psi(x,0) = Phi(x,0) + i * Phi_im(x,0)
        # Fuer t=0: Im(Psi) = 0 (reeller Anfangszustand)
        self.Phi_im    = np.zeros((self.N, self.N))
        self.prob_dens = self.Phi**2  # |Psi(t=0)|^2 = Phi(t=0)^2
        self.norm_wf   = float(np.sum(self.prob_dens) * self.dx**2)
        self.wf_history = {k: [] for k in self.wf_history}
        self.bridge_history = {k: [] for k in self.bridge_history}
        self._U_integral = 0.0
        self.history['prob_norm'] = []
        self.history['v_phase']   = []
        self.history['v_group']   = []

    def init_bubble_teilchen(self, teilchen_name):
        """
        Initialisiert die Vakuum-Blase direkt aus einem Standardmodell-Teilchen.

        Parameter aus STANDARDMODELL_FERMIONEN / STANDARDMODELL_BOSONEN:
          ciq_sigma  -> Blasengroesse sigma
          ciq_modus  -> Spin-Modulation (fermion/boson/graviton)

        Beispiele:
          engine.init_bubble_teilchen("Top-Quark (t)")
          engine.init_bubble_teilchen("Z-Boson (Z0)")
          engine.init_bubble_teilchen("Graviton (G)")
        """
        sigma = get_ciq_sigma(teilchen_name)
        modus = get_ciq_modus(teilchen_name)
        print(f"  -> Initialisiere Blase: {teilchen_name}")
        print(f"     sigma={sigma}, Modus={modus}")
        self.init_bubble(sigma=sigma, spin_mode=modus)

    def laplacian(self, F):
        """Diskreter Laplace-Operator (5-Punkt-Stencil, periodische Randbedingungen)"""
        return (np.roll(F, 1, 0) + np.roll(F, -1, 0) +
                np.roll(F, 1, 1) + np.roll(F, -1, 1) - 4 * F) / self.dx**2

    def double_well_force(self, Phi):
        """
        Doppelmulden-Potential: V(Phi) = a*Phi^4 - b*Phi^2
        Kraft: F = -dV/dPhi = -4*a*Phi^3 + 2*b*Phi

        Zwei Minima bei Phi ~ +/-sqrt(b/(2a)) -> Vakuumzustaende
        Higgs-Analogie: V(Phi) = lambda*(|Phi|^2 - v^2)^2 mit a=lambda, b=2*lambda*v^2
        m_H^2 proportional 2b (Higgs-Masse aus zweiter Ableitung am Minimum)
        """
        return -4 * self.potential_a * Phi**3 + 2 * self.potential_b * Phi

    def gravitational_bass(self):
        """
        Gravitations-Bass: langwelliger Spin-2-Modus.
        Wirkt als fokussierende Linse (Lautstarkenzunahme).

        CIQ v5: Kopplung skaliert mit cos_theta_W (SM-Parameter):
          Bass-Staerke proportional cos^2(theta_W) ~ 0.777
          cos(theta_W) = m_W / m_Z (Eval-GF-04, LEP)
        """
        from scipy.ndimage import gaussian_filter
        bass = gaussian_filter(self.Phi, sigma=self.N // 8)
        # Kopplung mit EW-Mischungswinkel
        return bass * 0.05 * self.cos_theta_W

    def compute_geometry(self):
        """
        Effektive Metrik: g_mu_nu(Phi) = exp(2*alpha*Phi)*eta_mu_nu + beta*nabla_mu_Phi*nabla_nu_Phi

        Ohne Phase -> keine Geometrie (Z=0, Tod)
        Mit Phase  -> emergente Raumzeit
        """
        conformal = np.exp(2 * self.alpha_geo * self.Phi)
        grad_y, grad_x = np.gradient(self.Phi, self.dx)
        contrast = grad_x**2 + grad_y**2   # |nabla Phi|^2
        return conformal + self.beta_geo * contrast

    def compute_eigenzeit(self):
        """
        CIQ Eigenzeitgleichung (v8, Brückenformel-gehärtet):
          dtau/dt = sqrt(1 + alpha*phi_super - nu*S_DM_mean - |beta|*Phi_G)

        v8: Vor dem Wurzel-Argument wird ein weicher logistischer Vor-Schalter
        S_ez (Brückenformel) eingefügt:
          S_ez = logistic_switch(phi_super, x_star=delta_crit, delta=0.1*delta_crit)
          => Starke Zustandsänderungen werden nicht einfach geclippt (hartes max),
             sondern kontrolliert hochgefahren (monoton, kalibrierbar).

        Warum:
          - Ohne Schalter: bei kleinen phi_super springt dtau/dt durch
            S_DM-Fluktuation sporadisch auf max(arg, 0.01), was die Eigenzeit
            diskontinuierlich macht.
          - Mit S_ez: phi_super < delta_crit -> alpha-Term schwach, Stabilität.
            phi_super >= delta_crit -> volle Kopplung, weicher Übergang.

        phi_super ist die RMS-Einhuellende (~0.06-0.10),
        daher linearer Term statt phi^3 (ausreichend sensitiv).
        v5: Gamma_Z-Normierung als Daempfungsreferenz verfuegbar (self.Gamma_Z_norm).
        """
        sdm_mean = np.mean(self.S_DM)
        phi_g    = np.mean(np.abs(self.Phi))  # Gravitationspotential-Proxy

        # Brückenformel: weicher logistischer Vor-Schalter für alpha-Kopplung
        # S_ez skaliert alpha_ez kontinuierlich hoch, sobald phi_super > delta_crit
        ez_star  = self.delta_crit              # Schwelle = Planck-Äquivalent
        ez_delta = max(0.1 * ez_star, 1e-4)    # Übergangsbreite
        S_ez = 1.0 / (1.0 + np.exp(-(self.phi_super - ez_star) / ez_delta))
        # S_ez = 0: phi_super << delta_crit -> alpha_ez-Kopplung minimal (ruhige Phase)
        # S_ez = 0.5: phi_super ~ delta_crit -> halbe Kopplung (Resonanzpunkt)
        # S_ez = 1: phi_super >> delta_crit -> volle Kopplung (Bounce-Phase)

        arg = (1.0
               + self.alpha_ez * S_ez * self.phi_super   # Brücke: S_ez skaliert alpha sanft
               - self.nu_ez    * sdm_mean
               - self.beta_ez  * phi_g)

        # ================================================================
        # REGULARISIERUNG (v11, ersetzt hartes max(arg, 0.01)):
        #
        # Problem: max(arg, 0.01) erzeugt eine Diskontinuitaet in der
        #   Ableitung von dtau/dt, was numerische Artefakte verursacht wenn
        #   arg nahe 0.01 oszilliert.
        #
        # Loesung: Glatte Regularisierung via SoftPlus-Approximation:
        #   arg_reg = 0.5 * (arg + sqrt(arg^2 + epsilon_reg^2))
        #
        #   Verhalten:
        #     arg >> epsilon_reg:  arg_reg ≈ arg  (unveraendert)
        #     arg ≈ 0:            arg_reg ≈ epsilon_reg / 2  (sanfter Boden)
        #     arg << -epsilon_reg: arg_reg ≈ epsilon_reg^2/(4*|arg|) → 0+ (asymptotisch)
        #
        #   Physikalische Interpretation des Bodens:
        #     epsilon_reg = Gamma_Z_norm^2 = (Gamma_Z / m_Z)^2 ~ 7.5e-4
        #     Die minimale Eigenzeit wird durch die natuerliche Breite der
        #     Z-Resonanz begrenzt: selbst im extremsten Zeitdilatations-Regime
        #     (arg → 0) bleibt eine Rest-Eigenzeit von ~Gamma_Z/m_Z erhalten.
        #     Dies entspricht dem physikalischen Prinzip, dass kein Beobachter
        #     vollstaendig "einfriert" (Regularisierung analoger Horizonte).
        #
        #   Vorteil gegenueber max(arg, 0.01):
        #     - C^inf glatt (keine Knicke)
        #     - Keine willkuerliche Konstante (aus SM-Physik abgeleitet)
        #     - Boden-Wert skaliert mit Gamma_Z (physikalisch konsistent)
        # ================================================================
        epsilon_reg = self.Gamma_Z_norm**2     # ~ 7.5e-4 (aus Z-Breite abgeleitet)
        arg_reg = 0.5 * (arg + np.sqrt(arg**2 + epsilon_reg))
        return np.sqrt(arg_reg)

    def compute_rsh(self):
        """
        R-S-H Dynamik (Lotka-Volterra-artiger Attraktor, kalibriert v3/v8):

          dR = alpha*R*(1 - R/R_max) + beta*H - gamma*S*R
          dS = delta*I + epsilon_lv*R*S - zeta*S
          dH = eta*R - theta*H
          Q  = R / (S + epsilon_small)

        Analytischer Fixpunkt Q* ~ 4.6 (stabil, numerisch verifiziert):
          gamma=0.45, epsilon_lv=0.25, zeta=0.74 -> R*~2.4, S*~0.52, Q*~4.6

        v8: Brückenformel-Skalierung der Kopplungsstärken:
          B_rsh = bridge_linear(phi_super, L=0, U=delta_crit)
          => phi_super = 0: lineare Kopplung bei Null (epsilon_lv, gamma_rsh gedämpft)
          => phi_super = delta_crit: volle Kopplung (B_rsh = 1)
          => phi_super > delta_crit: Sättigung (B_rsh = 1, kein Überschießen)

        Warum:
          - Ohne Skalierung: bei kleinem phi_super (ruhige Phase) laufen
            epsilon_lv*R*S und gamma_rsh*S*R trotzdem voll, was zum Überschwingen
            des S-Astes führt (S > R -> Instabilität).
          - Mit B_rsh: die Kopplungsterme wachsen proportional zum Aktivierungszustand;
            Fixpunkt bleibt stabil, aber phasensensitiv.

        Physikalische Interpretation im CIQ:
          - R*(1-R/R_max): logistisches Resonanzwachstum (Saettigung)
          - gamma*S*R:     Stoerung hemmt Resonanz (Raeuber-Beute-Kopplung)
          - epsilon_lv*R*S: Resonanz verstaerkt Glitch-Wahrnehmung (R fuehrt S)
          - zeta*S:         natuerlicher Zerfall der Stoerung
          - H folgt R gedaempft: traege Harmonie-Variable
        """
        # Input I = normierte Glitch-Staerke
        field_scale = max(np.max(np.abs(self.Phi)), 1e-6)
        I_input = np.mean(np.abs(self.Phi - self.Phi_prev)) / (self.dt * field_scale)

        # Brückenformel: bridge_linear-Skalierung der R-S-Kopplungsterme
        # B_rsh: phi_super in [0, delta_crit] -> [0, 1] (lineare Normierung, geclippt)
        B_rsh = float(np.clip(self.phi_super / max(self.delta_crit, 1e-6), 0.0, 1.0))
        # B_rsh = 0: ruhige Phase, Kopplung minimal (kein R-S-Überschießen)
        # B_rsh = 1: volle Aktivierung (phi_super >= delta_crit, Resonanz-Phase)

        # Koeffizienten (kalibriert v3.1 - Lotka-Volterra Attraktor)
        # Bedingung: zeta < epsilon_lv * R_max (S-Gleichgewicht erreichbar)
        alpha_rsh  = 0.5;   R_max      = 5.0
        beta_rsh   = 0.1;   gamma_rsh  = 0.45
        delta_rsh  = 0.05;  epsilon_lv = 0.25;  zeta_rsh = 0.74
        eta_rsh    = 0.4;   theta_rsh  = 0.3

        # v8: gamma_rsh und epsilon_lv mit B_rsh skaliert (phasensensitiv)
        # => verhindert Überschwingen in ruhiger Phase
        gamma_eff    = gamma_rsh  * (0.5 + 0.5 * B_rsh)   # min 50%, max 100%
        epsilon_eff  = epsilon_lv * (0.5 + 0.5 * B_rsh)   # min 50%, max 100%

        dR = (alpha_rsh * self.R_val * (1 - self.R_val / R_max)
              + beta_rsh   * self.H_val
              - gamma_eff  * self.S_val * self.R_val)
        dS = (delta_rsh   * I_input
              + epsilon_eff * self.R_val * self.S_val
              - zeta_rsh    * self.S_val)
        dH = eta_rsh * self.R_val - theta_rsh * self.H_val

        # ================================================================
        # R-S-H ZEITSKALIERUNG (v11, ersetzt den heuristischen Faktor 10):
        #
        # Problem: R-S-H operiert auf einer langsameren Zeitskala als das
        #   Phasenfeld. Ohne Skalierung konvergiert R-S-H zu langsam zur
        #   Fixpunkt-Dynamik, weil dt ~ 0.005 fuer das Phasenfeld optimiert
        #   ist (CFL-Bedingung), aber die R-S-H-ODE eine eigene natuerliche
        #   Zeitskala hat.
        #
        # Ableitung des Zeitskalierungsfaktors tau_rsh:
        #   Die R-S-H-Dynamik beschreibt makroskopische Resonanz-Stoerung-
        #   Harmonie-Zyklen. Ihre natuerliche Frequenz ist durch die
        #   Fixpunkt-Eigenfrequenz bestimmt:
        #     omega_rsh ~ sqrt(alpha_rsh * zeta_rsh) ~ sqrt(0.5 * 0.74) ~ 0.608
        #   Die Phasenfeld-Zeitskala ist:
        #     omega_phi ~ 1/dt ~ 200
        #   Verhaeltnis:
        #     tau_rsh = omega_phi / omega_rsh ~ 329
        #
        #   In Praxis genuegt ein moderater Faktor um die Zeitskalen
        #   anzugleichen. Der physikalisch motivierte Faktor:
        #     tau_rsh = 1 / (self.Gamma_Z_norm * self.dt)
        #   verbindet die R-S-H-Zeitskala mit der Z-Breite als natuerlicher
        #   Zerfalls-Zeitskala des schwachen Sektors.
        #
        #   Numerisch: 1 / (0.02737 * 0.005) ~ 7308 - zu gross!
        #   Besser: tau_rsh = 1 / self.Gamma_Z_norm ~ 36.5 - physikalisch
        #   motiviert, numerisch stabil, und nahe am frueheren Wert 10
        #   (gleiche Groessenordnung).
        #
        #   ALTERNATIV: alpha_s(m_Z) = 0.118 gibt 1/alpha_s ~ 8.5, nahe 10.
        #   Die starke Kopplung als Zeitskala ist physikalisch sinnvoll weil
        #   R-S-H auf hadronischen (QCD)-Skalen operiert.
        #
        #   v11: tau_rsh = 1 / alpha_s ~ 8.47 (aus HERA-Messung, Eval-GF-04)
        # ================================================================
        tau_rsh = 1.0 / self.alpha_s    # ~ 8.47, aus alpha_s(m_Z) = 0.118
        self.R_val = np.clip(self.R_val + dR * self.dt * tau_rsh, 0.01, 20.0)
        self.S_val = max(0.01, self.S_val + dS * self.dt * tau_rsh)
        self.H_val = max(0.01, self.H_val + dH * self.dt * tau_rsh)

        return self.R_val / (self.S_val + 1e-6)  # Stabilitaets-Quotient Q

    def measure_bubble_radius(self):
        """Messe den effektiven Blasenradius (Phasenfront, 90%-Perzentil)"""
        threshold = 0.1 * np.max(np.abs(self.Phi))
        mask = np.abs(self.Phi) > threshold
        if np.any(mask):
            distances = self.R_grid[mask]
            return np.percentile(distances, 90)
        return 0.0

    def step(self):
        """
        Ein Zeitschritt der Quanten-Orchester-Dynamik.

        Vereint:
          1. Wellendiffusion (Schroedinger-Gleichung <-> Schallwelle)
          2. Doppelmulden-Potential (Vakuumzustaende)
          3. Gravitations-Bass (Infraschall-Fokussierung)
          4. S_DM Akkumulation (Neugier-Operator / Dark Archive)
          5. Makro-Kohaerenz phi_super (RMS-Einhuellende)
          6. R-S-H Update
          7. Eigenzeitberechnung
          8. Guard: Singularitaetsvermeidung (Pauli-Prinzip als Guard)
          9. Energieberechnung
        """
        # 1. Laplacian + Doppelmulden-Kraft
        lap   = self.laplacian(self.Phi)
        force = self.double_well_force(self.Phi)

        # 2. Gravitations-Bass
        try:
            bass = self.gravitational_bass()
        except ImportError:
            # Fallback ohne scipy
            bass = np.zeros_like(self.Phi)

        # 3. Zeitevolution (gedaempfte Wellengleichung)
        reaction = self.diffusion * lap + force + bass
        Phi_next = (2 * self.Phi - self.Phi_prev
                    + self.dt**2 * reaction
                    - self.damping * self.dt * (self.Phi - self.Phi_prev))

        # 4. S_DM Akkumulation: Neugier-Operator
        #    dS_DM/dt = gamma * A_br * |Beschleunigung| * (|Phi| + kappa*|nabla Phi|) - lambda * phi_super
        #
        #    v8: Brückenformel-Aktivierungsfaktor A_br (logistic_switch aus integration_toolkit):
        #      A_br = logistic_switch(glitch_rms, x_star=sdm_glitch_star, delta=sdm_glitch_delta)
        #      glitch_rms = RMS der lokalen Beschleunigung (|d^2Phi/dt^2|)
        #      x_star = 1.0: Schwelle, ab der S_DM-Akkumulation stark aktiviert wird
        #      delta  = 0.3: Übergangsbreite (weich, kein harter Schnitt)
        #      => A_br nahe 0: kaum Aktivierung (ruhiges Feld)
        #      => A_br nahe 1: volle Aktivierung (starke Beschleunigung / Glitch)
        #      Kombination mit tanh-Normierung entfällt: A_br ersetzt heuristische tanh-Skalierung
        #      sauber: Aktivierung ist monoton und kalibrierbar (x_star, delta frei wählbar)
        d2phi           = (Phi_next - 2 * self.Phi + self.Phi_prev) / self.dt**2
        glitch          = np.abs(d2phi)
        local_coherence = np.abs(self.Phi)
        grad_y_s, grad_x_s = np.gradient(self.Phi, self.dx)
        gradient_amp    = np.sqrt(grad_x_s**2 + grad_y_s**2)
        extended_source = local_coherence + 0.5 * gradient_amp

        # Brückenformel: logistischer Aktivierungsfaktor für S_DM-Quellterm
        # Ersetzt rohe tanh(glitch/10)-Heuristik durch kalibrierbaren Sigmoid-Schalter
        sdm_glitch_star  = 1.0   # Aktivierungsschwelle (kalibrierbar)
        sdm_glitch_delta = 0.3   # Übergangsbreite (weich)
        glitch_rms       = np.sqrt(np.mean(glitch**2)) + 1e-15  # skalares RMS der ganzen Fläche
        # v11: als Instanzvariable speichern, damit der WF-Block direkt darauf
        # zugreifen kann (statt k_eff als Proxy zu verwenden)
        self._glitch_rms_current = glitch_rms
        # Skalares A_br: 0 = kein Glitch aktiv, 1 = volle S_DM-Aktivierung
        A_br_sdm   = 1.0 / (1.0 + np.exp(-(glitch_rms - sdm_glitch_star) / sdm_glitch_delta))
        # Lokaler normierter Quellterm: bridge_linear-Skalierung pro Pixel (Intensitätskarte)
        glitch_max = np.max(glitch) + 1e-15
        glitch_norm = np.clip(glitch / glitch_max, 0.0, 1.0)  # pixelweise [0,1]
        sdm_growth  = self.gamma_sdm * A_br_sdm * glitch_norm * extended_source

        # Logistische Saettigung + proportionaler Decay + Diffusion
        # Decay proportional S_DM (nicht konstant!) -> verhindert Diffusions-Pump.
        saturation    = np.clip(1.0 - self.S_DM / self.sdm_max, 0.0, 1.0)
        sdm_decay     = self.lambda_phi * (self.phi_super + 0.01) * self.S_DM
        sdm_diffusion = 0.05 * self.laplacian(self.S_DM)
        self.S_DM    += (sdm_growth * saturation - sdm_decay + sdm_diffusion) * self.dt
        self.S_DM     = np.clip(self.S_DM, 0, self.sdm_max)  # Harte Obergrenze

        # 5. Makro-Kohaerenz (Ordnungsparameter, v4: RMS-Einhuellende)
        #    Exponentiell geglaettetes Phi^2 -> misst Schwingungs-Amplitude,
        #    nicht momentanen Wert. Korrekt fuer oszillierendes Feld.
        a_env = self._envelope_alpha
        self._phi_sq_envelope = ((1 - a_env) * self._phi_sq_envelope
                                 + a_env * self.Phi**2)
        self.phi_super = np.sqrt(np.mean(self._phi_sq_envelope))

        # 6. R-S-H Update
        Q = self.compute_rsh()

        # 7. Eigenzeit
        eigenzeit = self.compute_eigenzeit()

        # 8. Guard: Singularitaetsvermeidung (Pauli-Prinzip als Guard)
        if np.max(np.abs(Phi_next)) > 5.0:
            Phi_next = np.clip(Phi_next, -5.0, 5.0)

        # 9. Update
        self.Phi_prev    = self.Phi.copy()
        self.Phi         = Phi_next
        self.time       += self.dt
        self.step_count += 1

        # 10. Energie (Gesamtenergie des Feldes)
        grad_y, grad_x = np.gradient(self.Phi, self.dx)
        kinetic      = 0.5 * np.mean((self.Phi - self.Phi_prev)**2 / self.dt**2)
        gradient_e   = 0.5 * np.mean(grad_x**2 + grad_y**2)
        potential_e  = np.mean(self.potential_a * self.Phi**4
                               - self.potential_b * self.Phi**2)
        total_energy = kinetic + gradient_e + potential_e

        # History
        self.history['time'].append(self.time)
        self.history['R'].append(self.R_val)
        self.history['S'].append(self.S_val)
        self.history['H'].append(self.H_val)
        self.history['Q'].append(Q)
        self.history['phi_super'].append(self.phi_super)
        self.history['sdm_total'].append(np.sum(self.S_DM))
        self.history['energy'].append(total_energy)
        self.history['eigenzeit'].append(eigenzeit)
        self.history['bubble_radius'].append(self.measure_bubble_radius())


        # ================================================================
        # WELLENFUNKTION-UPDATE (v9 - Strang-Splitting-Propagator + Brückenformel)
        #
        # Strang-Splitting (symmetrisches Lie-Trotter-Suzuki, Fehler O(dt^3)):
        #
        #   Psi(t+dt) = exp(-i*V(t+dt)*dt/(2*hbar))    [V-Halb-Schritt, t+dt]
        #             * exp(-i*T*dt/hbar)               [T-Voll-Schritt im k-Raum]
        #             * exp(-i*V(t)*dt/(2*hbar))        [V-Halb-Schritt, t]
        #             * Psi(t)
        #
        # Unterschied zu v7/v8 (Trotter/Lie-Splitting):
        #   v7/v8: beide V-Halbschritte nutzten identisches V_eff(t)
        #          => Fehler O(dt^2) wenn V zeitabhaengig
        #   v9:    erster V-Halbschritt: V_eff(t) aus altem Phi
        #          zweiter V-Halbschritt: V_eff(t+dt) aus neuem Phi (nach Wellengl.-Step)
        #          => Fehler O(dt^3) auch bei zeitabhaengigem V_eff (echter Strang)
        #
        # Caches (einmalig in __init__ berechnet, zeitunabhaengig):
        #   self._K2:      |k|^2-Gitter (N x N)
        #   self._k_abs:   |k|-Gitter   (N x N)
        #   self._phase_T: exp(-i*hbar*K2/(2m)*dt), fest fuer konstantes dt
        #
        # Energieerhaltungs-Monitor (v9):
        #   E_kin = <hbar^2 * K2 / (2m)>_Psi = sum(K2 * |Psi_hat|^2) / N^2
        #   E_pot = <V_eff>_Psi              = sum(V_eff * |Psi|^2) * dx^2
        #   E_tot = E_kin + E_pot            (Erhaltungsgroesse bei unitaerer Evolution)
        #
        # Brückenformel (unveraendert aus v8):
        #   U = integral(Psi_bridge(C,B,I,E)) dt
        #   V_eff = V_DW + alpha*C + gamma*I + zeta*S_Pi*(E_q-E_g)*|Psi| + 0.05*<S_DM>
        # ================================================================

        # ---- Hilfsfunktion: V_eff aus aktuellem Phi berechnen ----
        # (inline definiert, wird zweimal aufgerufen: bei t und t+dt)
        def _compute_V_eff(phi_field, phi_im_field, phi_sup, r_bub,
                           s_pi_val, e_q_val, e_g_val, sdm_mean_val):
            """
            Berechne V_eff(x,y) aus aktuellem Phasenzustand.
            Wird zweimal pro Strang-Step aufgerufen:
              1. mit altem Phi (t): V_A fuer ersten Halb-Schritt
              2. mit neuem Phi (t+dt): V_B fuer zweiten Halb-Schritt
            """
            _V_DW = (self.potential_a * phi_field**4
                     - self.potential_b * phi_field**2)
            _rho  = phi_field**2 + phi_im_field**2
            _rho_norm = np.sum(_rho) * self.dx**2 + 1e-30
            _C    = _rho / _rho_norm
            _I    = -float(np.sum(_C * np.log(_C + 1e-30)) * self.dx**2)
            _alpha_br = 0.05;  _gamma_br = 0.03
            _zeta_br  = 0.08
            _V = (_V_DW
                  + _alpha_br * _C
                  + _gamma_br * _I
                  + _zeta_br  * s_pi_val * (e_q_val - e_g_val) * np.abs(phi_field)
                  + 0.05 * sdm_mean_val)
            return _V, _C, _I

        # ---- Gemeinsame Größen (einmal berechnen, für beide V-Evaluierungen) ----

        # Schutzschalter S_Pi (unveraendert)
        T_eff  = self.phi_super
        T_star = self.delta_crit
        DeltaT = max(0.1 * T_star, 1e-4)
        S_Pi   = 1.0 / (1.0 + np.exp(-(T_eff - T_star) / DeltaT))

        # E_q, E_g (unveraendert)
        omega_eff_prev = (self.wf_history['omega_eff'][-1]
                          if self.wf_history['omega_eff'] else self.omega_wf)
        E_q = HBAR_NORM * omega_eff_prev
        r_bubble = max(self.measure_bubble_radius(), 1e-3)
        E_g = G * compute_Mbar(max(self.phi_super * 100, 1.0)) / max(r_bubble, 1e-3)
        E_g = np.clip(E_g * 1e-6, 0.0, 1.0)
        delta_E  = abs(E_q - E_g)
        sdm_mean = float(np.mean(self.S_DM))

        # Brückenformel-Koeffizienten
        alpha_br = 0.05;  beta_br  = 0.02
        gamma_br = 0.03;  delta_br = 0.10
        zeta_br  = 0.08

        # ---- Strang-Splitting: Schritt A - V_eff(t), halber V-Schritt ----
        V_eff_t, C_br, I_br = _compute_V_eff(
            self.Phi, self.Phi_im, self.phi_super, r_bubble,
            S_Pi, E_q, E_g, sdm_mean
        )
        # Energieobservable E_pot (aus V_eff(t) und aktuellem |Psi|^2)
        rho_t     = self.Phi**2 + self.Phi_im**2
        rho_norm_t = np.sum(rho_t) * self.dx**2 + 1e-30
        E_pot_wf  = float(np.sum(V_eff_t * (rho_t / rho_norm_t)) * self.dx**2)

        phase_V_A = np.exp(-1j * V_eff_t * (self.dt / 2.0) / HBAR_NORM)
        Psi_c     = self.Phi.astype(complex) + 1j * self.Phi_im
        Psi_c     = phase_V_A * Psi_c

        # ---- Strang-Splitting: Schritt B - T-Voll-Schritt (gecacht) ----
        Psi_hat   = sfft.fft2(Psi_c)
        Psi_hat   = self._phase_T * Psi_hat       # gecachter kinetischer Phasenfaktor
        Psi_c     = sfft.ifft2(Psi_hat)

        # ---- Strang-Splitting: Schritt C - V_eff(t+dt), halber V-Schritt ----
        # v9-Kernverbesserung: V_eff wird mit dem NEUEN Phi (nach Wellengl.-Step)
        # neu berechnet statt V_eff(t) nochmals zu verwenden.
        # self.Phi wurde oben in step() bereits auf Phi_next gesetzt.
        V_eff_tdt, _C_new, _I_new = _compute_V_eff(
            self.Phi, Psi_c.real, self.phi_super, r_bubble,
            S_Pi, E_q, E_g, sdm_mean
        )
        phase_V_B = np.exp(-1j * V_eff_tdt * (self.dt / 2.0) / HBAR_NORM)
        Psi_c     = phase_V_B * Psi_c

        # ---- Normierung VOR Renormierung (Diagnose-Observable) ----
        norm_sq_raw = float(np.sum(np.abs(Psi_c)**2) * self.dx**2)

        # ---- Bedingte Renormierung (v11: nur bei signifikanter Drift) ----
        # In einer unitaeren Evolution (hermitescher Hamiltonian) bleibt die Norm
        # exakt erhalten. Drift entsteht durch die nicht-hermitesche Kopplung an
        # das klassische Feld Phi. Renormierung wird nur durchgefuehrt wenn die
        # Drift einen Schwellenwert ueberschreitet (> 1% pro Step), und die Groesse
        # der Korrektur wird als Diagnose-Observable in norm_raw gespeichert.
        # Bei kleiner Drift (< 1%): KEINE Renormierung -> E_tot_wf bleibt
        # eine echte Erhaltungsgroesse und Norm-Drift zeigt die Staerke der
        # Phi-Psi-Kopplung quantitativ an.
        _norm_drift = abs(norm_sq_raw - 1.0)
        _NORM_DRIFT_THRESHOLD = 0.01   # 1%: oberhalb = signifikante nicht-unitaere Drift
        if _norm_drift > _NORM_DRIFT_THRESHOLD and norm_sq_raw > 1e-15:
            Psi_c_normed = Psi_c / np.sqrt(norm_sq_raw)
        else:
            Psi_c_normed = Psi_c

        # ---- Re/Im extrahieren ----
        self.Phi_im    = Psi_c_normed.imag
        self.prob_dens = np.abs(Psi_c_normed)**2
        self.norm_wf   = float(np.sum(self.prob_dens) * self.dx**2)

        # ================================================================
        # MEAN-FIELD RUECKKOPPLUNG: Psi -> Phi  (v11, formalisiert)
        # ================================================================
        # Physikalische Grundlage (semiklassische Mean-Field-Naeherung):
        #   Das klassische Phasenfeld Phi(x,t) und die Wellenfunktion Psi(x,t)
        #   sind NICHT dasselbe Feld. Phi ist der klassische Ordnungsparameter
        #   (Vakuum-Erwartungswert), Psi beschreibt die Quantenfluktuationen.
        #
        #   In einer konsistenten Mean-Field-Theorie (Hartree-Typ) koppelt
        #   der Erwartungswert <Psi> an das klassische Feld:
        #     Phi_next += kappa_mf * (Re(Psi_norm) - Phi_hat) * dt
        #   wobei Phi_hat = Phi / max(|Phi|) die normierte Feldrichtung ist.
        #
        #   Die Kopplungsstaerke kappa_mf ist NICHT frei, sondern wird aus der
        #   natuerlichen Zerfallsbreite des Z-Bosons abgeleitet:
        #     kappa_mf = hbar_norm * Gamma_Z_norm
        #   Gamma_Z_norm = Gamma_Z / m_Z ~ 0.02737 (dimensionslose Breite)
        #
        #   Interpretation: die QM-Rueckkopplung operiert auf der Zeitskala
        #   des schwachen Zerfalls. Dies ist physikalisch motiviert weil das
        #   Higgs-Feld (phi_super) ueber den schwachen Sektor an Materie koppelt.
        #
        #   Fruehere Version: kappa_mf = hbar * 0.01 (heuristisch, unbegruedet)
        #   Jetzt:            kappa_mf = hbar * Gamma_Z_norm ~ 0.02737 (abgeleitet)
        # ================================================================
        kappa_mf = HBAR_NORM * self.Gamma_Z_norm
        phi_max_abs = max(np.max(np.abs(self.Phi)), 1e-10)
        phi_hat = self.Phi / phi_max_abs   # normierte Feldrichtung
        phi_qm_correction = Psi_c_normed.real - phi_hat
        self.Phi += kappa_mf * phi_qm_correction

        # ---- Fourier-Spektral-Observablen (gecachte K2 / k_abs) ----
        # Psi_hat enthaelt den k-Raum nach T-Schritt (vor V_B): korrekt fuer k-Observablen
        k_abs     = self._k_abs
        K2        = self._K2
        power     = np.abs(Psi_hat)**2
        power_sum = np.sum(power) + 1e-30
        k_eff     = float(np.sum(k_abs * power) / power_sum)
        omega_eff = HBAR_NORM * k_eff**2 / (2.0 * M_NORM)
        v_ph_eff  = omega_eff / max(k_eff, 1e-10)
        v_gr_eff  = HBAR_NORM * k_eff / M_NORM
        delta_k   = float(np.sqrt(np.sum((k_abs - k_eff)**2 * power) / power_sum))

        # Kinetische Energie aus Fourierspektrum: E_kin = <hbar^2*k^2/(2m)>_Psi
        E_kin_wf  = float(np.sum(HBAR_NORM**2 * K2 / (2.0 * M_NORM) * power)
                          / (power_sum * self.N**2))
        E_tot_wf  = E_kin_wf + E_pot_wf

        # --- 5. Brückenformel-Observablen speichern ---
        # B: Raumzeitbindungsterm (G_eff -> CIQ-Gravitation)
        B_br = float(G * np.mean(np.abs(self.Phi)) / max(r_bubble**2, 1e-6))

        # ================================================================
        # BRUECKENFORMEL-INTEGRAL U (v11, dimensionskonsistent)
        # ================================================================
        # Problem (v8): Psi_bridge = alpha*C + beta*B + gamma*I + delta*(E_q+E_g)
        #   mischt Terme mit verschiedenen Dimensionen:
        #     C_mean ~ O(1/N^2)  (normierte Dichte, dimensionslos)
        #     B_br   ~ G * Phi / r^2  (kpc^-1 * (km/s)^2 / M_sun)
        #     I_br   ~ -sum(rho*log(rho))*dx^2  (nats, dimensionslos)
        #     E_q, E_g ~ O(1)  (normierte Energien, dimensionslos)
        #
        #   Die Summe verschiedener Dimensionen ist physikalisch nicht definiert.
        #
        # Loesung (v11): Jeder Term wird auf seinen empirischen Wertebereich
        #   normiert, sodass alle Beitraege dimensionslos in [0,1] liegen.
        #   Die Normierungsskalen sind aus den Anfangswerten oder analytischen
        #   Grenzen abgeleitet:
        #     C_norm: C_mean ist bereits normiert (sum = 1), typisch O(1/N^2) ~ 1e-4
        #             -> Skalierung: C_hat = C_mean * N^2 (auf ~O(1))
        #     B_norm: B_br ~ G * phi_eq / L^2, natuerliche Gravitationsskala
        #             -> Skalierung: B_hat = B_br / B_scale
        #     I_norm: Entropie ist maximal log(N^2) fuer Gleichverteilung
        #             -> Skalierung: I_hat = I_br / log(N^2)
        #     E_norm: (E_q + E_g) hat keine feste Skala -> normiert auf delta_crit
        #             als natuerlichen Energieschwellenwert
        #             -> Skalierung: E_hat = (E_q + E_g) / (2 * delta_crit)
        # ================================================================
        C_hat = float(np.mean(C_br)) * self.N**2          # ~O(1), dimensionslos
        B_scale = G * self.phi_eq / max(self.L**2, 1e-6)  # natuerliche Gravitationsskala
        B_hat = B_br / max(B_scale, 1e-15)                # ~O(1), dimensionslos
        I_max = np.log(self.N**2)                          # maximale Entropie
        I_hat = I_br / max(I_max, 1e-6)                   # ~O(1), dimensionslos
        E_hat = (E_q + E_g) / max(2.0 * self.delta_crit, 1e-6)  # ~O(1), dimensionslos

        # Brückenformel (alle Terme jetzt dimensionslos und O(1)):
        # Psi_bridge = alpha*C_hat + beta*B_hat + gamma*I_hat + delta*E_hat
        Psi_bridge_val = (alpha_br * C_hat
                          + beta_br  * B_hat
                          + gamma_br * I_hat
                          + delta_br * E_hat)
        self._U_integral += Psi_bridge_val * self.dt

        # --- 6. History aktualisieren ---
        self.wf_history['norm'].append(self.norm_wf)
        self.wf_history['prob_max'].append(float(np.max(self.prob_dens)))
        self.wf_history['v_phase'].append(v_ph_eff)
        self.wf_history['v_group'].append(v_gr_eff)
        self.wf_history['omega_eff'].append(omega_eff)
        self.wf_history['k_eff'].append(k_eff)
        self.wf_history['dispersionsmaß'].append(delta_k)
        # v9: Strang-Splitting Diagnose-Observablen
        self.wf_history['norm_raw'].append(norm_sq_raw)    # Normierung VOR Renorm
        self.wf_history['E_kin_wf'].append(E_kin_wf)
        self.wf_history['E_pot_wf'].append(E_pot_wf)
        self.wf_history['E_tot_wf'].append(E_tot_wf)

        # Brückenformel-spezifische History (erweiterbar)
        # bridge_history ist in __init__() initialisiert
        self.bridge_history['S_Pi'].append(float(S_Pi))
        self.bridge_history['E_q'].append(float(E_q))
        self.bridge_history['E_g'].append(float(E_g))
        self.bridge_history['I_entropy'].append(float(I_br))
        self.bridge_history['U_integral'].append(float(self._U_integral))
        self.bridge_history['delta_E'].append(float(delta_E))
        self.bridge_history['C_mean'].append(float(np.mean(C_br)))
        self.bridge_history['B_gravity'].append(float(B_br))

        # v8/v11: Brückenformel-Schalter-Observablen (berechnet aus aktuellem Zustand)
        # A_br_sdm: S_DM-Aktivierungsfaktor - DIREKT aus glitch_rms (v11)
        #   v8 nutzte k_eff als Proxy weil glitch_rms nicht zugreifbar war.
        #   v11: self._glitch_rms_current wird im klassischen Schritt gespeichert
        #   und ist hier direkt verfuegbar. Kein Proxy mehr noetig.
        # S_ez:  logistischer Eigenzeit-Vor-Schalter aus aktuellem phi_super
        # B_rsh: bridge_linear-Skalierung aus aktuellem phi_super
        # Alle Werte sind im [0,1]-Bereich -> hybrid_aggregate moeglich
        _ez_star  = self.delta_crit
        _ez_delta = max(0.1 * _ez_star, 1e-4)
        _S_ez_obs = float(1.0 / (1.0 + np.exp(-(self.phi_super - _ez_star) / _ez_delta)))
        _B_rsh_obs = float(np.clip(self.phi_super / max(self.delta_crit, 1e-6), 0.0, 1.0))
        # A_br_sdm: direkt aus gespeichertem glitch_rms (v11, kein Proxy)
        _glitch_rms_direct = self._glitch_rms_current   # exakter Wert aus klassischem Schritt
        _sdm_star  = 1.0;  _sdm_delta = 0.3  # gleiche Werte wie im S_DM-Block
        _A_br_obs  = float(1.0 / (1.0 + np.exp(-(_glitch_rms_direct - _sdm_star) / _sdm_delta)))

        # hybrid_aggregate: Brücken-Gesamtscore aus allen Indikatoren
        # Gewichtung: S_Pi (QM-Gravitations-Balance) x2, A_br_sdm (Aktivierung),
        #             B_rsh (R-S-H-Phasenlage), S_ez (Eigenzeit-Phasenlage)
        # Ziel: ein skalarer Score [0,1] der den Gesamtaktivierungszustand
        #        der CIQ-Brücke zusammenfasst (nuetzlich fuer Heatmap / Dashboard)
        _bridge_vals    = np.array([float(S_Pi), _A_br_obs, _B_rsh_obs, _S_ez_obs])
        _bridge_weights = np.array([2.0, 1.0, 1.0, 1.0])  # S_Pi doppelt gewichtet
        _bridge_weights = _bridge_weights / _bridge_weights.sum()
        # hybrid: 50% geometrisches Mittel + 50% arithmetisches Mittel
        _eps = 1e-9
        _geom  = float(np.prod(np.maximum(_bridge_vals, _eps) ** _bridge_weights))
        _arith = float(np.dot(_bridge_vals, _bridge_weights))
        _bridge_score = 0.5 * _geom + 0.5 * _arith

        self.bridge_history['A_br_sdm'].append(_A_br_obs)
        self.bridge_history['B_rsh'].append(_B_rsh_obs)
        self.bridge_history['S_ez'].append(_S_ez_obs)
        self.bridge_history['bridge_score'].append(float(_bridge_score))

        # In Haupt-History eintragen
        self.history['prob_norm'].append(self.norm_wf)
        self.history['v_phase'].append(v_ph_eff)
        self.history['v_group'].append(v_gr_eff)

        # ----------------------------------------------------------------
        # GP-PROPAGATOR-BLOCK (v10) - wird NUR ausgefuehrt wenn use_gp=True
        # ----------------------------------------------------------------
        # Fuehrt einen zweiten, reinen GP-Strang-Schritt auf dem QM-Zustand
        # durch, unabhaengig vom klassischen Phi-Update oben.
        # Psi_gp ist intern und wird nicht mit self.Phi_im geteilt,
        # damit kein Rueckkopplungskonflikt mit dem CIQ-Phasenfeld entsteht.
        # ----------------------------------------------------------------
        if self.use_gp:
            self._gp_step_and_record()

        return Q

    # ----------------------------------------------------------------
    # _gp_step_and_record (v10): GP-Strang-Schritt + Energie-Monitoring
    # ----------------------------------------------------------------
    def _gp_step_and_record(self):
        """
        Fuehrt einen vollstaendigen GP-Strang-Split-Step-Schritt durch und
        schreibt E_gp_kin, E_gp_trap, E_gp_int, E_gp_tot, E_gp_drift
        in wf_history.

        GP-Potential:
          V_gp(x,t) = pot_b * r^2  +  g_gp * |Psi_gp|^2

        Strang-Splitting:
          exp(-i*V_gp(Psi_in)*dt/2)  *  exp(-i*T*dt)  *  exp(-i*V_gp(Psi_mid)*dt/2)

        Keine Renormierung: norm_gp_raw misst unitaere Drift direkt.
        E_gp_0 wird beim ersten Schritt einmalig gesetzt.
        """
        K2      = self._K2
        dx      = self.dx
        HBAR    = HBAR_NORM
        M       = M_NORM
        dt      = self.dt

        # GP-Psi-Zustand: wird einmalig aus aktuellem Phi+Phi_im initialisiert
        # und dann intern weiterpropagiert. Initialisierung beim ersten Aufruf.
        if not hasattr(self, '_Psi_gp') or self._Psi_gp is None:
            # Thomas-Fermi-Startprofil: |Psi|^2 ~ max(0, mu_TF - pot_b*r^2) / g_gp
            R2  = self.X**2 + self.Y**2
            rho_TF = np.maximum(0.0, (self.mu_TF - self.potential_b * R2) / self.g_gp)
            Psi_init = np.sqrt(rho_TF).astype(complex)
            # Phasenkick aus aktuellem Phi (Kopplung an CIQ-Feld)
            phi_rms = float(np.sqrt(np.mean(self.Phi**2))) + 1e-10
            Psi_init *= np.exp(1j * self.Phi / phi_rms * 0.5)
            norm0 = float(np.sum(np.abs(Psi_init)**2) * dx**2)
            if norm0 > 1e-15:
                Psi_init /= np.sqrt(norm0)
            self._Psi_gp = Psi_init
            self._E_gp_0 = None  # wird nach erstem Schritt gesetzt

        Psi = self._Psi_gp
        R2  = self.X**2 + self.Y**2

        def V_gp(Psi_state):
            return self.potential_b * R2 + self.g_gp * np.abs(Psi_state)**2

        def E_gp_functional(Psi_state):
            """GP-Energie-Funktional (normiert auf ||Psi||^2)."""
            rho   = np.abs(Psi_state)**2
            norm_ = float(np.sum(rho) * dx**2) + 1e-30
            # Kinetisch im k-Raum
            Ph    = sfft.fft2(Psi_state)
            E_kin = float(np.sum(HBAR**2 * K2 / (2*M) * np.abs(Ph)**2)
                          * dx**2 / (self.N**2 * norm_))
            # Falle
            E_trap = float(np.sum(self.potential_b * R2 * rho) * dx**2 / norm_)
            # GP-Wechselwirkung g/2 * integral |Psi|^4
            E_int  = float(np.sum(self.g_gp / 2.0 * rho**2) * dx**2 / norm_)
            return E_kin, E_trap, E_int, E_kin + E_trap + E_int

        # ---- Strang-Schritt ----
        V_old  = V_gp(Psi)
        ph_V1  = np.exp(-1j * V_old * dt / 2.0 / HBAR)
        Psi    = ph_V1 * Psi                               # 1. V-Halbschritt
        Psi    = sfft.ifft2(self._phase_T * sfft.fft2(Psi))  # T-Schritt (gecacht)
        V_new  = V_gp(Psi)                                 # V am neuen Zustand
        ph_V2  = np.exp(-1j * V_new * dt / 2.0 / HBAR)
        Psi    = ph_V2 * Psi                               # 2. V-Halbschritt (Strang)

        # Zustand speichern (kein Renormieren: misst unitaere Drift)
        self._Psi_gp = Psi

        # ---- GP-Energie berechnen ----
        E_kin, E_trap, E_int, E_tot = E_gp_functional(Psi)

        # Startenergie beim ersten Schritt setzen
        if self._E_gp_0 is None:
            self._E_gp_0 = E_tot

        E_drift = abs(E_tot - self._E_gp_0)

        # ---- History ----
        self.wf_history['E_gp_kin'].append(E_kin)
        self.wf_history['E_gp_trap'].append(E_trap)
        self.wf_history['E_gp_int'].append(E_int)
        self.wf_history['E_gp_tot'].append(E_tot)
        self.wf_history['E_gp_drift'].append(E_drift)

    # ================================================================

    # 8b. WELLENFUNKTION_KLASSEN

    # Analytische Wellenfunktion eines freien Teilchens

    # Quelle: maths2mind.com - Wellenfunktion eines freien Teilchens

    # 

    # Implementiert:

    # FreieTeilchenWellenfunktion  - ebene Welle + Normierung

    # GaussWellenpaket             - normiertes Gauss-Wellenpaket

    # WellenpaketSuperposition     - Fourier-Superposition (Dispersion)

    # wellenfunktion_visualisierung - 6-Panel-Plot aller Eigenschaften

    # ================================================================

class FreieTeilchenWellenfunktion:
    """
    Analytische Wellenfunktion eines freien Teilchens.
    
    ```
    Psi(x, t) = A * exp(-i * (E*t - p*x) / hbar)
    = A * exp(-i * (omega*t - k*x))
    = A * (cos(k*x - omega*t) - i*sin(k*x - omega*t))
    
    Quelle: maths2mind.com - Wellenfunktion eines freien Teilchens
    
    Eigenschaften:
    E      = hbar * omega  (Planck-Einstein-Relation)
    p      = hbar * k      (de-Broglie-Relation)
    k      = 2*pi / lambda (Wellenzahl)
    omega  = 2*pi * nu     (Kreisfrequenz)
    
    Nichtrelativistische Dispersionsrelation:
    E = p^2 / (2m) => omega = hbar * k^2 / (2m)
    
    Phasengeschwindigkeit:   v_ph = omega / k = E / p = p / (2m)
    Gruppengeschwindigkeit:  v_gr = d(omega)/d(k) = hbar*k/m = p/m  (= v_klassisch)
    
    Normierung:
    |Psi(x,t)|^2 = A^2 = const  (ebene Welle: NICHT quadrat-integrierbar!)
    => muss als Wellenpaket (Gauss-Einhuellende) normiert werden.
    => Normierungsbedingung: integral_{-inf}^{inf} |Psi|^2 dx = 1
    
    Wahrscheinlichkeitsdichte:
    rho(x, t) = |Psi(x, t)|^2
    P(a <= x <= b) = integral_a^b rho(x, t) dx
    """

    def __init__(self, k0=2.0, m=M_NORM, hbar=HBAR_NORM, A=1.0):
        """
        Parameter
        ---------
        k0   : Zentralwellenzahl (in Sim.-Einheiten)
        m    : Masse (normiert, Standard: 1.0)
        hbar : reduziertes Wirkungsquantum (normiert, Standard: 1.0)
        A    : Amplitude (vor Normierung)
        """
        self.k0    = k0
        self.m     = m
        self.hbar  = hbar
        self.A     = A

        # Abgeleitete Groessen (Dispersionsrelation freies Teilchen)
        self.omega = hbar * k0**2 / (2.0 * m)   # omega = hbar*k^2/(2m)
        self.E     = hbar * self.omega           # E = hbar * omega
        self.p     = hbar * k0                  # p = hbar * k
        self.lam   = 2.0 * np.pi / k0 if k0 != 0 else np.inf  # Wellenlaenge

        # Geschwindigkeiten
        self.v_phase = self.omega / k0 if k0 != 0 else 0.0    # v_ph = omega/k
        self.v_group = hbar * k0 / m                           # v_gr = hbar*k/m

    def psi(self, x, t):
        """
        Komplexe Wellenfunktion Psi(x, t) = A * exp(-i*(omega*t - k*x))
        = A * exp(i*(k*x - omega*t))

        Zerlegung:
          Re(Psi) = A * cos(k*x - omega*t)
          Im(Psi) = A * sin(k*x - omega*t)   [Vorzeichen: +i in exp => +sin]
        """
        phase = self.k0 * x - self.omega * t
        return self.A * np.exp(1j * phase)

    def psi_real(self, x, t):
        """Realteil: Re(Psi) = A * cos(k*x - omega*t)"""
        return self.A * np.cos(self.k0 * x - self.omega * t)

    def psi_imag(self, x, t):
        """Imaginaerteil: Im(Psi) = A * sin(k*x - omega*t)"""
        return self.A * np.sin(self.k0 * x - self.omega * t)

    def prob_dichte(self, x, t):
        """
        Wahrscheinlichkeitsdichte: rho(x,t) = |Psi(x,t)|^2 = A^2
        (fuer ebene Welle ortsunabhaengig - physikalisch: Teilchen ueberall gleich wahrscheinlich)
        """
        return np.abs(self.psi(x, t))**2

    def prob_intervall(self, x_arr, t, a, b):
        """
        Wahrscheinlichkeit P(a <= x <= b) = integral_a^b |Psi|^2 dx
        (numerische Integration via Trapezregel)
        """
        mask = (x_arr >= a) & (x_arr <= b)
        if not np.any(mask):
            return 0.0
        dx_arr = x_arr[1] - x_arr[0]
        return float(np.trapezoid(self.prob_dichte(x_arr[mask], t), x_arr[mask]))

    def normierungsintegral(self, x_arr, t):
        """
        Normierungsintegral integral |Psi|^2 dx
        (fuer ebene Welle = A^2 * L, muss durch sqrt(L) normiert werden)
        """
        dx_arr = x_arr[1] - x_arr[0]
        return float(np.trapezoid(self.prob_dichte(x_arr, t), x_arr))

    def print_info(self):
        """Gibt alle Parameter und abgeleiteten Groessen aus."""
        print(f"\n  Freies Teilchen - Wellenfunktionsparameter:")
        print(f"    k0      = {self.k0:.4f}  [1/L]   (Wellenzahl)")
        print(f"    omega   = {self.omega:.4f}  [1/T]   (Kreisfrequenz, Dispersionsrelation)")
        print(f"    E       = {self.E:.4f}  [E]     (Energie: E = hbar*omega)")
        print(f"    p       = {self.p:.4f}  [p]     (Impuls: p = hbar*k)")
        print(f"    lambda  = {self.lam:.4f}  [L]     (Wellenlaenge: lambda = 2pi/k)")
        print(f"    v_phase = {self.v_phase:.4f}  [L/T]   (Phasengeschwindigkeit: omega/k)")
        print(f"    v_group = {self.v_group:.4f}  [L/T]   (Gruppengeschwindigkeit: hbar*k/m)")
        print(f"    A       = {self.A:.4f}  [-]     (Amplitude)")
        print(f"    hbar    = {self.hbar:.4f}  (normiert)")
        print(f"    m       = {self.m:.4f}  (normiert)")
        print(f"  Dispersionsrelation: omega = hbar*k^2/(2*m)")
        print(f"  => v_ph = p/(2m) = {self.p/(2*self.m):.4f}  (halbe Teilchengeschwindigkeit)")
        print(f"  => v_gr = p/m   = {self.p/self.m:.4f}  (klassische Teilchengeschwindigkeit)")

class GaussWellenpaket:
    """
    Normiertes Gauss-Wellenpaket im Ortsraum.
    
    ```
    Psi_G(x, t=0) = (2*pi*sigma^2)^(-1/4) * exp(i*k0*x) * exp(-x^2/(4*sigma^2))
    
    Normiert: integral |Psi_G|^2 dx = 1 (exakt, analytisch)
    
    Fourier-Darstellung (Impulsraum):
    phi_G(k) = (2*sigma^2/pi)^(1/4) * exp(-(k-k0)^2 * sigma^2)
    
    Zeitentwicklung (freies Teilchen, analytisch):
    sigma(t) = sigma * sqrt(1 + (hbar*t/(2*m*sigma^2))^2)  --> Dispersion!
    Schwerpunkt: x_0(t) = v_gr * t = (hbar*k0/m) * t
    
    Unschaerferelation:
    Delta_x * Delta_p = hbar/2  (Gauss-Wellenpaket: minimale Unschaerfe!)
    Delta_x = sigma
    Delta_p = hbar / (2*sigma)
    
    Dispersionsrelation:
    omega(k) = hbar*k^2/(2m)  => nichtlineares Dispersionsgesetz => Wellenpaket zerlaeuft
    """

    def __init__(self, k0=2.0, sigma=1.0, m=M_NORM, hbar=HBAR_NORM):
        """
        Parameter
        ---------
        k0    : Zentral-Wellenzahl
        sigma : Breite des Wellenpakets im Ortsraum (Unschaerfe Delta_x = sigma)
        m     : Masse (normiert)
        hbar  : normiertes Wirkungsquantum
        """
        self.k0    = k0
        self.sigma = sigma
        self.m     = m
        self.hbar  = hbar

        # Dispersionsrelation
        self.omega0 = hbar * k0**2 / (2.0 * m)
        self.v_group = hbar * k0 / m
        self.v_phase = self.omega0 / k0 if k0 != 0 else 0.0

        # Unschaerfen (Gauss-Wellenpaket = minimale Unschaerfe)
        self.delta_x = sigma
        self.delta_p = hbar / (2.0 * sigma)
        self.delta_k = 1.0 / (2.0 * sigma)
        self.heisenberg_produkt = self.delta_x * self.delta_p  # sollte = hbar/2

        # Normierungskonstante
        self.N0 = (2.0 * np.pi * sigma**2)**(-0.25)

    def psi_t0(self, x):
        """
        Gauss-Wellenpaket bei t=0.
        Psi(x, 0) = N0 * exp(i*k0*x) * exp(-x^2/(4*sigma^2))
        """
        return self.N0 * np.exp(1j * self.k0 * x) * np.exp(-x**2 / (4.0 * self.sigma**2))

    def sigma_t(self, t):
        """
        Zeitabhaengige Breite des Wellenpakets (Auseinanderlaufen durch Dispersion).
        sigma(t) = sigma * sqrt(1 + (hbar*t/(2*m*sigma^2))^2)
        """
        tau = self.hbar * t / (2.0 * self.m * self.sigma**2)
        return self.sigma * np.sqrt(1.0 + tau**2)

    def N_t(self, t):
        """Zeitabhaengige Normierungskonstante."""
        return (2.0 * np.pi * self.sigma_t(t)**2)**(-0.25)

    def x0_t(self, t):
        """Schwerpunkt des Wellenpakets: x_0(t) = v_gr * t"""
        return self.v_group * t

    def psi(self, x, t):
        """
        Zeitabhaengige Wellenfunktion des Gauss-Wellenpakets (analytisch, freies Teilchen).

        Psi(x, t) = N(t) * exp(i*k0*(x - v_ph*t)) * exp(-(x-x0(t))^2 / (4*sigma(t)^2))

        Phasenterm: exp(i*k0*x) * exp(-i*omega0*t) = Traegerwelle
        Einhuellende: Gauss mit Breite sigma(t) und Zentrum x0(t)=v_gr*t
        """
        sig_t = self.sigma_t(t)
        x0    = self.x0_t(t)
        N_t   = self.N_t(t)
        phase  = self.k0 * (x - self.v_phase * t)
        envelope = np.exp(-(x - x0)**2 / (4.0 * sig_t**2))
        return N_t * np.exp(1j * phase) * envelope

    def prob_dichte(self, x, t):
        """Wahrscheinlichkeitsdichte rho(x,t) = |Psi(x,t)|^2"""
        return np.abs(self.psi(x, t))**2

    def phi_impulsraum(self, k_arr):
        """
        Fourier-Transformierte (Impulsraum) bei t=0:
        phi(k) = (2*sigma^2/pi)^(1/4) * exp(-(k-k0)^2 * sigma^2)
        Gauss in k-Raum mit Breite Delta_k = 1/(2*sigma)
        """
        N_k = (2.0 * self.sigma**2 / np.pi)**0.25
        return N_k * np.exp(-(k_arr - self.k0)**2 * self.sigma**2)

    def print_info(self):
        """Gibt alle Parameter und Unschaerfen aus."""
        print(f"\n  Gauss-Wellenpaket - Parameter:")
        print(f"    k0          = {self.k0:.4f}  (Zentral-Wellenzahl)")
        print(f"    sigma       = {self.sigma:.4f}  (Ortsunschaerfe Delta_x)")
        print(f"    omega0      = {self.omega0:.4f}  (Zentral-Kreisfrequenz)")
        print(f"    v_gr        = {self.v_group:.4f}  (Gruppengeschwindigkeit = klassisch)")
        print(f"    v_ph        = {self.v_phase:.4f}  (Phasengeschwindigkeit = v_gr/2)")
        print(f"    Delta_x     = {self.delta_x:.4f}  (Ortsunschaerfe)")
        print(f"    Delta_p     = {self.delta_p:.4f}  (Impulsunschaerfe = hbar/(2*sigma))")
        print(f"    Delta_k     = {self.delta_k:.4f}  (k-Unschaerfe = 1/(2*sigma))")
        print(f"    Heis.Prod.  = {self.heisenberg_produkt:.4f}  (soll = hbar/2 = {HBAR_NORM/2:.4f})")
        print(f"    sigma(t=1)  = {self.sigma_t(1.0):.4f}  (Auseinanderlaufen nach t=1)")

class WellenpaketSuperposition:
    """
    Superposition ebener Wellen (Fourier-Darstellung des Wellenpakets).
    
    ```
    Psi(x, t) = (1/sqrt(2*pi)) * integral phi(k) * exp(i*(k*x - omega(k)*t)) dk
    
    Diskrete Approximation (N Moden):
    Psi(x, t) ~ sum_{n=1}^{N} c_n * exp(i*(k_n*x - omega_n*t))
    
    Dispersionsrelation (freies Teilchen):
    omega(k) = hbar * k^2 / (2m)
    
    Bedeutung:
    Gruppengeschwindigkeit: v_gr = d(omega)/dk |_{k=k0} = hbar*k0/m
    Phasengeschwindigkeit:  v_ph = omega(k0)/k0 = hbar*k0/(2m) = v_gr/2
    
    Superpositionsprinzip der QM:
    Jede Linearkombination von Loesungen der Schroedinger-Gleichung
    ist wieder eine Loesung (Linearitaet der SG).
    """

    def __init__(self, k0=2.0, sigma_k=0.5, N_moden=64, m=M_NORM, hbar=HBAR_NORM):
        """
        Parameter
        ---------
        k0      : Zentral-Wellenzahl
        sigma_k : Breite der k-Verteilung (Gauss im k-Raum)
        N_moden : Anzahl der superpositionierten ebenen Wellen
        m       : Masse
        hbar    : normiertes hbar
        """
        self.k0      = k0
        self.sigma_k = sigma_k
        self.N_moden = N_moden
        self.m       = m
        self.hbar    = hbar

        # Diskrete k-Werte um k0 (Gauss-Gewichtung)
        k_min = max(k0 - 4.0 * sigma_k, 0.01)
        k_max = k0 + 4.0 * sigma_k
        self.k_arr   = np.linspace(k_min, k_max, N_moden)
        self.dk      = self.k_arr[1] - self.k_arr[0]

        # Gauss-Gewichte im k-Raum (= Fourier-Koeffizienten)
        self.phi_k   = np.exp(-(self.k_arr - k0)**2 / (2.0 * sigma_k**2))
        self.phi_k  /= np.sqrt(np.sum(self.phi_k**2) * self.dk)  # Normierung

        # Dispersionsrelation fuer alle k-Moden
        self.omega_arr = hbar * self.k_arr**2 / (2.0 * m)

        # Gruppen- und Phasengeschwindigkeiten
        self.v_group = hbar * k0 / m
        self.v_phase = hbar * k0 / (2.0 * m)

    def psi(self, x, t):
        """
        Superposition aller Moden:
        Psi(x, t) = sum_n phi(k_n) * exp(i*(k_n*x - omega_n*t)) * dk / sqrt(2*pi)
        """
        result = np.zeros_like(x, dtype=complex)
        for n in range(self.N_moden):
            phase   = self.k_arr[n] * x - self.omega_arr[n] * t
            result += self.phi_k[n] * np.exp(1j * phase) * self.dk
        return result / np.sqrt(2.0 * np.pi)

    def prob_dichte(self, x, t):
        """Wahrscheinlichkeitsdichte |Psi(x,t)|^2"""
        return np.abs(self.psi(x, t))**2

    def dispersionsmaß(self):
        """
        Dispersionsmaß D: Breite des omega-Spektrums.
        D = sqrt(sum(omega_n^2 * |phi_n|^2) / sum(|phi_n|^2) - omega_0^2)
        Misst die Breite der Dispersionsrelation -> Zerlaufgeschwindigkeit.
        """
        omega_mean = np.sum(self.omega_arr * self.phi_k**2) / np.sum(self.phi_k**2)
        omega_var  = np.sum(self.omega_arr**2 * self.phi_k**2) / np.sum(self.phi_k**2)
        return float(np.sqrt(max(omega_var - omega_mean**2, 0.0)))

def wellenfunktion_visualisierung(engine=None, x_range=8.0, N_x=400, t_values=None):
    """
    6-Panel Visualisierung der Wellenfunktion eines freien Teilchens.
    
    ```
    Panel 1: Re(Psi), Im(Psi), |Psi|^2 bei t=0
    Panel 2: Gauss-Wellenpaket Zeitentwicklung (Dispersion)
    Panel 3: Impulsraum |phi(k)|^2 (Fourier-Darstellung)
    Panel 4: Phasen- vs. Gruppengeschwindigkeit (Dispersionsrelation omega(k))
    Panel 5: Normierung und Unschaerfe (Delta_x * Delta_p = hbar/2)
    Panel 6: Kopplung an CIQ-Phasenfeld (falls engine gegeben)
    
    Physikalische Grundlagen (maths2mind.com):
    Psi(x,t) = A * exp(-i*(E*t - p*x)/hbar)
    E = hbar*omega,  p = hbar*k,  k = 2pi/lambda
    omega = hbar*k^2/(2m)  [Dispersionsrelation, freies Teilchen]
    v_ph = omega/k,  v_gr = d(omega)/dk = hbar*k/m
    """
    if t_values is None:
        t_values = [0.0, 0.5, 1.0, 2.0, 4.0]

    # Objekte erstellen
    x_arr  = np.linspace(-x_range, x_range, N_x)
    ftw    = FreieTeilchenWellenfunktion(k0=2.0, m=1.0, hbar=1.0, A=1.0)
    gwp    = GaussWellenpaket(k0=2.0, sigma=1.0, m=1.0, hbar=1.0)
    super_ = WellenpaketSuperposition(k0=2.0, sigma_k=0.5, N_moden=32, m=1.0, hbar=1.0)

    fig, axes = plt.subplots(2, 3, figsize=(20, 12), facecolor='#0a0a1a')
    fig.suptitle(
        'Wellenfunktion des freien Teilchens  -  CIQ Quanten-Orchester Integration\n'
        'Psi(x,t) = A*exp(-i*(E*t - p*x)/hbar)  |  E=hbar*omega  |  p=hbar*k  |  omega=hbar*k^2/(2m)',
        fontsize=13, color='#fbbf24', fontweight='bold', y=0.99
    )

    for ax in axes.flat:
        ax.set_facecolor('#0a0a1a')
        ax.tick_params(colors='#aaa', labelsize=9)
        ax.grid(True, alpha=0.12, color='#333')
        for spine in ax.spines.values():
            spine.set_color('#333333')

    # -- Panel 1: Re/Im/|Psi|^2 bei t=0 --
    ax = axes[0, 0]
    psi_t0 = gwp.psi_t0(x_arr)
    ax.plot(x_arr, psi_t0.real,       color='#2dd4bf', lw=2,   label='Re(Psi) - Realteil')
    ax.plot(x_arr, psi_t0.imag,       color='#f43f5e', lw=2,   label='Im(Psi) - Imaginaerteil')
    ax.fill_between(x_arr, 0, np.abs(psi_t0)**2, alpha=0.3, color='#fbbf24',
                    label='|Psi|^2 - Wahrscheinlichkeitsdichte')
    ax.axvline(0, color='#555', lw=0.5, linestyle=':')
    ax.set_title('Gauss-Wellenpaket  t=0\nPsi = Re(Psi) + i*Im(Psi)',
                 color='white', fontsize=10, pad=6)
    ax.set_xlabel('x [Sim.-Einh.]', color='#888', fontsize=9)
    ax.set_ylabel('Amplitude / Dichte', color='#888', fontsize=9)
    ax.legend(fontsize=8, facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')

    # -- Panel 2: Zeitentwicklung des Gauss-Wellenpakets --
    ax = axes[0, 1]
    colors_t = ['#ffffff', '#66ccff', '#2dd4bf', '#fbbf24', '#f43f5e']
    for ti, col in zip(t_values, colors_t):
        rho_t = gwp.prob_dichte(x_arr, ti)
        ax.plot(x_arr, rho_t, color=col, lw=1.5, label=f't={ti:.1f}')
    ax.set_title('Zeitentwicklung |Psi(x,t)|^2\nDispersion: Wellenpaket laeuft auseinander',
                 color='white', fontsize=10, pad=6)
    ax.set_xlabel('x [Sim.-Einh.]', color='#888', fontsize=9)
    ax.set_ylabel('Wahrscheinlichkeitsdichte', color='#888', fontsize=9)
    ax.legend(fontsize=8, facecolor='#1a1a2e', edgecolor='#333', labelcolor='white',
              title='Zeit t', title_fontsize=8)

    # -- Panel 3: Impulsraum |phi(k)|^2 --
    ax = axes[0, 2]
    k_arr_plot = np.linspace(0.01, 5.0, 400)
    phi_k_plot = gwp.phi_impulsraum(k_arr_plot)
    ax.fill_between(k_arr_plot, 0, np.abs(phi_k_plot)**2, alpha=0.5, color='#a78bfa')
    ax.plot(k_arr_plot, np.abs(phi_k_plot)**2, color='#a78bfa', lw=2, label='|phi(k)|^2')
    ax.axvline(gwp.k0, color='#fbbf24', linestyle='--', lw=1.5,
               label=f'k0 = {gwp.k0:.2f}')
    ax.axvspan(gwp.k0 - gwp.delta_k, gwp.k0 + gwp.delta_k,
               alpha=0.15, color='#fbbf24', label=f'Delta_k = {gwp.delta_k:.2f}')
    ax.set_title('Impulsraum |phi(k)|^2\np = hbar*k  |  phi(k) = FT(Psi(x,0))',
                 color='white', fontsize=10, pad=6)
    ax.set_xlabel('Wellenzahl k [1/L]', color='#888', fontsize=9)
    ax.set_ylabel('Spektraldichte', color='#888', fontsize=9)
    ax.legend(fontsize=8, facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')

    # -- Panel 4: Dispersionsrelation omega(k) --
    ax = axes[1, 0]
    k_plot = np.linspace(0.1, 5.0, 300)
    omega_plot = HBAR_NORM * k_plot**2 / (2.0 * M_NORM)
    v_ph_plot  = omega_plot / k_plot
    v_gr_plot  = HBAR_NORM * k_plot / M_NORM
    ax.plot(k_plot, omega_plot, color='#2dd4bf', lw=2.5, label='omega(k) = hbar*k^2/(2m)')
    ax2_d = ax.twinx()
    ax2_d.plot(k_plot, v_ph_plot, color='#f43f5e', lw=1.5, linestyle='--',
               label='v_ph = omega/k')
    ax2_d.plot(k_plot, v_gr_plot, color='#fbbf24', lw=1.5,
               label='v_gr = hbar*k/m = 2*v_ph')
    ax.axvline(gwp.k0, color='#a78bfa', linestyle=':', alpha=0.7,
               label=f'k0={gwp.k0}')
    ax.set_title('Dispersionsrelation: omega = hbar*k^2/(2m)\nv_gr = 2*v_ph  (freies Teilchen)',
                 color='white', fontsize=10, pad=6)
    ax.set_xlabel('Wellenzahl k [1/L]', color='#888', fontsize=9)
    ax.set_ylabel('Kreisfrequenz omega', color='#888', fontsize=9)
    ax2_d.set_ylabel('Geschwindigkeit v', color='#888', fontsize=9)
    ax.legend(fontsize=8, loc='upper left',  facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')
    ax2_d.legend(fontsize=8, loc='upper right', facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')
    ax2_d.tick_params(colors='#888', labelsize=8)

    # -- Panel 5: Unschaerferelation Delta_x * Delta_p --
    ax = axes[1, 1]
    sigma_arr = np.linspace(0.1, 4.0, 300)
    delta_x   = sigma_arr
    delta_p   = HBAR_NORM / (2.0 * sigma_arr)
    prod      = delta_x * delta_p   # sollte = hbar/2 (Gauss minimiert Unschaerfe)
    ax.plot(sigma_arr, delta_x,  color='#2dd4bf', lw=2, label='Delta_x = sigma')
    ax.plot(sigma_arr, delta_p,  color='#f43f5e', lw=2, label='Delta_p = hbar/(2*sigma)')
    ax.fill_between(sigma_arr, 0, prod, alpha=0.2, color='#fbbf24',
                    label=f'Delta_x*Delta_p = hbar/2 = {HBAR_NORM/2:.2f}')
    ax.axhline(HBAR_NORM / 2, color='#fbbf24', linestyle='--', lw=1.5,
               label=f'Heisenberg-Grenze = {HBAR_NORM/2:.2f}')
    ax.axvline(gwp.sigma, color='#a78bfa', linestyle=':', alpha=0.8,
               label=f'sigma={gwp.sigma} (akt. Wellenpaket)')
    ax.set_title('Heisenberg-Unschaerferelation\nDelta_x * Delta_p >= hbar/2',
                 color='white', fontsize=10, pad=6)
    ax.set_xlabel('Ortsbreite sigma [L]', color='#888', fontsize=9)
    ax.set_ylabel('Unschaerfe', color='#888', fontsize=9)
    ax.legend(fontsize=8, facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')
    ax.set_ylim(0, min(3.0, ax.get_ylim()[1]))

    # -- Panel 6: Kopplung an CIQ-Phasenfeld --
    ax = axes[1, 2]
    if engine is not None and engine.Phi is not None:
        center  = engine.N // 2
        x_ciq   = np.linspace(-engine.L, engine.L, engine.N)
        phi_ciq = engine.Phi[center, :]
        rho_ciq = engine.prob_dens[center, :] if hasattr(engine, 'prob_dens') else phi_ciq**2
        phi_im  = engine.Phi_im[center, :] if hasattr(engine, 'Phi_im') else np.zeros_like(phi_ciq)
        ax.plot(x_ciq, phi_ciq, color='#2dd4bf', lw=2,   label='Re(Psi) = Phi(x,y=0,t)')
        ax.plot(x_ciq, phi_im,  color='#f43f5e', lw=1.5, label='Im(Psi) = Phi_im(x,y=0,t)')
        ax.fill_between(x_ciq, 0, rho_ciq * 3, alpha=0.25, color='#fbbf24',
                        label='|Psi|^2 * 3 (Wahrsch.dichte)')
        if engine.wf_history["k_eff"]:
            ax.set_title(f'CIQ-Phasenfeld als Wellenfunktion\n'
                         f't={engine.time:.2f}  norm={engine.norm_wf:.3f}  k_eff={engine.wf_history["k_eff"][-1]:.3f}',
                         color='white', fontsize=9, pad=6)
        else:
            ax.set_title(f'CIQ-Phasenfeld als Wellenfunktion\nt={engine.time:.2f}',
                         color='white', fontsize=9, pad=6)
        ax.axhline(0, color='#555', lw=0.5)
    else:
        # Fallback: Zeige Superpositions-Wellenpaket
        x_sup  = np.linspace(-x_range, x_range, 200)
        rho_sup = super_.prob_dichte(x_sup, 0.0)
        rho_sup_t = super_.prob_dichte(x_sup, 1.5)
        ax.plot(x_sup, rho_sup,   color='#2dd4bf', lw=2,   label='Superposition t=0')
        ax.plot(x_sup, rho_sup_t, color='#fbbf24', lw=2,   label='Superposition t=1.5')
        ax.set_title(f'Wellenpaket-Superposition ({super_.N_moden} Moden)\n'
                     f'k0={super_.k0}  sigma_k={super_.sigma_k}  v_gr={super_.v_group:.2f}',
                     color='white', fontsize=10, pad=6)

    ax.set_xlabel('x [Sim.-Einh.]', color='#888', fontsize=9)
    ax.set_ylabel('Amplitude / Dichte', color='#888', fontsize=9)
    ax.legend(fontsize=8, facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')

    plt.tight_layout(rect=[0, 0, 1, 0.95])
    return fig

