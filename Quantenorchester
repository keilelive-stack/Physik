class SDMObservables:
    """
    Messbare Observablen für S_DM (Dunkle Materie-Kopplung).

    S_DM wird messbar gekoppelt durch:
        1. σ_v_SDM: Effektive Geschwindigkeitsdispersion (Galaxienrotation)
        2. δv_rot:  Rotationskurven-Residuum (SPARC-Vergleich)
        3. P_SDM(k): Leistungsspektrum (Materie-Strukturen)
        4. f_DM:    Dunkle-Materie-Anteil im Blasenvolumen

    Physikalische Basis:
        ρ_DM_eff(r) = ζ · S_DM(r) / (4π·r²·dr)
        → S_DM wirkt wie eine effektive DM-Dichte

    Verknüpfung mit CIQ-Mastergleichung:
        H² = (8πG/3)·(ρ_DE + ζ·S_DM + ρ_b + ρ_geo)
        → S_DM tritt als Dichte-Term in der Friedmann-Gleichung auf
        → Observable: H(z)-Messung aus Typ-Ia Supernovae
    """

    def __init__(self, zeta=ZETA_SDM, G_norm=G_CIQ_NORM):
        self.zeta   = zeta
        self.G_norm = G_norm

    def compute_sdm_radial_profile(self, S_DM, R_grid, n_bins=50):
        """
        Radialprofil von S_DM: ρ_SDM(r) = ⟨S_DM⟩_ring(r)

        Einheit: [S_DM] / m² (gemittelt über Kreisring)
        Verwendung: Eingabe für Rotationskurven-Berechnung
        """
        r_max   = R_grid.max()
        r_edges = np.linspace(0, r_max, n_bins + 1)
        r_mids  = 0.5 * (r_edges[:-1] + r_edges[1:])
        sdm_profile = np.zeros(n_bins)

        for i in range(n_bins):
            mask = ((R_grid >= r_edges[i]) & (R_grid < r_edges[i+1]))
            if np.any(mask):
                sdm_profile[i] = np.mean(S_DM[mask])

        return r_mids, sdm_profile

    def compute_v_rotation(self, r_arr, sdm_profile, dx):
        """
        Effektive Rotationsgeschwindigkeit aus S_DM-Profil.

        Ableitung:
            M_SDM(<r) = ζ · ∫₀ʳ ρ_SDM(r') · 2π·r'·dr'  (2D-Projektion)
            v_rot²(r) = G · M_SDM(<r) / r
            v_rot(r)  = √(G·ζ·M_SDM(<r)/r)

        Einheit: [v_rot] = √(G·M/r) = normiert [CIQ-Einheiten]

        Observable:
            Vergleich mit gemessener v_obs(r) aus SPARC-Katalog:
            χ² = Σᵢ [v_rot(rᵢ) - v_obs(rᵢ)]² / σ²(rᵢ)
        """
        M_enclosed = np.zeros_like(r_arr)
        for i in range(1, len(r_arr)):
            dr = r_arr[i] - r_arr[i-1]
            # 2D-Kreisring: dM = ρ · 2π·r·dr
            ring_mass = self.zeta * sdm_profile[i] * 2 * np.pi * r_arr[i] * dr
            M_enclosed[i] = M_enclosed[i-1] + ring_mass

        r_safe = np.maximum(r_arr, 1e-6)
        v_rot_sq = self.G_norm * M_enclosed / r_safe
        v_rot = np.sqrt(np.maximum(v_rot_sq, 0.0))
        return v_rot

    def compute_sigma_v_eff(self, S_DM, R_grid, dx):
        """
        Effektive Geschwindigkeitsdispersion σ_v (massengewichtet).

        Definition (Jeans-Gleichung):
            σ_v² = ζ · ∫ S_DM(r) · r² dr / ∫ S_DM(r) dr

        Physik:
            σ_v misst die kinetische Energie der S_DM-Verteilung.
            Große σ_v → S_DM weit vom Zentrum → diffuse Halos.
            Kleine σ_v → S_DM konzentriert → kompakte Kerne.

        Observable:
            σ_v aus stellaren Geschwindigkeitsmessungen in Galaxien.
            CIQ-Vorhersage: σ_v ∝ √(ζ · ⟨S_DM⟩ · r²_eff)

        Einheit: [σ_v] = √(m²/s²) = m/s  (normiert: dimensionlos)
        """
        r2_sdm  = np.sum(S_DM * R_grid**2) * dx**2
        sdm_tot = np.sum(S_DM) * dx**2 + 1e-15
        sigma_v_sq = self.zeta * r2_sdm / sdm_tot
        return float(np.sqrt(max(sigma_v_sq, 0.0)))

    def compute_power_spectrum(self, S_DM, dx):
        """
        Leistungsspektrum P_SDM(k) = |FFT(S_DM)|² / N²

        Physikalische Bedeutung:
            P_SDM(k) gibt die Stärke der S_DM-Fluktuationen auf
            Skala λ = 2π/k an.
            Vergleich mit Materie-Leistungsspektrum P(k) aus Planck:
            → P_SDM(k) ∝ k^n_s  (Harrison-Zel'dovich: n_s ~ 1)
            → Abweichungen zeigen CIQ-spezifische Strukturbildung

        Einheit: [P_SDM] = [S_DM]² · m⁴ (dimensionierte Varianz)

        Observable:
            Einziger freier Parameter: ζ (Normierung)
            → P_SDM(k₀) = P_matter(k₀) fixiert ζ aus CMB-Daten
        """
        S_k    = sfft.fft2(S_DM)
        P_k    = np.abs(S_k)**2 / S_DM.size**2

        N    = S_DM.shape[0]
        kx   = sfft.fftfreq(N, d=dx) * 2 * np.pi
        ky   = sfft.fftfreq(N, d=dx) * 2 * np.pi
        KX, KY = np.meshgrid(kx, ky)
        k_abs  = np.sqrt(KX**2 + KY**2)

        # Radiales Mittel (azimuthales Leistungsspektrum)
        k_bins = np.linspace(0, k_abs.max(), N // 2)
        P_radial = np.zeros(len(k_bins) - 1)
        k_mids   = 0.5 * (k_bins[:-1] + k_bins[1:])

        for i in range(len(k_mids)):
            mask = ((k_abs >= k_bins[i]) & (k_abs < k_bins[i+1]))
            if np.any(mask):
                P_radial[i] = np.mean(P_k[mask])

        return k_mids, P_radial

    def compute_f_dm(self, S_DM, Phi, dx):
        """
        Dunkle-Materie-Anteil f_DM im Blasenvolumen.

        f_DM = ζ·⟨S_DM⟩ / (ρ_bary + ζ·⟨S_DM⟩)
        ρ_bary ∝ ⟨|Φ|²⟩

        Observable:
            f_DM aus Galaxienhaufen-Röntgenbeobachtungen (Chandra/XMM).
            Kosmologischer Wert: f_DM ~ 0.85
            CIQ-Vorhersage bei Resonanz (phi_super ~ delta_crit): f_DM ~ 0.7-0.9

        Einheit: dimensionlos [0, 1]
        """
        rho_sdm  = self.zeta * np.mean(S_DM)
        rho_bary = np.mean(Phi**2) * dx**2
        total    = rho_sdm + rho_bary + 1e-15
        return float(rho_sdm / total)

    def all_observables(self, S_DM, Phi, R_grid, dx):
        """
        Berechnet alle paper-relevanten S_DM-Observablen in einem Aufruf.

        Rückgabe: dict mit allen Messwerten + Einheiten
        """
        r_mids, sdm_profile = self.compute_sdm_radial_profile(S_DM, R_grid)
        v_rot    = self.compute_v_rotation(r_mids, sdm_profile, dx)
        sigma_v  = self.compute_sigma_v_eff(S_DM, R_grid, dx)
        k_mids, P_SDM = self.compute_power_spectrum(S_DM, dx)
        f_dm     = self.compute_f_dm(S_DM, Phi, dx)
        sdm_mean = float(np.mean(S_DM))
        sdm_max  = float(np.max(S_DM))

        return {
            # Skalare Observablen
            'sigma_v_eff':    sigma_v,     # Geschwindigkeitsdispersion (messbar)
            'f_dm':           f_dm,        # Dunkle-Materie-Anteil (messbar)
            'sdm_mean':       sdm_mean,    # mittlere S_DM-Dichte
            'sdm_max':        sdm_max,     # maximale S_DM-Dichte

            # Kurven-Observablen
            'r_profile':      r_mids,      # Radialpositionen [CIQ-Einheiten]
            'sdm_profile':    sdm_profile, # S_DM-Radialprofi
            'v_rot_sdm':      v_rot,       # Rotationskurve aus S_DM [CIQ-Einh.]
            'k_spectrum':     k_mids,      # Wellenzahlvektor [1/m_norm]
            'P_sdm_spectrum': P_SDM,       # Leistungsspektrum [S_DM²·m²]

            # Einheiten-Dokumentation (für Paper-Tabellen)
            'einheiten': {
                'sigma_v_eff':    'dimensionlos (normiert)',
                'f_dm':           'dimensionlos [0,1]',
                'v_rot_sdm':      'CIQ-Einheiten = √(G_norm·M/r)',
                'P_sdm_spectrum': 'S_DM² · m²_norm',
                'k_spectrum':     '1/m_norm',
            }
        }


