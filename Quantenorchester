def get_masse_GeV(name):
    """Gibt numerische Masse in GeV zurueck (aus FERMIONEN oder BOSONEN dict)."""
    if name in STANDARDMODELL_FERMIONEN:
        m = STANDARDMODELL_FERMIONEN[name]["masse_GeV"]
    elif name in STANDARDMODELL_BOSONEN:
        m = STANDARDMODELL_BOSONEN[name]["masse_GeV"]
    else:
        return None
    try:
        return float(m)
    except (TypeError, ValueError):
        return None

def get_ciq_sigma(name):
    """CIQ Blasen-Groesse sigma fuer ein Teilchen."""
    for d in [STANDARDMODELL_FERMIONEN, STANDARDMODELL_BOSONEN]:
        if name in d:
            return d[name].get("ciq_sigma", 1.5)
    return 1.5

def get_ciq_modus(name):
    """Gibt den CIQ Spin-Modus zurueck (fermion/boson/graviton/mixed)."""
    for d in [STANDARDMODELL_FERMIONEN, STANDARDMODELL_BOSONEN]:
        if name in d:
            return d[name].get("ciq_modus", "mixed")
    return "mixed"

