    ax1.legend(fontsize=7, facecolor='#111133', labelcolor='white', loc='upper left')

    # ---- Panel 2: Unendlicher Potentialtopf ---------------------
    ax2 = fig.add_subplot(gs[0, 1])
    _style(ax2, '2. Unendlicher Potentialtopf\nEigenfunktionen n=1..4  (En~n^2)')
    topf  = UnendlicherPotentialtopf(L=4.0)
    x_box = np.linspace(-2.5, 2.5, 600)
    E_ref = topf.energie_n(4)
    for n in range(1, 5):
        En    = topf.energie_n(n)
        off   = En / E_ref
        psi_n = topf.psi_n(x_box, n)
        ax2.plot(x_box, psi_n * 0.35 + off,
                 color=COLORS[n-1], lw=1.5, label=f'n={n}, E={En:.2f}')
        ax2.axhline(off, color=COLORS[n-1], lw=0.5, ls='--', alpha=0.5)
    ax2.axvline(-topf.L/2, color='white', lw=1.5)
    ax2.axvline( topf.L/2, color='white', lw=1.5)
    ax2.set_xlabel('x [norm.]'); ax2.set_ylabel('En/E4 + psi_n')
    ax2.legend(fontsize=7, facecolor='#111133', labelcolor='white')

    # ---- Panel 3: Harmonischer Oszillator -----------------------
    ax3 = fig.add_subplot(gs[0, 2])
    _style(ax3, '3. Harmonischer Oszillator\nEn=(n+1/2)hbar*omega  |  Hermite-WF')
    ho   = HarmonischerOszillator(omega=1.0)
    x_ho = np.linspace(-5, 5, 600)
    V_ho = ho.potential(x_ho)
    E_ref_ho = ho.energie_n(4)
    ax3.plot(x_ho, V_ho / E_ref_ho * 0.85,
             color='#7777aa', lw=1.5, ls='--', label='V(x)=1/2 m omega^2 x^2')
    for n in range(4):
        En  = ho.energie_n(n)
        off = En / E_ref_ho
        pn  = ho.psi_n(x_ho, n)
        ax3.plot(x_ho, pn * 0.35 + off,
                 color=COLORS[n], lw=1.5, label=f'n={n}, E={En:.2f} hbar*w')
        ax3.axhline(off, color=COLORS[n], lw=0.4, ls=':', alpha=0.6)
    ax3.set_ylim(-0.1, 1.1)
    ax3.set_xlabel('x/a'); ax3.set_ylabel('En/E4 + psi_n')
    ax3.legend(fontsize=7, facecolor='#111133', labelcolor='white')

    # ---- Panel 4: T(epsilon) QM vs. klassisch -------------------
    ax4 = fig.add_subplot(gs[1, 0])
    _style(ax4, '4. Tunnelbarriere: T(epsilon)\nQM vs. klassisch  (U0=3, L=1.5)')
    tb       = Tunnelbarriere(U0=3.0, L=1.5)
    eps_arr  = np.linspace(0.02, 8.0, 500)
    T_qm     = tb.scan_transmission(eps_arr)
    T_klass  = np.where(eps_arr > tb.U0, 1.0, 0.0)
    ax4.plot(eps_arr, T_klass, '--', color='#888888', lw=1.5, label='klassisch')
    ax4.plot(eps_arr, T_qm,    color=COLORS[0], lw=2.0,
             label=f'QM (U0={tb.U0}, L={tb.L})')
    ax4.axvline(tb.U0, color='#ff4444', lw=1.0, ls=':',
                alpha=0.8, label=f'U0={tb.U0}')
    ax4.fill_between(eps_arr, 0, T_qm, where=(eps_arr < tb.U0),
                     alpha=0.22, color='#00e5ff', label='Tunnelbereich')
    ax4.set_xlabel('Energie epsilon'); ax4.set_ylabel('T')
    ax4.set_ylim(-0.05, 1.12)
    ax4.legend(fontsize=7, facecolor='#111133', labelcolor='white')

    # ---- Panel 5: psi(x) durch Barriere -------------------------
    ax5 = fig.add_subplot(gs[1, 1])
    _style(ax5, '5. Wellenfunktion durch Barriere\nRe[psi(x)] fuer drei Energien')
    x_t = np.linspace(-4, 6, 600)
    cases = [(1.0, COLORS[0], 'e=1.0 (Tunneln)'),
             (3.0, COLORS[2], 'e=3.0 (Resonanz)'),
             (5.0, COLORS[1], 'e=5.0 (ueber Barriere)')]
    for eps_t, col, lbl in cases:
        psi_t = tb.wellenfunktion(x_t, eps_t)
        ax5.plot(x_t, psi_t, color=col, lw=1.5, label=lbl)
    ax5.fill_between([0, tb.L], [-1.5, -1.5], [1.5, 1.5],
                     alpha=0.15, color='#ffaa00',
                     label=f'Barriere [0, {tb.L}]')
    ax5.axvline(0,    color='#ffaa00', lw=0.8, ls=':')
    ax5.axvline(tb.L, color='#ffaa00', lw=0.8, ls=':')
    ax5.set_xlabel('x [norm.]'); ax5.set_ylabel('Re[psi(x)]')
    ax5.legend(fontsize=7, facecolor='#111133', labelcolor='white', loc='upper right')

    # ---- Panel 6: STM-Tunnelstrom I_T(d) ------------------------
    ax6 = fig.add_subplot(gs[1, 2])
    _style(ax6, '6. STM-Tunnelstrom I_T(d)\nI_T ~ eV * exp(-2*sqrt(2m*Phi)/hbar * d)')
