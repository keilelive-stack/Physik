class HarmonischerOszillator:
    """
    Harmonischer Oszillator (PDF S. 80):
    
    ```
    V(x) = (1/2) * m * omega^2 * x^2
    
    Eigenenergien (aequidistant! lineare n-Abhaengigkeit):
    E_n = (n + 1/2) * hbar * omega     n = 0, 1, 2, ...
    Nullpunktsenergie: E_0 = hbar*omega/2
    
    Eigenfunktionen (Hermite-Polynome H_n):
    psi_n(x) = pi^(-1/4) / sqrt(2^n * n! * a) * exp(-x^2/(2a^2)) * H_n(x/a)
    a = sqrt(hbar/(m*omega))   (charakteristische Laenge)
    
    Zeitabh. Loesung:
    Psi_n(x,t) = psi_n(x) * exp(-i * E_n * t / hbar)
    """
    def __init__(self, omega=1.0, hbar=HBAR_NORM, m=M_NORM):
        self.omega = float(omega)
        self.hbar  = float(hbar)
        self.m     = float(m)
        self.a     = np.sqrt(hbar / (m * omega))

    def energie_n(self, n):
        """E_n = (n + 1/2) * hbar * omega"""
        return (0.5 + n) * self.hbar * self.omega

    def potential(self, x):
        """V(x) = (1/2) * m * omega^2 * x^2"""
        return 0.5 * self.m * self.omega**2 * x**2

    def hermite(self, n, xi):
        """Hermite-Polynome H_n(xi) via Rekursionsformel"""
        if n == 0:
            return np.ones_like(xi, dtype=float)
        elif n == 1:
            return 2.0 * xi
        H_prev2 = np.ones_like(xi, dtype=float)
        H_prev1 = 2.0 * xi
        for k in range(2, n + 1):
            H_curr  = 2 * xi * H_prev1 - 2 * (k - 1) * H_prev2
            H_prev2 = H_prev1
            H_prev1 = H_curr
        return H_prev1

    def psi_n(self, x, n):
        """Normierte Eigenfunktion mit Hermite-Polynomen"""
        from math import factorial
        a    = self.a
        xi   = x / a
        Hn   = self.hermite(n, xi)
        norm = (np.pi**(-0.25)) / np.sqrt(2**n * factorial(n) * a)
        return norm * np.exp(-xi**2 / 2.0) * Hn

    def psi_zeitabh(self, x, t, n):
        """Psi_n(x,t) = psi_n(x) * exp(-i*E_n*t/hbar)"""
        En = self.energie_n(n)
        return self.psi_n(x, n) * np.exp(-1j * En * t / self.hbar)

    def superposition(self, x, t, n_max=4, koeff=None):
        """Superposition der ersten n_max Zustaende"""
        if koeff is None:
            koeff = np.ones(n_max) / np.sqrt(float(n_max))
        psi_total = np.zeros(len(x), dtype=complex)
        for i, n in enumerate(range(n_max)):
            psi_total += koeff[i] * self.psi_zeitabh(x, t, n)
        return psi_total

    def eigenniveaus(self, n_max=6):
        """[(n, E_n), ...]"""
        return [(n, self.energie_n(n)) for n in range(n_max)]

