# Bubble-Birth -> Resonanzknoten (3-Reihen-Zeitreihe)

# ================================================================

def time_evolution_plot(N=200, L=4.0, total_steps=600, snapshot_count=6):
    """
    Zeigt die Zeitentwicklung: Von der initialen Vakuumfluktuation
    ueber Bubble-Birth bis zur Bildung stabiler Resonanzknoten.
    
    ```
    Kosmischer Zyklus:
    Fluktuation -> Resonanzaufbau -> S_DM-Akkumulation -> Stabilisierung
    
    3 Reihen x snapshot_count Spalten:
    Reihe 1: Phasenfeld Phi
    Reihe 2: Geometrie g_eff
    Reihe 3: S_DM Dunkles Archiv
    """
    print("=" * 60)
    print("  ZEITENTWICKLUNG: Bubble-Birth -> Resonanzknoten")
    print("  Kosmischer Zyklus der Phasendynamik")
    print("=" * 60)

    engine = QuantenOrchesterEngine(N=N, L=L, dt=0.005)
    engine.init_bubble(sigma=1.5, spin_mode='mixed')

    snapshots_at = np.linspace(0, total_steps - 1, snapshot_count, dtype=int)
    snapshots, sdm_snapshots, geom_snapshots, times = [], [], [], []

    for step in range(total_steps):
        engine.step()
        if step in snapshots_at:
            snapshots.append(engine.Phi.copy())
            sdm_snapshots.append(engine.S_DM.copy())
            geom_snapshots.append(engine.compute_geometry().copy())
            times.append(engine.time)

    fig, axes = plt.subplots(3, snapshot_count, figsize=(20, 10),
                             facecolor='#0a0a1a')
    fig.suptitle('Kosmischer Zyklus: Fluktuation -> Resonanzknoten -> Dunkles Archiv',
                 fontsize=15, color='#fbbf24', fontweight='bold', y=0.98)

    ext = [-L, L, -L, L]
    row_labels = ['Phasenfeld Phi\n"Partitur"',
                  'Geometrie g_eff\n"Emergente Raumzeit"',
                  'Dunkles Archiv S_DM\n"Stumme Resonatoren"']

    for col in range(snapshot_count):
        ax = axes[0, col]
        ax.set_facecolor('#0a0a1a')
        ax.imshow(snapshots[col], extent=ext, origin='lower',
                  cmap=CMAP_RESONANZ, vmin=-1.5, vmax=1.5)
        ax.set_title(f't = {times[col]:.2f}', color='white', fontsize=9)
        ax.tick_params(colors='#666', labelsize=6)

        ax = axes[1, col]
        ax.set_facecolor('#0a0a1a')
        ax.imshow(np.log1p(geom_snapshots[col]), extent=ext, origin='lower',
                  cmap=CMAP_CHOR)
        ax.tick_params(colors='#666', labelsize=6)

        ax = axes[2, col]
        ax.set_facecolor('#0a0a1a')
        ax.imshow(np.log1p(sdm_snapshots[col] * 100), extent=ext, origin='lower',
                  cmap=CMAP_SDM)
        ax.tick_params(colors='#666', labelsize=6)

    for row, label in enumerate(row_labels):
        axes[row, 0].set_ylabel(label, color='white', fontsize=9)

    plt.tight_layout(rect=[0, 0, 1, 0.95])
    return fig, engine

