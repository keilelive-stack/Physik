                 (6.0, COLORS[2], 'Phi=6.0 eV')]
    for phi_ev, col, lbl in stm_cases:
        I_t = Tunnelbarriere.stm_tunnelstrom(d_nm, eV=4.0, Phi_eV=phi_ev)
        ax6.semilogy(d_nm * 1e9, I_t, color=col, lw=2.0, label=lbl)
    ax6.axvline(0.3, color='#ffaa00', lw=1.0, ls=':',
                alpha=0.7, label='Dd=0.3nm -> I*1000')
    ax6.set_xlabel('Abstand d [nm]'); ax6.set_ylabel('I_T (norm., log)')
