# 13. ERHALTUNGSGESETZ-VISUALISIERUNG

# DeltaV + R = const  (Vakuumdruck + Resonanz)

# ================================================================

def conservation_law_plot(engine):
    """
    Zeigt das Erhaltungsgesetz der resonanten Raumzeit-Architektur:
    
    ```
    DeltaV + R = const
    
    Vakuumdruck (DeltaV) + gebundene Resonanz (R) = Gesamtenergie
    Materie existiert, um den Vakuumdruck zu stabilisieren.
    
    4 Panels:
    1. R-S-H Felder (Zeitreihe)
    2. Stabilitaetsquotient Q = R/(S+eps)
    3. Energie + S_DM (DeltaV sinkt wo R waechst)
    4. Eigenzeit + Blasenwachstum
    """
    if not engine.history['time']:
        print("Keine History-Daten. Fuehre erst die Simulation durch.")
        return None

    fig, axes = plt.subplots(2, 2, figsize=(14, 10), facecolor='#0a0a1a')
    fig.suptitle('Erhaltungsgesetz: DeltaV + R = const\n'
                 '"Materie existiert, um den Vakuumdruck zu stabilisieren"',
                 fontsize=14, color='#fbbf24', fontweight='bold')

    t     = np.array(engine.history['time'])
    R_h   = np.array(engine.history['R'])
    S_h   = np.array(engine.history['S'])
    H_h   = np.array(engine.history['H'])
    E_h   = np.array(engine.history['energy'])
    Q_h   = np.array(engine.history['Q'])
    sdm_h = np.array(engine.history['sdm_total'])
    ez_h  = np.array(engine.history['eigenzeit'])
    br_h  = np.array(engine.history['bubble_radius'])

    for ax in axes.flat:
        ax.set_facecolor('#0a0a1a')
        ax.tick_params(colors='#888', labelsize=8)
        ax.grid(True, alpha=0.15, color='#333')

    # Panel 1: R, S, H
    ax = axes[0, 0]
    ax.fill_between(t, 0, R_h, alpha=0.3, color='#2dd4bf', label='R (Resonanz)')
    ax.fill_between(t, 0, S_h, alpha=0.3, color='#f43f5e', label='S (Stoerung)')
    ax.plot(t, H_h, color='#a78bfa', lw=2, label='H (Harmonie)')
    ax.set_title('R-S-H Felder', color='white', fontsize=10)
    ax.legend(fontsize=8, facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')

    # Panel 2: Q und Schwellenwert
    ax = axes[0, 1]
    ax.plot(t, Q_h, color='#fbbf24', lw=2)
    ax.axhline(1.0, color='#f43f5e', linestyle='--', alpha=0.7, label='Q=1 (kritisch)')
    ax.axhline(engine.delta_crit, color='#2dd4bf', linestyle=':', alpha=0.7,
               label=f'Delta_crit={engine.delta_crit}')
    ax.fill_between(t, 1.0, Q_h, where=Q_h > 1, alpha=0.2, color='#2dd4bf')
    ax.fill_between(t, Q_h, 1.0, where=Q_h < 1, alpha=0.2, color='#f43f5e')
    ax.set_title('Stabilitaetsquotient Q = R/(S+eps)', color='white', fontsize=10)
    ax.legend(fontsize=8, facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')

    # Panel 3: Energie + S_DM (Erhaltungsgesetz)
    ax  = axes[1, 0]
    ax.plot(t, E_h, color='#ff6b6b', lw=1.5, label='Gesamtenergie')
    ax2 = ax.twinx()
    ax2.plot(t, sdm_h, color='#9933ff', lw=1.5, label='Summe(S_DM)')
    ax.set_title('Energie & Dunkles Archiv\n"DeltaV sinkt wo R waechst"',
                 color='white', fontsize=10)
    ax.legend(fontsize=8, loc='upper left',  facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')
    ax2.legend(fontsize=8, loc='upper right', facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')
    ax2.tick_params(colors='#888', labelsize=8)

    # Panel 4: Eigenzeit + Bubble-Radius
    ax  = axes[1, 1]
    ax.plot(t, ez_h, color='#fbbf24', lw=2, label='dtau/dt (Eigenzeit)')
    ax2 = ax.twinx()
    ax2.plot(t, br_h, color='#2dd4bf', lw=1.5, alpha=0.7, label='R_bubble')
    ax.set_title('Eigenzeit & Blasenwachstum\n"Kohaerenz beschleunigt die Zeit"',
                 color='white', fontsize=10)
    ax.legend(fontsize=8, loc='upper left',  facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')
    ax2.legend(fontsize=8, loc='upper right', facecolor='#1a1a2e', edgecolor='#333', labelcolor='white')
    ax2.tick_params(colors='#888', labelsize=8)

    plt.tight_layout(rect=[0, 0, 1, 0.92])
    return fig

