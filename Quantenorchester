class UnendlicherPotentialtopf:
    """
    Particle-in-a-box (PDF S. 76-78):
    
    ```
    U(x) = 0   fuer -L/2 < x < L/2
    inf  sonst  => psi verschwindet an Raendern
    
    Eigenfunktionen (normiert sqrt(2/L)):
    psi_n(x) = sqrt(2/L) * cos(n*pi*x/L)   n = 1,3,5,...  (ungerade n, gerade Paritaet)
    psi_n(x) = sqrt(2/L) * sin(n*pi*x/L)   n = 2,4,6,...  (gerade n, ungerade Paritaet)
    
    Eigenenergien (quadratische n-Abhaengigkeit):
    E_n = hbar^2 * n^2 * pi^2 / (2 * m * L^2)
    epsilon_n = n^2 * pi^2 / L^2   (normiert)
    
    Vollstaendige Loesung:
    Psi_n(x,t) = psi_n(x) * exp(-i * E_n * t / hbar)
    
    Superposition:
    Psi(x,t) = sum_n c_n * psi_n(x) * exp(-i*E_n*t/hbar)
    """
    def __init__(self, L=4.0, hbar=HBAR_NORM, m=M_NORM):
        self.L    = float(L)
        self.hbar = float(hbar)
        self.m    = float(m)

    def epsilon_n(self, n):
        """Normierte Eigenenergie: epsilon_n = n^2 * pi^2 / L^2"""
        return (n * np.pi / self.L)**2

    def energie_n(self, n):
        """Eigenenergie: E_n = hbar^2 * n^2 * pi^2 / (2 * m * L^2)"""
        return (self.hbar**2 * (n * np.pi)**2) / (2.0 * self.m * self.L**2)

    def psi_n(self, x, n):
        """Normierte Eigenfunktion im Topf [-L/2, L/2]"""
        inTopf = (np.abs(x) <= self.L / 2.0)
        norm   = np.sqrt(2.0 / self.L)
        if n % 2 == 1:   # ungerade n -> gerade Paritaet -> cos
            psi = norm * np.cos(n * np.pi * x / self.L)
        else:             # gerade n -> ungerade Paritaet -> sin
            psi = norm * np.sin(n * np.pi * x / self.L)
        return np.where(inTopf, psi, 0.0)

    def psi_zeitabh(self, x, t, n):
        """Zeitabhaengige Loesung: Psi_n(x,t) = psi_n(x) * exp(-i*E_n*t/hbar)"""
        En    = self.energie_n(n)
        psi0  = self.psi_n(x, n)
        phase = np.exp(-1j * En * t / self.hbar)
        return psi0 * phase

    def superposition(self, x, t, n_max=4, koeff=None):
        """Superposition der ersten n_max Zustaende mit Koeffizienten koeff"""
        if koeff is None:
            koeff = np.ones(n_max) / np.sqrt(float(n_max))
        psi_total = np.zeros(len(x), dtype=complex)
        for i, n in enumerate(range(1, n_max + 1)):
            psi_total += koeff[i] * self.psi_zeitabh(x, t, n)
        return psi_total

    def eigenniveaus(self, n_max=6):
        """Liste: [(n, E_n), ...]"""
        return [(n, self.energie_n(n)) for n in range(1, n_max + 1)]

