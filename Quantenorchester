class Tunnelbarriere:
    """
    Rechteck-Potentialwall / Tunneleffekt (PDF S. 85-90):
    
    ```
    U(x) = U0   fuer 0 < x < L
    0    sonst
    
    Transmissionskoeffizient (aus Stetigkeitsbedingungen):
    
    Fall epsilon > U0 (klassisch erlaubt, noch Resonanzen):
    k   = sqrt(epsilon - U0)
    T   = 4*epsilon*(epsilon-U0) / [4*epsilon*(epsilon-U0) + U0^2 * sin^2(k*L)]
    
    Fall epsilon < U0 (klassisch verboten -> Tunneleffekt!):
    kappa = sqrt(U0 - epsilon)
    T     = 4*epsilon*(U0-epsilon) / [4*epsilon*(U0-epsilon) + U0^2 * sinh^2(kappa*L)]
    T > 0: Das Teilchen tunnelt durch die Barriere! (QM vs klassisch T=0)
    
    STM-Tunnelstrom (S. 90):
    I_T(d) ~ eV * exp(-2 * sqrt(2*m*Phi) / hbar * d)
    Phi = Austrittsarbeit (eV), d = Spitzen-Proben-Abstand (m)
    -> Faktor 1000 Stromerhohung bei Abstandsaenderung von nur 0.3 nm!
    """
    def __init__(self, U0=3.0, L=1.5, hbar=HBAR_NORM, m=M_NORM):
        self.U0   = float(U0)
        self.L    = float(L)
        self.hbar = float(hbar)
        self.m    = float(m)

    def transmission(self, epsilon):
        """T(epsilon) - skalarer Transmissionskoeffizient"""
        U0, L = self.U0, self.L
        if epsilon <= 1e-12:
            return 0.0
        if epsilon > U0:
            k     = np.sqrt(epsilon - U0)
            num   = 4.0 * epsilon * (epsilon - U0)
            denom = num + U0**2 * np.sin(k * L)**2
            return num / denom if denom > 1e-30 else 1.0
        else:
            kappa = np.sqrt(U0 - epsilon)
            num   = 4.0 * epsilon * (U0 - epsilon)
            denom = num + U0**2 * np.sinh(kappa * L)**2
            return num / denom if denom > 1e-30 else 0.0

    def scan_transmission(self, epsilon_arr):
        """T(epsilon) Vektorisiert ueber epsilon_arr"""
        return np.array([self.transmission(e) for e in epsilon_arr])

    def wellenfunktion(self, x_arr, epsilon):
        """
        Realteil von psi(x) durch die Barriere:
          Bereich I  (x<0): einlaufend + reflektiert
          Bereich II (0<=x<=L): exponentiell/oszillatorisch
          Bereich III (x>L): transmittiert
        """
        U0, L = self.U0, self.L
        T_val = self.transmission(epsilon)
        k1    = np.sqrt(np.maximum(epsilon, 1e-12))
        psi   = np.zeros_like(x_arr, dtype=float)
        for i, x in enumerate(x_arr):
            if x < 0:
                psi[i] = np.cos(k1 * x)
            elif x <= L:
                if epsilon < U0:
                    kappa = np.sqrt(U0 - epsilon)
                    psi[i] = np.exp(-kappa * x)
                else:
                    k = np.sqrt(epsilon - U0)
                    psi[i] = np.cos(k * x)
            else:
                psi[i] = np.sqrt(max(T_val, 0.0)) * np.cos(k1 * (x - L))
        return psi


def stm_tunnelstrom(d_arr, eV=4.0, Phi_eV=4.5,
                    hbar_si=1.054571817e-34,
                    m_e_si=9.1093837015e-31,
                    e_si=1.602176634e-19):
    """
    STM-Tunnelstrom I_T(d) in SI-Einheiten (normiert).

    d_arr   : Abstands-Array in Metern
    eV      : Spannung in eV
    Phi_eV  : Austrittsarbeit in eV (typisch 4-5 eV fuer Metalle)

    Rueckgabe: normiertes I_T(d)/I_T(d[0])

    I_T(d) ~ eV * exp(-2*sqrt(2*m*Phi)/hbar * d)
    """
    Phi_J  = Phi_eV * e_si
    decay  = 2.0 * np.sqrt(2.0 * m_e_si * Phi_J) / hbar_si
    I_raw  = eV * np.exp(-decay * d_arr)
    return I_raw / I_raw[0]

