def patch_engine(engine):
    """
    Erweitert eine bestehende QuantenOrchesterEngine um alle
    Paper-Ready Komponenten.

    Verwendung:
        engine = QuantenOrchesterEngine(N=200, L=4.0, dt=0.005)
        engine.init_bubble(sigma=1.5)
        patch_engine(engine)       # <- einmalig
        for _ in range(500):
            engine.step()
            metrics = compute_paper_metrics(engine)   # <- jeder Step
        plot_paper_ready_dashboard(engine)
    """
    engine._bridge_explicit = BrueckenformelExplizit()
    engine._sdm_obs         = SDMObservables()
    engine._ciq_grav        = CIQGravitation()

    engine.sdm_obs_history = {
        'sigma_v_eff': [], 'f_dm': [], 'sdm_mean': [], 'H': [],
        'rho_tot': [], 'bounce_ratio': [], 'Delta': [], 'S_grav': [], 'P_grav': []
    }
    engine.grav_history = {
        'H': [], 'H2': [], 'rho_tot': [], 'bounce_ratio': [],
        'Delta': [], 'S_grav': [], 'P_grav': [],
        'Phi_G_max': [], 'Phi_G_mean': []
    }

    # Brückenformel-Parameter aus BRUECKENFORMEL_PARAMETER lesen (falls vorhanden)
    bp = globals().get('BRUECKENFORMEL_PARAMETER', {})
    engine._bridge_explicit.alpha = bp.get('alpha_br', 0.05)
    engine._bridge_explicit.beta  = bp.get('beta_br',  0.02)
    engine._bridge_explicit.gamma = bp.get('gamma_br', 0.03)
    engine._bridge_explicit.delta = bp.get('delta_br', 0.10)
    engine._bridge_explicit.zeta  = bp.get('zeta_br',  0.08)

    print("  [CIQ Paper-Ready Patch v1.0] Engine erweitert:")
    print("    ✓ BrueckenformelExplizit  (Einheit, Ableitung, Interpretation)")
    print("    ✓ SDMObservables          (σ_v, f_DM, P_SDM(k), v_rot)")
    print("    ✓ CIQGravitation          (Poisson ∇²Φ_G, Friedmann H², Δ→S→P)")
    return engine


def apply_full_patch(engine):
    """Alias für patch_engine(engine). Rückgabe: gepatchte Engine."""
    return patch_engine(engine)


