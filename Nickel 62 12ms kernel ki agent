      "source": [
        "import torch\n",
        "import torch.nn as nn\n",
        "import time\n",
        "\n",
        "class Conv1DModel(nn.Module):\n",
        "    def __init__(self, in_channels, out_channels, kernel_size):\n",
        "        super().__init__()\n",
        "        self.conv = nn.Conv1d(in_channels, out_channels, kernel_size=kernel_size)\n",
        "        self.fc = nn.Linear(out_channels, 1)\n",
        "\n",
        "    def forward(self, x):\n",
        "        x = self.conv(x)\n",
        "        x = torch.mean(x, dim=-1) # Global average pooling\n",
        "        x = self.fc(x)\n",
        "        return x\n",
        "\n",
        "def get_12ms_kernel_size(fs=50000):\n",
        "    # 12 ms = 0.012 seconds\n",
        "    return int(0.012 * fs)\n",
        "\n",
        "def benchmark_ms(model, x, iters=200, warmup=30):\n",
        "    model.eval()\n",
        "    device = x.device\n",
        "\n",
        "    # Warm-up\n",
        "    with torch.no_grad():\n",
        "        for _ in range(warmup):\n",
        "            _ = model(x)\n",
        "\n",
        "    if device.type == 'cuda':\n",
        "        torch.cuda.synchronize()\n",
        "\n",
        "    start = time.perf_counter()\n",
        "    with torch.no_grad():\n",
        "        for _ in range(iters):\n",
        "            _ = model(x)\n",
        "\n",
        "    if device.type == 'cuda':\n",
        "        torch.cuda.synchronize()\n",
        "\n",
        "    end = time.perf_counter()\n",
        "    avg_time_ms = ((end - start) / iters) * 1000\n",
        "    return avg_time_ms\n",
        "\n",
        "# Setup testing parameters\n",
        "fs = 50000 # 50 kHz\n",
        "kernel_size = get_12ms_kernel_size(fs)\n",
        "print(f\"Calculated Kernel Size for 12 ms at {fs} Hz: {kernel_size}\")\n",
        "\n",
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "model = Conv1DModel(in_channels=1, out_channels=16, kernel_size=kernel_size).to(device)\n",
        "\n",
        "# Dummy input: (batch_size, channels, sequence_length)\n",
        "# Example: 100 ms of data = 5000 samples\n",
        "seq_len = int(0.1 * fs)\n",
        "dummy_input = torch.randn(1, 1, seq_len).to(device)\n",
        "\n",
        "avg_ms = benchmark_ms(model, dummy_input)\n",
        "print(f\"Average Inference Time over 200 iterations: {avg_ms:.3f} ms\")\n",
        "if avg_ms <= 12.0:\n",
        "    print(\"Latency benchmark passed (<= 12 ms)\")\n",
        "else:\n",
        "    print(\"Latency benchmark failed (> 12 ms)\")"
