      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Create the phase-space scatter plot\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.scatter(df_telemetry['B'], df_telemetry['z'], c=df_telemetry['cycle'], cmap='viridis', alpha=0.8)\n",
        "plt.colorbar(label='Cycle Index')\n",
        "\n",
        "# Add lines for stability limit and target attractor\n",
        "plt.axvline(0, color='red', linestyle='--', label='Stability Limit (B=0)')\n",
        "plt.axhline(0.732, color='green', linestyle='--', label='Target Attractor (z=0.732)')\n",
        "\n",
        "# Add labels and title\n",
        "plt.title('Phase Space Dynamics: Continuity z(t) vs Stability Balance B(t)')\n",
