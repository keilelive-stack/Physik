            "```python\n",
            "from dataclasses import dataclass\n",
            "from typing import Dict, Any, Optional\n",
            "\n",
            "@dataclass\n",
            "class CalibrationState:\n",
            "    k_factor: float\n",
            "    k_factor_u: float   # Standardunsicherheit\n",
            "    ref_id: str\n",
            "    timestamp: str\n",
            "    notes: str = \"\"\n",
            "\n",
            "class Ni62Agent:\n",
            "    def __init__(self, model, device=\"cpu\"):\n",
            "        self.model = model\n",
            "        self.device = device\n",
            "        self.cal_state: Optional[CalibrationState] = None\n",
            "\n",
            "    def preprocess(self, signal, axis=None, meta: Optional[Dict[str, Any]]=None):\n",
            "        # 1) baseline removal (placeholder)\n",
            "        # 2) normalize\n",
            "        # 3) windowing for 12ms receptive field\n",
            "        return signal\n",
            "\n",
            "    def predict_raw(self, x):\n",
            "        # returns predicted log_ratio and log_var (or ratio)\n",
            "        self.model.eval()\n",
            "        with torch.no_grad():\n",
            "            y = self.model(x)\n",
            "        return y\n",
            "\n",
            "    def calibrate_k_factor(self, measured_ratio: float, certified_ratio: float, u_cert: float):\n",
            "        # Simple K = R_cert / R_meas; keep uncertainty for propagation\n",
            "        k = certified_ratio / measured_ratio\n",
            "        # Minimal: u(K) from u_cert only (extend with u_meas as needed)\n",
            "        self.cal_state = CalibrationState(k_factor=k, k_factor_u=u_cert/measured_ratio,\n",
            "                                          ref_id=\"SRM986\", timestamp=\"ISO-8601\")\n",
            "        return self.cal_state\n",
            "\n",
            "    def predict_calibrated(self, measured_ratio: float):\n",
            "        if self.cal_state is None:\n",
            "            raise RuntimeError(\"CalibrationState missing. Run calibrate_k_factor() first.\")\n",
            "        return self.cal_state.k_factor * measured_ratio\n",
            "```\n",
