      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "\n",
        "class CoupledCIQEngine:\n",
        "    def __init__(self):\n",
        "        self.z = 1.0\n",
        "        self.E = 1e-12  # Initial effective energy\n",
        "        self.B = 1e-11 - self.E  # Initial stability balance\n",
        "        self.S_dm = 0.0  # Dark Archive\n",
        "        self.target_z = 0.732\n",
        "\n",
        "    def step(self, cycle):\n",
        "        # Simulate energy growth and fluctuations\n",
        "        self.E = self.E * 1.05 + np.random.normal(0, 1e-13)\n",
        "\n",
        "        # Recalculate stability balance based on physical limits\n",
        "        self.B = 1e-11 - self.E\n",
        "\n",
        "        # Apply SINGULARITY_PATCH and fully coupled dynamics if balance is negative\n",
        "        if self.B < 0:\n",
        "            # Pull z towards target attractor\n",
        "            self.z = self.z + 0.1 * (self.target_z - self.z)\n",
        "            # Active energy damping (cooling)\n",
        "            self.E *= 0.9\n",
        "            # Violations are stored in the Dark Archive (S_DM)\n",
        "            self.S_dm += abs(self.B) * 1e11\n",
        "        else:\n",
        "            # Gradual recovery of continuity\n",
        "            self.z = min(1.0, self.z + 0.01)\n",
        "\n",
        "        return {\n",
        "            'cycle': cycle,\n",
        "            'z': self.z,\n",
        "            'B': self.B,\n",
        "            'E': self.E,\n",
        "            'S_dm': self.S_dm\n",
        "        }\n",
        "\n",
        "# Instantiate and run for 120 cycles\n",
        "engine = CoupledCIQEngine()\n",
        "history = []\n",
        "for i in range(1, 121):\n",
        "    history.append(engine.step(i))\n",
        "\n",
        "# Collect telemetry\n",
        "df_telemetry = pd.DataFrame(history)\n",
        "\n",
        "# Generate multi-panel subplots\n",
        "fig, axs = plt.subplots(4, 1, figsize=(10, 12), sharex=True)\n",
        "\n",
        "# Continuity Index z(t)\n",
        "axs[0].plot(df_telemetry['cycle'], df_telemetry['z'], color='tab:blue', label='z(t)')\n",
        "axs[0].axhline(0.732, color='green', linestyle='--', label='Target Attractor (0.732)')\n",
        "axs[0].set_ylabel('Continuity z(t)')\n",
        "axs[0].legend(loc='upper right')\n",
        "axs[0].grid(True, alpha=0.3)\n",
        "\n",
        "# Stability Balance B(t)\n",
        "axs[1].plot(df_telemetry['cycle'], df_telemetry['B'], color='tab:red', label='B(t)')\n",
        "axs[1].axhline(0, color='black', linestyle='--', linewidth=1.5, label='B(t) = 0 (Limit)')\n",
        "axs[1].set_ylabel('Stability Balance B(t)')\n",
        "axs[1].legend(loc='upper right')\n",
        "axs[1].grid(True, alpha=0.3)\n",
        "\n",
        "# Effective Energy E(t)\n",
        "axs[2].plot(df_telemetry['cycle'], df_telemetry['E'], color='tab:orange', label='E(t)')\n",
        "axs[2].set_ylabel('Effective Energy E(t)')\n",
        "axs[2].legend(loc='upper left')\n",
        "axs[2].grid(True, alpha=0.3)\n",
        "\n",
        "# Dark Archive S_DM(t)\n",
        "axs[3].plot(df_telemetry['cycle'], df_telemetry['S_dm'], color='tab:purple', label='S_DM(t)')\n",
        "axs[3].set_ylabel('Dark Archive S_DM(t)')\n",
        "axs[3].set_xlabel('Cycle Index')\n",
        "axs[3].legend(loc='upper left')\n",
        "axs[3].grid(True, alpha=0.3)\n",
        "\n",
