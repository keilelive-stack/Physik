        "from dataclasses import dataclass\n",
        "from typing import Optional, Dict, Any\n",
        "import torch\n",
        "import os\n",
        "import time\n",
        "\n",
        "@dataclass\n",
        "class CalibrationState:\n",
        "    k_factor: float\n",
        "    k_factor_u: float\n",
        "    ref_id: str\n",
        "    timestamp: str\n",
        "    notes: str = ''\n",
        "\n",
        "class Ni62Agent:\n",
        "    def __init__(self, model, device: str = 'cpu'):\n",
        "        self.model = model\n",
        "        self.device = device\n",
        "        self.cal_state: Optional[CalibrationState] = None\n",
        "\n",
        "    def preprocess(self, signal, axis=None, meta: Optional[Dict] = None):\n",
        "        return signal\n",
        "\n",
        "    def predict_raw(self, signal):\n",
        "        self.model.eval()\n",
        "        with torch.no_grad():\n",
        "            return self.model(signal)\n",
        "\n",
        "    def calibrate_k_factor(self, measured_ratio: float, measured_u: float, certified_ratio: float, certified_u: float, ref_id: str):\n",
        "        k_factor = certified_ratio / measured_ratio\n",
        "        # GUM uncertainty propagation (simplified relative uncertainty addition)\n",
        "        rel_u_meas = measured_u / measured_ratio\n",
        "        rel_u_cert = certified_u / certified_ratio\n",
        "        k_factor_u = k_factor * ((rel_u_meas**2 + rel_u_cert**2)**0.5)\n",
        "\n",
        "        self.cal_state = CalibrationState(\n",
        "            k_factor=k_factor,\n",
        "            k_factor_u=k_factor_u,\n",
        "            ref_id=ref_id,\n",
        "            timestamp=time.strftime('%Y-%m-%d %H:%M:%S')\n",
        "        )\n",
        "        return self.cal_state\n",
        "\n",
        "    def predict_calibrated(self, measured_ratio: float, measured_u: float):\n",
        "        if not self.cal_state:\n",
        "            raise RuntimeError('Calibration state is None. Run calibrate_k_factor first.')\n",
        "\n",
        "        calibrated_ratio = measured_ratio * self.cal_state.k_factor\n",
        "        # Simplified uncertainty propagation\n",
        "        rel_u_meas = measured_u / measured_ratio\n",
        "        rel_u_k = self.cal_state.k_factor_u / self.cal_state.k_factor\n",
        "        calibrated_u = calibrated_ratio * ((rel_u_meas**2 + rel_u_k**2)**0.5)\n",
        "\n",
        "        return calibrated_ratio, calibrated_u\n",
