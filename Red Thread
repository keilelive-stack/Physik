# Helper function to calculate MSE, AIC, and BIC
def evaluate_model(y_true, y_pred, k, n):
    mse = np.mean((y_true - y_pred)**2)
    # AIC = n * log(MSE) + 2 * k
    aic = n * np.log(mse) + 2 * k
    # BIC = n * log(MSE) + k * np.log(n)
    bic = n * np.log(mse) + k * np.log(n)
    return mse, aic, bic

