import numpy as np

class RedThreadEngine:
    def __init__(self, nodes_dict, fractal_cfg):
        # ODE Parameters from documentation
        self.Delta = fractal_cfg['parameters']['stability_window']
        self.tau = fractal_cfg['parameters']['eeg_tau']
        self.k = 0.15
        self.mu = 0.10
        self.gamma = 0.25
        self.lambda_param = 0.5
        self.beta = 0.12

        self.ciq_nodes = nodes_dict
        self.fractal_config = fractal_cfg

        # Initial States: [z(ZIS), m(Möbius), q(DM), a(Matter), b(BH), c(CIQ), e(Energy)]
        self.X0 = [1.0, 0.01, 0.05, 0.0, 0.0, 0.5, 1.0]

    def ode_system(self, t, X):
        z, m, q, a, b, c, e = X
        # ODE Logic
        dzdt = -0.05 * m * (1 - z) - 0.01 * q
        dmdt = 0.2 * (1 - z) * (self.Delta - abs(self.Delta - c))
        dqdt = self.mu * m * (1 - c) + 0.05 * q * (1 - q)
        dadt = self.k * m * q * c - 0.03 * a
        dbdt = self.gamma * (a**2) * (1 - c) - 0.1 * b
        dcdt = self.lambda_param * (self.Delta - abs(q - a)) - 0.2 * b
        dedt = self.beta * (q + a) - 0.05 * e + 0.3 * b
        return [dzdt, dmdt, dqdt, dadt, dbdt, dcdt, dedt]

