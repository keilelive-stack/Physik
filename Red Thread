import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

class GoldilocksAuditor:
    def __init__(self):
        self.rho_total = 1e25  # Lokale Dichte am Bounce
        self.rho_limit = 1e15  # BBN/CMB Grenze
        self.t_bbn = 1.0       # BBN Referenzzeit (1s)
        self.target_eta = 1e-3 # Deine Ziel-Asymmetrie

    def run_scan(self):
        # Scan-Bereich: t_bounce (log) und delta_0 (log)
        t_samples = np.logspace(-20, -5, 100)
        delta_samples = np.logspace(-10, -1, 100)

        T, D0 = np.meshgrid(t_samples, delta_samples)

        # 1. Physikalische Konsistenz (Füllfaktor-Logik)
        # Dilution D = (1 / t_bounce)^2
        D = (self.t_bbn / T)**2
        # f_req = (rho_limit * D) / rho_total
        f_req = (self.rho_limit * D) / self.rho_total
        # Ein Score: 1 wenn global erlaubt (f_req >= 1), sinkend wenn f_req < 1
        physics_score = np.clip(np.log10(f_req + 1e-20) / 10, 0, 1)

        # 2. Habitabilität (Asymmetrie-Erfolg)
        # Wie nah kommt eta_f (delta_0) an das Ziel 10^-3?
        eta_f = D0
        habitability_score = np.exp(-abs(np.log10(eta_f) - np.log10(self.target_eta))**2)

        # 3. Goldlöckchen-Index (Kombination)
        goldilocks_index = physics_score * habitability_score

        # Visualisierung
        plt.figure(figsize=(12, 8))
        cp = plt.contourf(T, D0, goldilocks_index, levels=20, cmap='magma')
        plt.colorbar(cp, label='Goldlöckchen-Index (Erfolgs-Wahrscheinlichkeit)')

        plt.xscale('log')
        plt.yscale('log')
        plt.xlabel('Zeitpunkt des Bounces t_bounce (s)')
        plt.ylabel('Symmetrie-Bias delta_0 (Materie/Antimatter)')
        plt.title('Agent XΩ: Suche nach der Goldlöckchen-Zone (Audit Sept 2025)')

        # Markiere den aktuellen Audit-Punkt
        plt.scatter([1e-12], [1e-3], color='cyan', s=100, label='Aktueller Audit-Punkt', edgecolors='white')

        plt.legend()
        plt.grid(True, which="both", ls="-", alpha=0.2)
        plt.savefig('goldilocks_heatmap.png')
        plt.show()
        return "Heatmap generiert."

# --- EXECUTION ---
