            # Resonanz-Dämpfung am Eisen-Anker
            resonance_gain = np.exp(-abs(u - self.u_res) * (self.zeta / 1000.0))
            tension *= (1.0 - 0.95 * resonance_gain) # 95% Dämpfung am Peak

        return tension * (1.0 - ci)

