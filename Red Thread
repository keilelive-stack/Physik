class BounceEngine:
    """Simuliert die Wiedergeburt von Struktur durch Zeta-Kondensation."""
    def __init__(self):
        # Parameter: Kosmos-Regime (n=4.0)
        self.A, self.B, self.n = 0.584, 1.034, 4.0
        self.zeta = 3840.0
        self.u_res = 0.725 # Eisen-Anker (Parität)

    def run_bounce_cycle(self, u_max=2.0):
        u_vals = np.linspace(0, u_max, 500)
        results = []

        for u in u_vals:
            # 1. Zerfall der ALTEN Struktur (Welle)
            ci_old = np.exp(-self.A * u - self.B * (u**self.n))

            # 2. Emission der Strahlung (Teilchen)
            # Die Information 'parkt' im Strahlungsfeld
            i_radiation = 1.0 - ci_old

            # 3. DER BOUNCE: Re-Kondensation der NEUEN Struktur
            # Sobald die Strahlungsdichte maximal ist und u den
            # kritischen Wert überschreitet, beginnt die neue Welle zu wachsen.
            # Der Zeta-Schild wirkt als 'magnetischer Attraktor' für die Information.

            bounce_trigger = 1.1 # Der Punkt des 'Urknalls' oder Neustarts
            new_growth_rate = 0
            if u > bounce_trigger:
                # Kondensations-Funktion: Die Strahlung wird wieder zu Welle
                # Gesteuert durch die Resonanzkraft Zeta
                condensation_efficiency = 1.0 - np.exp(-(u - bounce_trigger) * (self.zeta / 500))
                new_growth_rate = i_radiation * condensation_efficiency
                # Die freie Strahlung sinkt entsprechend
                i_radiation -= new_growth_rate

            # Bilanz-Check: I_Old + I_Radiation + I_New = 1.0
            i_total = ci_old + i_radiation + new_growth_rate

            results.append({
                "u": u,
                "Welle_Alt": ci_old,
                "Strahlung": i_radiation,
                "Welle_Neu": new_growth_rate,
                "Gesamt": i_total
            })

        return pd.DataFrame(results)

