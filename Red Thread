import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

# ==============================================================================
# 1. DIE KALIBRIERUNGS-DATEN (Audit-Ergebnisse vom Sept 2025)
# ==============================================================================
AUDIT_RESULTS = {
    "EEG_Kollaps_Neu": {
        "A": 2.1063,
        "B": 3.5411,
        "n": 1.965,
        "desc": "Real-Data Fit (EEG/Propofol)"
    },
    "Kosmos_Reset_Neu": {
        "A": 0.584,
        "B": 1.034,
        "n": 4.0,
        "desc": "Hubble-Tension / DESI fσ8 Audit"
    },
    "Zeta_Knoten": 3840.0,
    "Eisen_Anker": 0.725
}

# ==============================================================================
# 2. DIE REKALIBRIERUNGS-ENGINE
# ==============================================================================
class CIQ_Calibrator:
    def __init__(self, old_params=None):
        # Falls keine alten Daten übergeben werden, nutzen wir Standard-Platzhalter
        self.current_params = old_params if old_params else {"A": 0.5, "B": 0.05, "n": 2.0}
        self.is_calibrated = False

    def apply_audit_patch(self, regime_key):
        """Ersetzt alte Daten durch die neuen Audit-Ergebnisse."""
        print(f"--- STARTE REKALIBRIERUNG: {regime_key} ---")
        new_data = AUDIT_RESULTS[regime_key]

        # Backup der alten Daten für den Vergleich
        self.old_params = self.current_params.copy()

        # Überschreiben
        self.current_params.update({
            "A": new_data["A"],
            "B": new_data["B"],
            "n": new_data["n"]
        })
        self.is_calibrated = True
        print(f"Update abgeschlossen: A={new_data['A']}, n={new_data['n']}")

    def get_ci_curve(self, u_vals):
        """Berechnet die CI-Kurve mit den aktuell geladenen Parametern."""
        A, B, n = self.current_params["A"], self.current_params["B"], self.current_params["n"]
        return np.exp(-A * u_vals - B * (u_vals**n))

# ==============================================================================
# 3. VERGLEICHS-ANALYSE (Alt vs. Neu)
# ==============================================================================
def run_calibration_check():
    u_vals = np.linspace(0, 1.5, 300)
    calibrator = CIQ_Calibrator() # Startet mit Standard-Daten (n=2)

    # Kurve VOR der Kalibrierung (Alte Daten)
    ci_old = calibrator.get_ci_curve(u_vals)

    # Kalibrierung auf die neuen EEG-Daten
    calibrator.apply_audit_patch("EEG_Kollaps_Neu")
    ci_new = calibrator.get_ci_curve(u_vals)

    # Visualisierung
    plt.figure(figsize=(12, 6))
    plt.plot(u_vals, ci_old, 'gray', linestyle='--', label='Alte Daten (Standard n=2.0)')
    plt.plot(u_vals, ci_new, 'purple', linewidth=2.5, label='Kalibrierte Daten (Audit n=1.965)')

    plt.axvline(AUDIT_RESULTS["Eisen_Anker"], color='red', alpha=0.3, label='Eisen-Fixpunkt (0.725)')
    plt.fill_between(u_vals, ci_old, ci_new, color='purple', alpha=0.1, label='Präzisions-Gewinn')

    plt.title("Agent XΩ: System-Kalibrierung (Alt vs. Audit-Ergebnisse)")
    plt.xlabel("Normierte Expansion / Zeit (u)")
    plt.ylabel("Continuity Index (CI)")
    plt.legend()
    plt.grid(True, alpha=0.2)
    plt.tight_layout()
    plt.show()

# Ausführen
run_calibration_check()