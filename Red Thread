class RedThreadEngine:
    def __init__(self, nodes_dict):
        # Core ODE Parameters from documentation
        self.Delta = 0.7
        self.tau = 0.0083
        self.k = 0.15
        self.mu = 0.10
        self.gamma = 0.25
        self.lambda_param = 0.5
        self.beta = 0.12

        # State management
        self.ciq_nodes = nodes_dict

        # Initial States: [z(ZIS), m(M&#246;bius), q(DM), a(Matter), b(BH), c(CIQ), e(Energy)]
        self.X0 = [1.0, 0.01, 0.05, 0.0, 0.0, 0.5, 1.0]
        self.t_span = (0, 50)

    def system_dynamics(self, t, X):
        z, m, q, a, b, c, e = X

        # ODE Logic defined in 'CIQ Red-Thread ODE Engine v1.0.md'
        dzdt = -0.05 * m * (1 - z) - 0.01 * q
        dmdt = 0.2 * (1 - z) * (self.Delta - abs(self.Delta - c))
        dqdt = self.mu * m * (1 - c) + 0.05 * q * (1 - q)
        dadt = self.k * m * q * c - 0.03 * a
        dbdt = self.gamma * (a**2) * (1 - c) - 0.1 * b
        dcdt = self.lambda_param * (self.Delta - abs(q - a)) - 0.2 * b
        dedt = self.beta * (q + a) - 0.05 * e + 0.3 * b

        return [dzdt, dmdt, dqdt, dadt, dbdt, dcdt, dedt]

    def simulate(self):
        t_eval = np.linspace(self.t_span[0], self.t_span[1], 1000)
        self.sol = solve_ivp(self.system_dynamics, self.t_span, self.X0, t_eval=t_eval, max_step=0.1)
        return self.sol

    def plot_results(self):
