        """Berechnet die strukturelle Integrität."""
        return np.exp(-self.A * u - self.B * (u**self.n))

    def calculate_tax(self, u, ci, shield_active=False):
        """Berechnet die aktuelle Entropie-Steuer pro Zeitschritt."""
        # Standard Hubble-Tension
        tension = self.hubble_base_rate * (1.0 / (ci + 1e-6))

        # Zeta-Schild Logik
