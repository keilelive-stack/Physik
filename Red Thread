            shield_active = True if abs(u - self.engine.u_res) < 0.3 else False

            # Steuer-Audit
            current_tax = self.engine.calculate_tax(u, ci, shield_active)
            cum_tax += current_tax * dt
            net_info = max(0, 1.0 - cum_tax)

            self.log.append({
                "u": u, "CI": ci, "Net_Info": net_info,
                "Shield": shield_active, "Tax_Rate": current_tax
            })

        return pd.DataFrame(self.log)

